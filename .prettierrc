{
  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.md", "*.mdc"],
      "options": {
        "proseWrap": "preserve",
        "embeddedLanguageFormatting": "off"
      }
    },
    {
      "files": ["package.json", "tsconfig.json", "tsconfig.*.json"],
      "options": {
        "printWidth": 120
      }
    }
  ]
}
