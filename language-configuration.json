{
  "comments": {
    "lineComment": "'"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "(?i)^\\s*(Namespace|Class|Structure|Enum|Sub|Function|Property|Get|Set|For|If|Else|ElseIf|Select\\s+Case|Case|Do|While|With|Using|Match|Try|Catch|Finally)\\b",
    "decreaseIndentPattern": "(?i)^\\s*(End|Next|Loop|Else|ElseIf|Case|Catch|Finally)\\b"
  }
}
