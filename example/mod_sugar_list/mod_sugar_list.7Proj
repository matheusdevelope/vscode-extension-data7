  <Codigo>Imports mod_tlist
Imports mod_product
Dim _names As TTList_String = New TTList_String()
_names.Push(&quot;Produto 1&quot;)
_names.Push(&quot;Produto 2&quot;)
_names.Push(&quot;Produto 3&quot;)
Dim _prods As TTList_Product = New TTList_Product()
_prods.Push(New Product(0, &quot;Manual&quot;))
Dim __src0 As TTList_Product = New TTList_Product()
Dim __idx0 As Integer
For __idx0 = 0 To _names.Length - 1
   Dim pName As String = _names.GetItem(__idx0)
   Dim pIndex As Integer = __idx0
   __src0.Push(New Product(pIndex + 1, pName))
Next
_prods.Push(__src0)
Dim __idx1 As Integer
For __idx1 = 0 To _prods.Length - 1
   Dim p As Product = _prods.GetItem(__idx1)
   print(p.ToString())
Next
Dim _last As Product = _prods.Pop()
print _last.ToString()
&apos; O ToString não apacere no autocomplete de _prods, o linter não acusa erro na IDE e nem no build.
&apos; pelo que pude notar, nenhum metodo ou prop das classes de herança da TTList aparece no autocomplete, mas o linter e o build reconhecem normalmente.
print _prods.ToString()</Codigo>
