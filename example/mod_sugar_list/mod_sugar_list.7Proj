      End Function
      Function Pop() As String
         Dim _extracted As TTObject = me._base.Pop()
         Pop = me.Unwrap(_extracted)
         If Assigned(_extracted) Then
            _extracted.Free()
         End If
      End Function
      Function Shift() As String
         Dim _extracted As TTObject = me._base.Shift()
         Shift = me.Unwrap(_extracted)
         If Assigned(_extracted) Then
            _extracted.Free()
         End If
      End Function
      Sub Unshift(pValue As String)
         me.Unshift(0, pValue)
      End Sub
      Function Includes(pValue As String) As Boolean
         Dim i As Integer
         Dim _len As Integer = me.Length
         For i = 0 To _len - 1
            Dim _current As String = me.Take(i)
            Dim _equal As Boolean = me.GetIsEqual(_current, pValue)
            If _equal Then
               Includes = True
               Exit Function
            End If
         Next
         Includes = False
      End Function
      Function GetIsEqual(pValue1 As String, pValue2 As String) As Boolean
         GetIsEqual = (pValue1 = pValue2)
      End Function
      Function Join(pSeparator As String) As String
         Dim _str As String = &quot;&quot;
         Dim i As Integer
         Dim _len As Integer = me.Length
         For i = 0 To _len - 1
            If i &gt; 0 Then _str = _str &amp; pSeparator
            Dim _val As String = me.Take(i)
            _str = _str &amp; CStr(me.GetToString(_val))
         Next
         Join = _str
