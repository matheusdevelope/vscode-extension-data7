   Class TTItem_String
      Inherits TTObject
      Private _id As String
      Value As String
      Property ID As String
         Get
            ID = me._id
         End Get
      End Property
      Sub New(pValue As String)
         MyBase.New()
         me._init(&quot;&quot;, pValue)
      End Sub
      Sub New(pID As String, pValue As String)
         MyBase.New()
         me._init(pID, pValue)
      End Sub
      Sub New(pValue As TTItem_String)
         MyBase.New()
         me.Assign(pValue)
      End Sub
      Private Sub _init(pID As String, pValue As String)
         pID = pID.Trim()
         If pID &lt;&gt; &quot;&quot; Then
