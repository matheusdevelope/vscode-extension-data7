      <Codigo>
Imports mod_event_emitter
Imports mod_logger_info
Imports mod_logger_formater
Imports mod_logger_transport

Namespace mod_logger

   Class LoggerOptions

      Silent As Boolean
      Format As Formater
      Level As Integer = LogLevel.Info
      StrictLevel As Boolean
      exitOnError As Integer

      Transports As TransportList

      Sub New()
         MyBase.New()
         me.Transports = New TransportList()
      End Sub

      Sub New(pOptions As LoggerOptions)
         Mybase.New()
         me.Fill(pOptions)
      End Sub

      Sub Fill(pValue As LoggerOptions)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Silent = .Silent
            me.Format = .Format
            me.Level = .Level
            me.StrictLevel = .StrictLevel
            me.exitOnError = .exitOnError
            me.Transports = .Transports
         End With
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class


   Class Logger
      Inherits EventEmitter

      Options As LoggerOptions = New LoggerOptions()

      Sub New()
         Mybase.New()
      End Sub

      Sub New(pValue As LoggerOptions)
         Mybase.New()
         me.Configure(pValue)
      End Sub

      Sub Configure(pValue As LoggerOptions)
         me.Options.Transports.Clean()
         me.Options.Fill(pValue)
      End Sub

      Sub Log(pLevel As Integer, pMessage As String, pExtra As String = "")
         IF me.Options.Transports.Count = 0
            Throw New Exception("Nenhum transporte de logs foi adicionado, verifique!")
         End If
         If me.Options.Silent OR ((me.Options.StrictLevel AND me.Options.Level &lt;&gt; pLevel) OR (NOT me.Options.StrictLevel AND pLevel &gt; me.Options.Level))
            Exit Sub
         End If
         Dim _info As New LogInfo(pMessage, pLevel, pExtra)
         Dim i As Integer, count As Integer = me.Options.Transports.Count
         For i = 0 To count - 1
            me.Options.Transports.Take(i)._write(_info, NULL)
         Next
      End Sub

      Sub Log(pLevel As Integer, pMessage As String, pException As Exception)
         me.Log(pLevel, pMessage, pException._GetMessage())
      End Sub

      Sub Log(pLevel As Integer, pMessage As String, pExtra As Variant)
         me.Log(pLevel, pMessage, CStr(pExtra))
      End Sub

      Sub Log(pLevel As String, pMessage As String)
         me.Log(LogLevel.FromString(pLevel), pMessage)
      End Sub

      Sub Log(pLevel As String, pMessage As String, pException As Exception)
         me.Log(LogLevel.FromString(pLevel), pMessage, pException)
      End Sub

      Sub Log(pLevel As String, pMessage As String, pExtra As Variant)
         me.Log(LogLevel.FromString(pLevel), pMessage, pExtra)
      End Sub

      Sub Info(pMessage As String)
         me.Log(LogLevel.Info, pMessage)
      End Sub

      Sub Info(pMessage As String, pException As Exception)
         me.Log(LogLevel.Info, pMessage, pException)
      End Sub

      Sub Info(pMessage As String, pExtra As Variant)
         me.Log(LogLevel.Info, pMessage, pExtra)
      End Sub

      Sub Warn(pMessage As String)
         me.Log(LogLevel.Warn, pMessage)
      End Sub

      Sub Warn(pMessage As String, pException As Exception)
         me.Log(LogLevel.Warn, pMessage, pException)
      End Sub

      Sub Warn(pMessage As String, pExtra As Variant)
         me.Log(LogLevel.Warn, pMessage, pExtra)
      End Sub

      Sub Debug(pMessage As String)
         me.Log(LogLevel.Debug, pMessage)
      End Sub

      Sub Debug(pMessage As String, pException As Exception)
         me.Log(LogLevel.Debug, pMessage, pException)
      End Sub

      Sub Debug(pMessage As String, pExtra As Variant)
         me.Log(LogLevel.Debug, pMessage, pExtra)
      End Sub

      Sub Erro(pMessage As String)
         me.Log(LogLevel.Erro, pMessage)
      End Sub

      Sub Erro(pMessage As String, pException As Exception)
         me.Log(LogLevel.Erro, pMessage, pException)
      End Sub

      Sub Erro(pMessage As String, pExtra As Variant)
         me.Log(LogLevel.Erro, pMessage, pExtra)
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace
</Codigo>
