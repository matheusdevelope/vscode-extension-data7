    <mod_event_emitter>
      <Codigo>imports Collections
imports mod_base_list

Namespace mod_event_emitter

   Delegate Sub DelegateCallback(pEvent As String)
   Delegate Sub DelegateCallbackVar(pEvent As String, pData As Variant)
   Delegate Sub DelegateCallbackObj(pEvent As String, pData As TObject)

   Class EventEmitter

      Public Events As EventCallbackList
      Public AvailableEvents As StringList
      Public CheckEvents As Boolean = False
      Public MaxListeners As Integer = -1

      Sub New()
         MyBase.New()
         me.events = New EventCallbackList()
         me.AvailableEvents = New StringList()
      End Sub

      Function Listen(pCallback As EventCallback) As EventCallback
         me.CheckEventIsValid(pCallback.EventName)
         me.CheckMaxListeners()
         me.events.Add(pCallback)
         Return me.events.Last
      End Function

      Function Listen(pEvent As String, pCallback As DelegateCallback) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         Return me.events.Last
      End Function

      Function ListenVar(pEvent As String, pCallback As DelegateCallbackVar) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         Return me.events.Last
      End Function

      Function ListenObj(pEvent As String, pCallback As DelegateCallbackObj) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         Return me.events.Last
      End Function

      Sub Emit(pEvent As String)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer
         For i = 0 To _events.Count - 1
            IF _events.Take(i).Callback &lt;&gt; NULL
               _events.Take(i).Callback(pEvent)
            End If
         Next
      End Sub

      Sub Emit(pEvent As String, pData As TObject)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer
         For i = 0 To _events.Count - 1
            IF _events.Take(i).CallbackObj &lt;&gt; NULL
               _events.Take(i).CallbackObj(pEvent, pData)
            End If
         Next
      End Sub

      Sub Emit(pEvent As String, pData As Variant)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer
         For i = 0 To _events.Count - 1
            IF _events.Take(i).CallbackVar &lt;&gt; NULL
               _events.Take(i).CallbackVar(pEvent, pData)
            End If
         Next
      End Sub

      Sub EmitObj(pEvent As String, pData As TObject)
         me.Emit(pEvent, pData)
      End Sub

      Sub Off(pIdCallback As Integer)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i).ID &lt;&gt; pIdCallback
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pCallback As EventCallback)
         me.CheckEventIsValid(pCallback.EventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i) &lt;&gt; pCallback
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pEventName As String, pCallback As DelegateCallback)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).Callback &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pEventName As String, pCallback As DelegateCallbackVar)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).CallbackVar &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub OffObj(pEventName As String, pCallback As DelegateCallbackObj)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).CallbackObj &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub RemoveListeners(pEventName As String)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer
         For i = 0 To me.events.Count - 1
            IF me.events.Take(i).EventName &lt;&gt; pEventName
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub RemoveListeners()
         me.events.Clean()
      End Sub

      Function Listeners(pEventName As String = "") As EventCallbackList
         If pEventName &lt;&gt; ""
            Return me.events.Filter(me.FilterEventsByName, pEventName)
         Else
            Return me.events
         End If
      End Function

      Private Sub CheckEventIsValid(pEvent As String)
         IF me.CheckEvents
            pEvent = pEvent.ToLower
            me.AvailableEvents.Text = me.AvailableEvents.Text.ToLower
            IF me.AvailableEvents.IndexOf(pEvent) = -1
               Throw new System.Exception("The event [" + pEvent + "] is not aceppted." + CHAR(13) + "Available events:" + CHAR(13) + me.AvailableEvents.Text)
            End IF
         End IF
      End Sub

      Private Sub CheckMaxListeners()
          If Me.MaxListeners &gt; -1 AND Me.Events.Count = Me.MaxListeners
              Throw New System.Exception("Número máximo de listeners atingido (" + Me.MaxListeners.ToString + "). Não é possível adicionar mais listeners.")
          End If
      End Sub

      Private Function FilterEventsByName(pValue As EventCallback, i As Integer, extra As Variant) As Boolean
         Dim _extra As String = CStr(extra)
         Return pValue.EventName.ToUpper = _extra.ToUpper
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Class EventCallback

      Public ReadOnly EventName As String
      Public ReadOnly CallbackVar As DelegateCallbackVar
      Public ReadOnly CallbackObj As DelegateCallbackObj
      Public ReadOnly Callback As DelegateCallback

      Sub New()
         MyBase.New()
      End Sub

      Sub New(pEventName As String, pCallbackWithoutData As DelegateCallback)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = NULL
         me.CallbackObj = NULL
         me.Callback = pCallbackWithoutData
      End Sub

      Sub New(pEventName As String, pCallbackObj As DelegateCallbackObj)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = NULL
         me.CallbackObj = pCallbackObj
         me.Callback = NULL
      End Sub

      Sub New(pEventName As String, pCallback As DelegateCallbackVar)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = pCallback
         me.CallbackObj = NULL
         me.Callback = NULL
      End Sub


      Sub New(pEventName As String, pCallback As DelegateCallbackVar, pCallbackObj As DelegateCallbackObj, pCallbackWithoutData As DelegateCallback)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = pCallback
         me.CallbackObj = pCallbackObj
         me.Callback = pCallbackWithoutData
      End Sub

      Sub New(pEventCallback As EventCallback)
         MyBase.New()
         me.Fill(pEventCallback)
      End Sub

      Function Id() As Integer
         Return me.GetHashCode
      End Function

      Sub Fill(pEventCallback As EventCallback)
         IF pEventCallback = NULL
            Exit Sub
         End If
         With pEventCallback
            me.EventName = .EventName
            me.CallbackVar = .CallbackVar
            me.CallbackObj = .CallbackObj
            me.Callback = .Callback
         End With
      End Sub

      Function Copy() As EventCallback
         Return New EventCallback(me)
      End Function

      Function GetId() As String
         Return me.GetHashCode.ToString
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function FindDelegate(pValue As EventCallback, i As Integer, extra As Variant) As Boolean
   Delegate Function MapDelegate(pValue As EventCallback, i As Integer, extra As Variant) As EventCallback
   Delegate Sub ForEachDelegate(pValue As EventCallback, i As Integer, extra As Variant)

   Class EventCallbackList
      Inherits BaseList

      Sub New()
         MyBase.New()
         me.OwnsObjects = False
      End Sub

      ' Do if you need a custom ID, the default is the HashCode of class
      Sub Add(pValue As EventCallback)
         'MyBase.Add(pValue, pValue.GetHashCode.ToString)    'Default class ID used in BaseList
         MyBase.Add(pValue.GetID.ToString, pValue)
      End Sub

      Function Take(index As integer) As EventCallback
         Return EventCallback(MyBase.Take(index))
      End Function

      Function Take(pID As String) As EventCallback
         Return EventCallback(MyBase.TakeFromId(pID))
      End Function

      Function First As EventCallback
         Return EventCallback(MyBase.First)
      End Function

      Function Last As EventCallback
         Return EventCallback(MyBase.Last)
      End Function

      Function Copy As EventCallbackList
         Dim values As New EventCallbackList()
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 to _count -1
            values.Add(New EventCallback(EventCallback(me._list.Objects(i))))
         Next
         Return values
      End Function

      Function IndexOf(handler As FindDelegate) As Integer
         Return me.IndexOf(handler, "")
      End Function

      Function IndexOf(handler As FindDelegate, extra As Variant) As Integer
         Return MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As FindDelegate) As EventCallback
         Return me.Find(handler, "")
      End Function

      Function Find(handler As FindDelegate, extra As Variant) As EventCallback
         Return EventCallback(MyBase.Find(handler, extra))
      End Function

      Function Filter(handler As FindDelegate) As EventCallbackList
         Return me.Filter(handler, "")
      End Function

      Function Filter(handler As FindDelegate, extra As Variant) As EventCallbackList
         Return EventCallbackList(MyBase.Filter(handler, extra))
      End Function

      Sub ForEach(handler As FindDelegate)
         me.ForEach(handler, "")
      End Sub

      Sub ForEach(handler As ForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As FindDelegate) As EventCallbackList
         Return me.Map(handler, "")
      End Function

      Function Map(handler As MapDelegate, extra As Variant) As EventCallbackList
       Return EventCallbackList(MyBase.Map(handler, extra))
      End Function

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True)
         me.Sort(handlerGetPropValue, pAsc, "")
      End Sub

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True, pExtra As Variant)
         MyBase.Sort(handlerGetPropValue, pAsc, pExtra)
      End Sub

      Function ToString(pPrint As Boolean = True) As String
         'Dim i As Integer, _count As Integer = me.Count, txt As New Collections.StringList()
         'txt.Add("EventCallback Count:" + _count.ToString)
         'For i = 0 to _count -1
         '   txt.Add(EventCallback(MyBase.Take(i)).ToString(False))
         'Next
         If pPrint
            print "EventCallbackList" 'txt.Text
         End If
         ToString = "EventCallbackList" 'txt.Text
         'txt.Free()
      End Function

      'Function ToJson As TJSONArray
      '   Dim i As Integer, _count As Integer = me.Count, list As New TJSONArray()
      '   For i = 0 to _count -1
      '      list.PutObject(EventCallback(MyBase.Take(i)).ToJson())
      '   Next
      '   Return list
      'End Function

      'Shared Function FromJson(pList As TJSONArray) As EventCallbackList
      '   Dim i As Integer, _count As Integer = pList.Length , list As New EventCallbackList()
      '   For i = 0 to _count -1
      '      list.Add(EventCallback.FromJson(pList.GetJSONObject(i)))
      '   Next
      '   Return list
      'End Function

      Sub Free()
         If NOT me.OwnsObjects
            Dim i As Integer, _count As Integer = me.Count
            For i = 0 To _count - 1
               EventCallback(MyBase.Take(i)).Free()
            Next
         End If
         MyBase.Free()
      End Sub

   End Class

