Imports mod_base_list
Imports mod_event_emitter
Imports mod_logger_info
Imports mod_logger_formater

Namespace mod_logger_transport

   Delegate Sub DelegateCallback(pInfo As LogInfo)

   Class TransportOptions
      Private _Level As Integer
      StrictLevel As Boolean
      HandleExceptions As Boolean
      Silent As Boolean
      Format As Formater

      Property Level As Integer
         Get
            print "getting: " + me._level.ToString
            Return me._level
         End Get
         Set(pValue As Integer)
            print "setting: " + pValue.ToString
            me._level = pValue
         End Set
      End property

      Sub New()
         MyBase.New()
         me.Level = LogLevel.Info
         me.Format = New Formater()
      End Sub

      Sub New(pLevel As Integer, pHandleExceptions As Boolean, pSilent As Boolean, pFormat As Formater)
         Mybase.New()
         me.Level = pLevel
         me.HandleExceptions = pHandleExceptions
         me.Silent = pSilent
         me.Format = pFormat
      End Sub

      Sub Fill(pValue As TransportOptions)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Level = .Level
            me.HandleExceptions = .HandleExceptions
            me.Silent = .Silent
            me.Format = .Format
         End With
      End Sub

      Sub Free()
         me.Format.Free()
         MyBase.Free()
      End Sub

   End Class

   Class Transport
      Inherits EventEmitter

      Overridable Options As TransportOptions = New TransportOptions()

       Sub New()
           MyBase.New()
       End Sub

       Sub New(pOptions As TransportOptions)
           MyBase.New()
           me.Options.Fill(pOptions)
       End Sub

       Sub New(pValue As Transport)
           MyBase.New()
           me.Options.Fill(pValue.Options)
       End Sub

       Sub _write(pInfo As LogInfo, pCallback As DelegateCallback)

          print me.Options.StrictLevel.ToString + ":   " + me.Options.Level.ToString + " - " + pInfo.Level.ToString

          '(pInfo.IsException AND NOT me.Options.HandleExceptions) OR

          If (pInfo.IsException AND NOT me.Options.HandleExceptions) OR me.Options.Silent OR ((me.Options.StrictLevel AND me.Options.Level &lt;&gt; pInfo.Level) OR (NOT me.Options.StrictLevel AND pInfo.Level &gt; me.Options.Level))
          'print me.Options.Silent OR (me.Options.StrictLevel AND me.Options.Level &lt;&gt; pInfo.Level) 'OR (NOT me.Options.StrictLevel AND pInfo.Level &gt; me.Options.Level)
          'If (pInfo.IsException AND NOT me.Options.HandleExceptions) OR me.Options.Silent OR (NOT me.Options.StrictLevel AND me.Options.Level &lt; pInfo.Level) OR (me.Options.StrictLevel AND me.Options.Level &lt;&gt; pInfo.Level) Then
             IF pCallback &lt;&gt; NULL
                pCallback(pInfo)
             End If
             Exit Sub
          End If

          pInfo = me.Options.Format.Transform(pInfo, me.Options.Format.Options)
          me.Log(pInfo, pCallback)
       End Sub

       Overridable Sub Log(pInfo As LogInfo, pCallback As DelegateCallback)
          Throw New Exception("Method Not Implemented")
       End Sub

       Function GetID As String
          Return me.GetHashCode.ToString()
       End Function

       Sub Free()
          MyBase.Free()
       End Sub

   End Class

   Delegate Function FindDelegate(pValue As Transport, i As Integer, extra As Variant) As Boolean
   Delegate Function MapDelegate(pValue As Transport, i As Integer, extra As Variant) As Transport
   Delegate Sub ForEachDelegate(pValue As Transport, i As Integer, extra As Variant)

   Class TransportList
      Inherits BaseList

      Sub New()
         MyBase.New()
         me.OwnsObjects = False
      End Sub

      ' Do if you need a custom ID, the default is the HashCode of class
      Sub Add(pValue As Transport)
         'MyBase.Add(pValue, pValue.GetHashCode.ToString)    'Default class ID used in BaseList
         MyBase.Add(pValue.GetID.ToString, pValue)
      End Sub

      Function Take(index As integer) As Transport
         Return Transport(MyBase.Take(index))
      End Function

      Function Take(pID As String) As Transport
         Return Transport(MyBase.TakeFromId(pID))
      End Function

      Function First As Transport
         Return Transport(MyBase.First)
      End Function

      Function Last As Transport
         Return Transport(MyBase.Last)
      End Function

      Function Copy As TransportList
         Dim values As New TransportList()
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 to _count -1
            values.Add(New Transport(Transport(me._list.Objects(i))))
         Next
         Return values
      End Function

      Function IndexOf(handler As FindDelegate) As Integer
         Return me.IndexOf(handler, "")
      End Function

      Function IndexOf(handler As FindDelegate, extra As Variant) As Integer
         Return MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As FindDelegate) As Transport
         Return me.Find(handler, "")
      End Function

      Function Find(handler As FindDelegate, extra As Variant) As Transport
         Return Transport(MyBase.Find(handler, extra))
      End Function

      Function Filter(handler As FindDelegate) As TransportList
         Return me.Filter(handler, "")
      End Function

      Function Filter(handler As FindDelegate, extra As Variant) As TransportList
         Return TransportList(MyBase.Filter(handler, extra))
      End Function

      Sub ForEach(handler As FindDelegate)
         me.ForEach(handler, "")
      End Sub

      Sub ForEach(handler As ForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As FindDelegate) As TransportList
         Return me.Map(handler, "")
      End Function

      Function Map(handler As MapDelegate, extra As Variant) As TransportList
       Return TransportList(MyBase.Map(handler, extra))
      End Function

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True)
         me.Sort(handlerGetPropValue, pAsc, "")
      End Sub

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True, pExtra As Variant)
         MyBase.Sort(handlerGetPropValue, pAsc, pExtra)
      End Sub

      Function ToString(pPrint As Boolean = True) As String
         'Dim i As Integer, _count As Integer = me.Count, txt As New Collections.StringList()
         'txt.Add("Transport Count:" + _count.ToString)
         'For i = 0 to _count -1
         '   txt.Add(Transport(MyBase.Take(i)).ToString(False))
         'Next
         If pPrint
            print "TransportList" 'txt.Text
         End If
         ToString = "TransportList" 'txt.Text
         'txt.Free()
      End Function

      'Function ToJson As TJSONArray
      '   Dim i As Integer, _count As Integer = me.Count, list As New TJSONArray()
      '   For i = 0 to _count -1
      '      list.PutObject(Transport(MyBase.Take(i)).ToJson())
      '   Next
      '   Return list
      'End Function

      'Shared Function FromJson(pList As TJSONArray) As TransportList
      '   Dim i As Integer, _count As Integer = pList.Length , list As New TransportList()
      '   For i = 0 to _count -1
      '      list.Add(Transport.FromJson(pList.GetJSONObject(i)))
      '   Next
      '   Return list
      'End Function

      Sub Free()
         If NOT me.OwnsObjects
            Dim i As Integer, _count As Integer = me.Count
            For i = 0 To _count - 1
               Transport(MyBase.Take(i)).Free()
            Next
         End If
         MyBase.Free()
      End Sub

   End Class

End Namespace
</Codigo>
