    <mod_logger_formater>
      <Codigo>
Imports mod_logger_info

Namespace mod_logger_formater

   Class Formater

      Options As TJSONObject = New TJSONObject()

      Sub New()
         MyBase.New()
      End Sub

      Overridable Function Transform(pInfo As LogInfo, pOptions As TJSONObject) As LogInfo
         pInfo.Message = "[" + LogLevel.AsString(pInfo.Level) + "] " + pInfo.Message
         Return pInfo
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Class FormaterWithTime
      Inherits Formater

      Sub New()
         MyBase.New()
      End Sub

      Overrides Function Transform(pInfo As LogInfo, pOptions As TJSONObject) As LogInfo
         print "Aqui"
         pInfo.Message = "[" + LogLevel.AsString(pInfo.Level) + "] " + "[" + pInfo.Time.ToString("DD-MM-YYYY HH:NN:SS.ZZZ") + "]" +  pInfo.Message
         Return pInfo
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace
