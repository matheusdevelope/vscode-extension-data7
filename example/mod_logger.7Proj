      <Codigo>Imports Collections

Namespace mod_base_list

   Delegate Function FindDelegate(pValue As TObject, i As Integer, extra As Variant) As Boolean
   Delegate Function MapDelegate(pValue As TObject, i As Integer, extra As Variant) As TObject
   Delegate Function SortPropDelegate(pValue As TObject, i As Integer, extra As Variant) As String
   Delegate Sub ForEachDelegate(pValue As TObject, i As Integer, extra As Variant)

   Class BaseList
      'Private
      _list As StringList

      Sub New()
         MyBase.New()
         me._list = New StringList()
         me.OwnsObjects = False
      End Sub

      Property OwnsObjects As Boolean
         Get
            Return me._list.OwnsObjects
         End Get
         Set(pValue As Boolean)
            me.SetOwnsObjects(pValue)
         End Set
      End Property

      Property Sorted As Boolean
         Set(pValue As Boolean)
            me.SetSorted(pValue)
         End Set
      End Property

      Sub Add(pValue As TObject)
         me._list.AddObject(pValue.GetHashCode.ToString, pValue)
      End Sub

      Sub Add(pID As String, pValue As TObject)
         me._list.AddObject(pID.ToUpper, pValue)
      End Sub

      Sub Add(pValues As BaseList)
         Dim i As Integer
         For i = 0 To pValues.Count - 1
             me.Add(pValues.Take(i))
         Next
      End Sub

      Sub AddWithId(pID As String, pValue As TObject)
         me.Add(pID.ToUpper, pValue)
      End Sub

      Function Take(pID As String) As TObject
         Return me.Take(me.IndexOf(pID))
      End Function

      Function Take(index As Integer) As TObject
         Return me._list.Objects(index)
      End Function

      Function TakeFromId(pID As String) As TObject
         Return me.Take(pID)
      End Function

      Function Has(pID As String) As Boolean
         Return me.IndexOf(pID) &lt;&gt; -1
      End Function

      Function IndexOf(pID As String) As Integer
         pID = pID.ToUpper
         Return me._list.IndexOf(pID)
      End Function

      Function IndexOf(handler As FindDelegate) As Integer
         Return me.IndexOf(handler, "")
      End Function

      Function IndexOf(handler As FindDelegate, extra As Variant) As Integer
         Dim value As Integer = -1
         Dim i As Integer
         For i = 0 to me.Count -1
             If handler(me.Take(i), i, extra)
                value = i
                Exit For
             End IF
         Next
         Return value
      End Function

      Function Find(handler As FindDelegate) As TObject
         Return me.Find(handler, "")
      End Function

      Function Find(handler As FindDelegate, extra As Variant) As TObject
         Dim value As TObject
         Dim i As Integer
         For i = 0 to me.Count -1
             If handler(me.Take(i), i, extra)
                value = me.Take(i)
                Exit For
             End IF
         Next
         Return value
      End Function

      Function Filter(handler As FindDelegate) As BaseList
         Return me.Filter(handler, "")
      End Function

      Function Filter(handler As FindDelegate, extra As Variant) As BaseList
         Dim _new As New BaseList()
         Dim i As Integer
         For i = 0 To me.Count - 1
             IF handler(me.Take(i), i, extra)
                _new.Add(me.Take(i))
             End IF
         Next
         Return _new
      End Function

      Sub ForEach(handler As FindDelegate)
         me.ForEach(handler, "")
      End Sub

      Sub ForEach(handler As ForEachDelegate, extra As Variant)
         Dim i As Integer
         For i = 0 To me.Count - 1
             handler(me.Take(i), i, extra)
         Next
      End Sub

      Function Map(handler As FindDelegate) As BaseList
         Return me.Map(handler, "")
      End Function

      Function Map(handler As MapDelegate, extra As Variant) As BaseList
         Dim _new As New BaseList()
         Dim i As Integer
         For i = 0 To me.Count - 1
             _new.Add(handler(me.Take(i), i, extra))
         Next
         Return _new
      End Function

      Function First() As TObject
         If me.count &gt; 0
            Return me.Take(0)
         End If
         Return NULL
      End Function

      Function Last() As TObject
         Dim i As Integer = me.Count -1
         If me.count &gt; 0
            Return me.Take(i)
         End If
         Return NULL
      End Function

      Function Copy() As BaseList
         Dim values As New BaseList
         Dim i As Integer
         For i = 0 to me.Count -1
            values.Add(me.Take(i))
         Next
         Return values
      End Function

      Function Count() As Integer
         Return me._list.Count
      End Function

      Sub Delete(index as integer)
         me._list.Delete(index)
      End Sub

      Sub Delete(pID As String)
         _list.Delete(me.IndexOf(pID))
      End Sub

      Sub Clean()
         me._list.Clear()
      End Sub

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True)
         me.Sort(handlerGetPropValue, pAsc, "")
      End Sub

      Sub Sort(handlerGetPropValue As SortPropDelegate, pAsc As Boolean = True, pExtra As Variant)
         If handlerGetPropValue &lt;&gt; NULL

            Dim listTemp As New StringList, i As Integer
            Dim count As Integer = me.Count
            For i = 0 To count - 1
               Dim item As TObject = me._list.Objects(i)
               Dim prop_value As String = handlerGetPropValue(item, i, pExtra)
               ' Adiciona o item atual na lista temporária usando a prop como ID
               listTemp.AddObject(prop_value, item)
            Next
            ' Ordena a lista temporária
            listTemp.Sorted = True

            ' Recria a lista atual baseado na lista temporária ordenada pelo valor da propriedade retornada
            Dim tempOwnsObjects As Boolean = me.OwnsObjects
            me.OwnsObjects = False
            me.Clean()
            count = listTemp.Count

            For i = 0 To count - 1
               Dim idx As Integer = i
               If Not pAsc
                  idx = count - i - 1
               End If
               me.Add(listTemp.Objects(idx))
            Next
            me.OwnsObjects = tempOwnsObjects

            listTemp.Free()
         Else
            Throw New Exception("You must send a handler")
         End If
      End Sub

      Sub ToString(pNameList As String = "Base")
         print(pNameList + " Count: " + me.Count.ToString())
         Dim i As Integer
         For i = 0 to me.Count -1
             me.Take(i).toString()
         Next
      End Sub

      Sub ListToString
         print me._list.Text
      End Sub

      Sub Free()
         me._list.Free()
         MyBase.Free()
      End Sub

      Private Sub SetOwnsObjects(pValue As Boolean)
         me._list.OwnsObjects = pValue
      End Sub

      Private Sub SetSorted(pValue As Boolean)
         me._list.Sorted = pValue
      End Sub

   End Class

End Namespace</Codigo>
