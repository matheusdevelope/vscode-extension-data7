Namespace mod_logger_info

   Class LogLevel

      Shared Function Erro As Integer
         Return 0
      End Function

      Shared Function Warn As Integer
         Return 1
      End Function

      Shared Function Info As Integer
         Return 2
      End Function

      Shared Function Debug As Integer
         Return 3
      End Function

      Shared Function AsString(pLevel As Integer) As String
         Select pLevel
            Case 0
               Return "ERROR"
            Case 1
               Return "WARN"
            Case 2
               Return "INFO"
            Case 3
               Return "DEBUG"
            Case Else
               Return "Level Not Defined (" + pLevel.toString + ")"
         End Select
      End Function

      Shared Function FromString(pLevel As String) As Integer
         pLevel = pLevel.ToUpper
         Select pLevel
            Case "ERROR"
               Return 0
            Case "WARN"
               Return 1 
            Case "INFO"
               Return 2 
            Case "DEBUG"
               Return 3 
            Case Else
               Return -1
         End Select
      End Function

   End Class

   Class LogInfo
      Message As String
      Time As TDateTime = DateTime()
      Level As Integer
      Duration As Integer
      IsException As Boolean
      Extra As String

      Sub New()
         Mybase.New()
      End Sub

      Sub New(pMessage As String, pLevel As Integer, pExtra As String = "")
         Mybase.New()
         me.Message = pMessage
         me.Level = pLevel
         me.Extra = pExtra
      End Sub


      Sub New(pMessage As String, pTime As TDateTime, pLevel As Integer, pDuration As Integer = 0, pIsException As Boolean = False, pExtra As String = "")
         Mybase.New()
         me.Message = pMessage
         me.Time = pTime
         me.Level = pLevel
         me.Duration = pDuration
         me.isException = pIsException
         me.Extra = pExtra
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace
