      Value As Product

      Sub New(pID As String, pValue As Product)
         MyBase.New()
         pID = Trim(pID)
         If pID &lt;&gt; "" Then
            me.ID = pID
         Else
            me.ID = CStr(me.GetHashCode)
         End If
         me.Value = pValue
      End Sub

      Sub New(pValue As Product)
