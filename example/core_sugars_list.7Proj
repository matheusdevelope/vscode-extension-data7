      Function IndexOf(pHandler As TObjectFindDelegate, extra As Variant) As Integer
         Dim value As Integer = -1
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               value = i
               Exit For
            End IF
         Next
         IndexOf = value
