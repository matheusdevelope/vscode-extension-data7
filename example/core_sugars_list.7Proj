      Function Filter(pHandler As TObjectFindDelegate, extra As Variant) As TTObjectList
         Dim _new As New TTObjectList()
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               _new.Add(TTObjectItem(MyBase.Take(i)).Copy())
            End IF
         Next
         Filter = _new
      End Function

      Sub ForEach(pHandler As TObjectForEachDelegate)
         me.ForEach(pHandler, "")
      End Sub

      Sub ForEach(pHandler As TObjectForEachDelegate, extra As Variant)
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            pHandler(me.Take(i), i, extra)
         Next
      End Sub

      Function Map(pHandler As TObjectMapDelegate) As TTObjectList
