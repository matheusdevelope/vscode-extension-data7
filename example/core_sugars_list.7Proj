         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TTObjectItem)
         If pValue = NULL Then
            Exit Sub
         End If
         me.ID = pValue.ID
         me.Value = pValue.Value
      End Sub

      Overrides Function Copy() As TTObjectItem
         Copy = me 'New TTObjectItem(me)
      End Function

      Overrides Function GetID() As String
