   Class TPrimitiveItem
      Inherits TTObject

      ReadOnly ID As String
      Value As Boolean

      Sub New(pID As String, pValue As Boolean)
         MyBase.New()
         pID = Trim(pID)
         If pID &lt;&gt; "" Then
            me.ID = pID
         Else
            me.ID = CStr(me.GetHashCode)
         End If
         me.Value = pValue
      End Sub

      Sub New(pValue As Boolean)
         MyBase.New()
         me.ID = CStr(me.GetHashCode)
         me.Value = pValue
      End Sub

      Sub New(pValue As TPrimitiveItem)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TPrimitiveItem)
         If pValue = NULL Then
            Exit Sub
         End If
         me.ID = pValue.ID
         me.Value = pValue.Value
      End Sub

      Overrides Function Copy() As TPrimitiveItem
         Copy = New TPrimitiveItem(me)
      End Function

      Overrides Function GetID() As String
         GetID = me.ID
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(me.Classname)
            .Prop("ID", me.ID)
            .Prop("Value", me.Value)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         print "TPrimitiveItem.Dispose: " &amp; me.ID
         me.ID = Unassigned
         me.Value = Unassigned
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Class TPrimitiveList
      Inherits TTObjectList

      Sub New()
         MyBase.New("TPrimitiveList", True)
      End Sub

      Property Item(pIndex As Integer) As Boolean
         Get
            Dim _item As TPrimitiveItem = CType(MyBase.Take(pIndex), TPrimitiveItem)
            If _item &lt;&gt; NULL Then
               Item = _item.Value
            Else
               Item = Unassigned
            End If
         End Get
         Set(pValue As Boolean)
            Dim _item As TPrimitiveItem = CType(MyBase.Take(pIndex), TPrimitiveItem)
            If _item &lt;&gt; NULL Then
               _item.Value = pValue
            End If
         End Set
      End Property

      Sub Add(pID As String, pValue As Boolean)
         me.Add(New TPrimitiveItem(pID, pValue))
      End Sub

      Sub Add(pValue As Boolean)
         me.Add("", pValue)
      End Sub

      Function Take(pIndex As Integer) As Boolean
         Dim _item As TPrimitiveItem = CType(MyBase.Take(pIndex), TPrimitiveItem)
         If _item &lt;&gt; NULL Then
            Take = _item.Value
         Else
            Take = Unassigned
         End If
      End Function

      Function Take(pID As String) As Boolean
         Dim _item As TPrimitiveItem = CType(MyBase.TakeFromId(pID), TPrimitiveItem)
         If _item &lt;&gt; NULL Then
            Take = _item.Value
         Else
            Take = Unassigned
         End If
      End Function

      Function First() As Boolean
         Dim _item As TPrimitiveItem = CType(MyBase.First, TPrimitiveItem)
         If _item &lt;&gt; NULL Then
            First = _item.Value
         Else
            First = Unassigned
         End If
      End Function

      Function Last() As Boolean
         Dim _item As TPrimitiveItem = CType(MyBase.Last, TPrimitiveItem)
         If _item &lt;&gt; NULL Then
            Last = _item.Value
         Else
            Last = Unassigned
         End If
      End Function

      Function Copy() As TPrimitiveList
         Copy = CType(MyBase.Copy(), TPrimitiveList)
      End Function

      Function First(pLimit As Integer) As TPrimitiveList
         First = CType(MyBase.Range(pLimit, False), TPrimitiveList)
      End Function

      Function Last(pLimit As Integer) As TPrimitiveList
         Last = CType(MyBase.Range(pLimit, True), TPrimitiveList)
      End Function

      Function IndexOf(pHandler As TPrimitiveFindDelegate) As Integer
         IndexOf = me.IndexOf(pHandler, "")
      End Function

      Function IndexOf(pHandler As TPrimitiveFindDelegate, extra As Variant) As Integer
         Dim value As Integer = -1
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               value = i
               Exit For
            End IF
         Next
         IndexOf = value
      End Function

      Function Find(pHandler As TPrimitiveFindDelegate) As Boolean
         Find = me.Find(pHandler, "")
      End Function

      Function Find(pHandler As TPrimitiveFindDelegate, extra As Variant) As Boolean
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               Find = me.Take(i)
               Exit Function
            End IF
         Next
         Find = Unassigned
      End Function

      Function Filter(pHandler As TPrimitiveFindDelegate) As TPrimitiveList
         Filter = me.Filter(pHandler, "")
      End Function

      Function Filter(pHandler As TPrimitiveFindDelegate, extra As Variant) As TPrimitiveList
         Dim _new As New TPrimitiveList()
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               _new.Add(TPrimitiveItem(MyBase.Take(i)).Copy())
            End IF
         Next
         Filter = _new
      End Function

      Sub ForEach(pHandler As TPrimitiveForEachDelegate)
         me.ForEach(pHandler, "")
      End Sub

      Sub ForEach(pHandler As TPrimitiveForEachDelegate, extra As Variant)
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            pHandler(me.Take(i), i, extra)
         Next
      End Sub

      Function Map(pHandler As TPrimitiveMapDelegate) As TPrimitiveList
         Map = me.Map(pHandler, "")
      End Function

      Function Map(pHandler As TPrimitiveMapDelegate, extra As Variant) As TPrimitiveList
         Dim _new As New TPrimitiveList()
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            Dim _item As TPrimitiveItem = TPrimitiveItem(MyBase.Take(i)).Copy()
            _item.Value = pHandler(_item.Value, i, extra)
            _new.Add(_item)
         Next
         Map = _new
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

