      Function Find(pHandler As TObjectFindDelegate, extra As Variant) As Product
         Dim i As Integer, _count As Integer = me.Count
         For i = 0 To _count - 1
            If pHandler(me.Take(i), i, extra)
               Find = me.Take(i)
               Exit Function
            End IF
         Next
         Find = NULL
      End Function

      Function Filter(pHandler As TObjectFindDelegate) As TTObjectList
         Filter = me.Filter(pHandler, "")
