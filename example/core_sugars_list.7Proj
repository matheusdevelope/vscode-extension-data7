      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         Dim valStr As String = "NULL"
         If me.Value &lt;&gt; NULL Then
            valStr = me.Value.ToString()
         End If

         With console.Block(me.Classname)
            .Prop("ID", me.ID)
            .Prop("Value", valStr)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.ID = Unassigned
         If me.Value &lt;&gt; NULL Then me.Value.Free()
         me.Value = NULL
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

