# Files excluded from the .vsix package.
# Everything in `src/` is compiled to `out/`; the .ts files don't need to ship.

.vscode/**
.vscode-test/**
src/**
node_modules/**
.gitignore
.gitattributes
.cursor/**
.github/**
*.vsix
**/*.vsix

# Build/dev artefacts
tsconfig.json
**/tsconfig.json
**/*.map
**/*.ts
!out/**/*.d.ts
out/**
!out/extension.js
!out/mcp/
!out/mcp/server.bundled.js
!out/mcp/data/
!out/mcp/data/**
dist/**
coverage/**

# Linter and formatter configs (developer tooling, not runtime).
.editorconfig
.prettierrc
.prettierrc.*
.prettierignore
eslint.config.*
.eslintrc.*
.eslintignore

# MCP resources read the versioned language, example, and official-documentation
# trees at runtime. Keep docs/ in the VSIX so --docs-root remains valid.
project_context.md
CONTRIBUTING.md
scripts/**

# External documentation snapshots that should never be packaged.
Documentacao Classes Form Delphi/**

# Test artefacts
**/*.test.js
out/test/**

# Runtime assets are copied into this package by `npm run package:assets`.
docs/**/node_modules/**
core_modules/**/*.map
