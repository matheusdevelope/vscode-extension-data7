{
  "name": "@data7/core",
  "version": "0.1.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json && npm run mcp:articles && npm run mcp:bundle",
    "watch": "tsc -watch -p ./tsconfig.json",
    "mcp:articles": "node ../../scripts/extract-official-articles.js",
    "mcp:bundle": "esbuild dist/mcp/server.js --bundle --minify --platform=node --target=node22 --outfile=dist/mcp/server.bundled.js",
    "test": "node --test dist/test/**/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.8.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  }
}
