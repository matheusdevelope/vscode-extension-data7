         Dim str2 As String = &quot;NULL&quot;
         If me._missingFieldsOptional &lt;&gt; NULL
            str2 = me._missingFieldsOptional.ToString()
         End If
         Dim str3 As String = &quot;NULL&quot;
         If me._missingFieldsRequired &lt;&gt; NULL
            str3 = me._missingFieldsRequired.ToString()
         End If

         With console.Block(&quot;TValidationResult&quot;)
            .Prop(&quot;Logs&quot;, me.Logs.Text)
            .Prop(&quot;FoundFields&quot;, str1)
            .Prop(&quot;MissingFieldsOptional&quot;, str2)
            .Prop(&quot;MissingFieldsRequired&quot;, str3)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         If me.Logs &lt;&gt; NULL Then me.Logs.Free()
         If me._foundFields &lt;&gt; NULL Then me._foundFields.Free()
         If me._missingFieldsOptional &lt;&gt; NULL Then me._missingFieldsOptional.Free()
         If me._missingFieldsRequired &lt;&gt; NULL Then me._missingFieldsRequired.Free()
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

