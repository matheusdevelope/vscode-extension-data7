    <mod_pipeline_mapper>
      <Codigo>Imports Collections
Imports mod_pipeline_cell
Imports mod_pipeline_field
Imports mod_pipeline_schema
Imports mod_pipeline_window
Imports mod_pipeline_record
Imports mod_pipeline_navigator
Imports mod_pipeline_validation

&apos;@Module-Imported
Namespace mod_pipeline_mapper

   Class TMapper

      Protected _name As String

      ThrowExceptionOnFailure As Boolean = True

      Sub New(pName As String = &quot;TMapper&quot;)
         MyBase.New()
         me._name = pName
      End Sub

      Function Execute(pSchema As TSchema, pNavigator As TNavigator) As TValidationResult
         Dim result As New TValidationResult()
         Dim header As TRecord = pNavigator.GetHeader(pSchema.Window)

         If header = NULL Then
            result.Success = False
            result.Logs.Add(&quot;ERRO: Header não localizado na janela de busca.&quot;)
         Else
            Dim i As Integer, j As Integer
            Dim fieldsCount As Integer = pSchema.Fields.Count - 1
            Dim cellsCount As Integer = header.Cells.Count - 1
            For i = 0 To fieldsCount
                  Dim _field As TField = pSchema.Fields.Take(i)
                  Dim _isFieldFound As Boolean = False
                  For j = 0 To cellsCount
                     Dim _cell As TCell = header.Cells.Take(j)
                     Dim _optionIndex As Integer = _field.Options.IndexOf(_cell.Name)
                     If _optionIndex &gt;= 0 Then
                        _field.IndexOptionFound = _optionIndex
                        _field.Index = j
                        result.FoundFields.Add(_field.Copy())
                        _isFieldFound = True
                        Exit For
                     End If
                  Next
                  If Not _isFieldFound Then
                     If _field.Required Then
                        result.Success = False
                        result.MissingFieldsRequired.Add(_field.Copy())
                     Else
                        result.MissingFieldsOptional.Add(_field.Copy())
                     End If
                  End If
            Next
            me.BuildLogMissingFields(result)
            pSchema.HeaderIndex = header.Index
            pNavigator.Position = header.Index + 1
            header.Free()
         End If
         If Not result.Success And me.ThrowExceptionOnFailure Then
            Throw New Exception(&quot;Falha no mapeamento de campos!&quot; &amp; Chr(13) &amp; Chr(13) &amp; result.Logs.Text)
         End If
         Execute = result
      End Function

      Protected Overridable Sub BuildLogMissingFields(pResult As TValidationResult)
         Dim txt As New StringList()
         Dim i As Integer
         Dim count As Integer = pResult.MissingFieldsRequired.Count - 1
         If count &gt;= 0
            pResult.Logs.Add(&quot;Campos obrigatórios ausentes:&quot;)
            pResult.Logs.Add(&quot;&quot;)
            For i = 0 To count
               Dim _field As TField = pResult.MissingFieldsRequired.Take(i)
               pResult.Logs.Add(&quot;Nome: &quot; + _field.Name)
               pResult.Logs.Add(&quot;Títulos aceitos: [&quot; + _field.Options.AsString() + &quot;]&quot;)
               pResult.Logs.Add(&quot;&quot;)
               pResult.Logs.Add(&quot;&quot;)
            Next
         End If
      End Sub

      Overridable Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TMapper&quot;)
            .Prop(&quot;Name&quot;, me._name)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
