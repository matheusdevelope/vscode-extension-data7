&apos;@Module-Imported
Namespace mod_pipeline_navigator_horizontal

   Class TNavigatorHorizontal
      Inherits TNavigator

      Sub New(pData As TDataSource)
          MyBase.New(&quot;HorizontalNavigator&quot;, pData)
      End Sub

      Overridable Overrides Function GetHeader(pWindow As TWindow) As TRecord
         Dim i As Integer
         Dim count As Integer
         Dim headerIndex As Integer = -1

         count = me.Rows - 1
         For i = pWindow.MinRow To count
            If pWindow.MaxRow &gt;= 0 And i &gt; pWindow.MaxRow Then Exit For
            If CStr(me.GetValueFrom(i, pWindow.MinCol)) &lt;&gt; &quot;&quot; Then
               headerIndex = i
               Exit For
            End If
         Next

         If headerIndex = -1 Then
            Exit Function
         End If

         Dim _record As New TRecord(headerIndex)
         count = me.Columns - 1
         For i = pWindow.MinCol To count
            If pWindow.MaxCol &gt;= 0 And i &gt; pWindow.MaxCol Then Exit For
            Dim _value As String = Utils.Normalize(CStr(me.GetValueFrom(i, headerIndex)))
            If _value &lt;&gt; &quot;&quot; Then
               _record.Cells.Add(New TCell(i, _value))
            End If
         Next

         GetHeader = _record
      End Function

      Overridable Overrides Function GetValue(pIndex As Integer) As Variant
         GetValue = me.GetValueFrom(pIndex, me.Position)
      End Function

      Overridable Overrides Sub SetValue(pIndex As Integer, pValue As Variant)
         me.SetValueFrom(pIndex, me.Position, pValue)
      End Sub

      Protected Overridable Overrides Function _getRecords() As Integer
         _getRecords = me.Rows
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
