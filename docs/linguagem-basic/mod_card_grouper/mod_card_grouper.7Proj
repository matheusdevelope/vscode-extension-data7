    <mod_enum>
      <Codigo>
Imports mod_enum
Imports Collections
Imports mod_base_list

&apos;@Module-Imported
Namespace mod_enum

   Class BaseEnum

      Private Shared _enum_cache As StringList
      Private Shared _enum_cache_initialized As Boolean

      Protected _value As Integer
      Protected _description As String

      Private Sub New(pValue As Integer, pDescription As String)
         MyBase.New()
         me._value = pValue
         me._description = pDescription
      End Sub

      Property AsInteger As Integer
         Get
            Return me._value
         End Get
      End Property

      Property AsString As String
         Get
            Return me._description
         End Get
      End Property

      Function IsValue(pValue As BaseEnum) As Boolean
         IsValue = me.IsValue(pValue.AsInteger)
      End Function

      Function IsValue(pValue As Variant) As Boolean
         Select Case TypeName(pValue)
            Case &quot;String&quot;
               IsValue = UCase(pValue) = UCase(me.AsString)
            Case &quot;Integer&quot;, &quot;Long&quot;, &quot;Byte&quot;
               IsValue = pValue = me.AsInteger
            Case Else
               IsValue = False
         End Select
      End Function

      Protected Shared Function _GetKeyCache(pClassName As String, pEnumName As String) As String
         _GetKeyCache = UCase(pClassName) &amp; &quot;-&quot; &amp; UCase(pEnumName)
      End Function

      Protected Shared Function _IsCached(pClassName As String, pEnumName As String) As Boolean
         If Not _enum_cache_initialized Then Return False
         Dim _key As String = BaseEnum._GetKeyCache(pClassName, pEnumName)
         _IsCached = _enum_cache.IndexOf(_key) &gt;= 0
      End Function

      Protected Shared Sub _AddCache(pClassName As String, pEnumName As String, pEnum As BaseEnum)
         If Not _enum_cache_initialized Then
            _enum_cache = New StringList()
            _enum_cache_initialized = True
         End If
         Dim _key As String = BaseEnum._GetKeyCache(pClassName, pEnumName)
         _enum_cache.AddObject(_key, pEnum)
      End Sub

      Protected Shared Sub _AddEnumItem(pClassName As String, pEnum As BaseEnum)
         If Not BaseEnum._IsCached(pClassName, pEnum.AsString) Then
            BaseEnum._AddCache(pClassName, pEnum.AsString, pEnum)
         End If
      End Sub

      Protected Shared Function _GetCache(pClassName As String, pEnumName As String) As TObject
         If Not _enum_cache_initialized Then Throw New Exception(&quot;Enum cache not initialized&quot;)
         Dim _key As String = BaseEnum._GetKeyCache(pClassName, pEnumName)
         Dim _idx As Integer = _enum_cache.IndexOf(_key)
         If _idx &lt; 0 Then Throw New Exception(&quot;Enum &apos;&quot; &amp; pEnumName &amp; &quot;&apos; not found in &apos;&quot; &amp; pClassName &amp; &quot;&apos;&quot;)
         Return _enum_cache.Objects(_idx)
      End Function

      Protected Shared Function _GetCache(pClassName As String, pEnumId As Integer) As TObject
         If Not _enum_cache_initialized Then Throw New Exception(&quot;Enum cache not initialized&quot;)
         Dim i As Integer
         For i = 0 To _enum_cache.Count - 1
            Dim _enum As BaseEnum = BaseEnum(_enum_cache.Objects(i))
            Dim _string_key As String = _enum_cache.Strings(i)
            If _enum.AsInteger = pEnumId And _string_key.ToUpper.StartsWith(UCase(pClassName))
               _GetCache = _enum
               Exit Function
            End If
         Next
         Throw New Exception(&quot;Enum ID &apos;&quot; &amp; pEnumId.ToString() &amp; &quot;&apos; not found in &quot; &amp; pClassName)
      End Function

      Protected Shared Function _GetEnumOptions(pClassName As String) As String
         If Not _enum_cache_initialized Then Return &quot;&quot;
         Dim _result As String = &quot;&quot;
         Dim i As Integer
         For i = 0 To _enum_cache.Count - 1
            Dim _enum As BaseEnum = BaseEnum(_enum_cache.Objects(i))
            Dim _string_key As String = _enum_cache.Strings(i)
            If _string_key.ToUpper.StartsWith(UCase(pClassName) &amp; &quot;-&quot;) Then
               If _result &lt;&gt; &quot;&quot; Then _result = _result &amp; &quot;;&quot;
               _result = _result &amp; _enum.AsString &amp; &quot;=&quot; &amp; CStr(_enum.AsInteger)
            End If
         Next
         _GetEnumOptions = _result.Trim()
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Class TEnum
      Inherits BaseItem

      Private _value As BaseEnum

      Property Value As BaseEnum
         Get
            Value = me._value
         End Get
      End Property

      Property AsOption As String
         Get
            AsOption = &quot;&quot;&quot;&quot; &amp; me._value.AsString &amp; &quot;=&quot; &amp; me._value.AsInteger.ToString() &amp; &quot;&quot;&quot;&quot;
         End Get
      End Property

      Sub New(pValue As BaseEnum)
         MyBase.New()
         me._value = pValue
      End Sub

      Sub New(pValue As TEnum)
         MyBase.New()
         me._value = pValue.Value
      End Sub

      Overrides Function Copy() As TEnum
         Copy = New TEnum(me)
      End Function

      Overrides Function GetID As String
         GetID = me._value.AsString
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TEnum&quot;)
            .Prop(&quot;AsString&quot;, me._value.AsString)
            .Prop(&quot;AsInteger&quot;, me._value.AsInteger)
            .Prop(&quot;AsOption&quot;, me.AsOption)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TEnumFindDelegate(pValue As TEnum, i As Integer, extra As Variant) As Boolean
   Delegate Function TEnumMapDelegate(pValue As TEnum, i As Integer, extra As Variant) As TEnum
   Delegate Sub TEnumForEachDelegate(pValue As TEnum, i As Integer, extra As Variant)

   Class TEnumList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TEnumList&quot;, False)
      End Sub

      Function Add(pValue As BaseEnum) As TEnum
         Dim _option As TEnum
         If me.Has(pValue.AsString) Then
            _option = me.Take(pValue.AsString)
         Else
            _option = New TEnum(pValue)
            me.Add(_option)
         End If
         Add = _option
      End Function

      Function AsOptions As String
         Dim txt As New StringList()
         Dim i As Integer, _count As Integer = me.Count - 1
         For i = 0 to _count
            txt.Add(me.Take(i).AsOption)
         Next
         AsOptions = txt.Text.Trim.Replace(txt.LineBreak, &quot;;&quot;)
         txt.Free()
      End Function

      Property Item(pIndex As Integer) As TEnum
         Get
            Item = CType(MyBase.Take(pIndex), TEnum)
         End Get
         Set(pValue As TEnum)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TEnum
         Take = CType(MyBase.Take(pIndex), TEnum)
      End Function

      Function Take(pID As String) As TEnum
         Take = CType(MyBase.TakeFromId(pID), TEnum)
      End Function

      Function First As TEnum
         First = CType(MyBase.First, TEnum)
      End Function

      Function First(pLimit As Integer) As TEnumList
         First = CType(MyBase.Range(pLimit, False), TEnumList)
      End Function

      Function Last As TEnum
         Last = CType(MyBase.Last, TEnum)
      End Function

      Function Last(pLimit As Integer) As TEnumList
         Last = CType(MyBase.Range(pLimit, True), TEnumList)
      End Function

      Function Copy As TEnumList
         Return CType(MyBase.Copy(), TEnumList)
      End Function

      Function IndexOf(handler As TEnumFindDelegate) As Integer
         IndexOf = me.IndexOf(handler, &quot;&quot;)
      End Function

      Function IndexOf(handler As TEnumFindDelegate, extra As Variant) As Integer
         IndexOf = MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As TEnumFindDelegate) As TEnum
         Find = me.Find(handler, &quot;&quot;)
      End Function

      Function Find(handler As TEnumFindDelegate, extra As Variant) As TEnum
         Find = CType(MyBase.Find(handler, extra), TEnum)
      End Function

      Function Filter(handler As TEnumFindDelegate) As TEnumList
         Return me.Filter(handler, &quot;&quot;)
      End Function

      Function Filter(handler As TEnumFindDelegate, extra As Variant) As TEnumList
         Filter = CType(MyBase.Filter(handler, extra), TEnumList)
      End Function

      Sub ForEach(handler As TEnumFindDelegate)
         me.ForEach(handler, &quot;&quot;)
      End Sub

      Sub ForEach(handler As TEnumForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As TEnumFindDelegate) As TEnumList
         Map = me.Map(handler, &quot;&quot;)
      End Function

      Function Map(handler As TEnumMapDelegate, extra As Variant) As TEnumList
         With CType(MyBase.Map(handler, extra), TEnumList)
            Map = .Copy()
         End With
      End Function

   End Class

End Namespace</Codigo>
