    <mod_value_formatter>
      <Codigo>Imports Collections

&apos;@Module-Imported
Namespace mod_value_formatter

   Class ValueFormatter

      Protected _acceptedFormats As StringList = New StringList()
      Protected _format As String

      Sub New(pFormat As String = &quot;Default&quot;)
         MyBase.New()
         me._registerDefaultFormats()
         me.Format = pFormat
      End Sub

      Sub New(pValue As ValueFormatter)
         MyBase.New()
         me._registerDefaultFormats()
         me.Fill(pValue)
      End Sub

      Private Sub _registerDefaultFormats()
         me._acceptedFormats.Add(&quot;Default&quot;)
         me._acceptedFormats.Add(&quot;String&quot;)
         me._acceptedFormats.Add(&quot;Integer&quot;)
         me._acceptedFormats.Add(&quot;Currency&quot;)
         me._acceptedFormats.Add(&quot;Float&quot;)
         me._acceptedFormats.Add(&quot;Date&quot;)
         me._acceptedFormats.Add(&quot;DateTime&quot;)
         me._acceptedFormats.Add(&quot;Boolean&quot;)
      End Sub

      Property Format As String
         Get
            Format = me._format
         End Get
         Set(pValue As String)
            If me._acceptedFormats.IndexOf(pValue) &lt; 0 Then
               Throw New Exception(&quot;Invalid format: &quot; + pValue +  &quot;.&quot; + Chr(13) + &quot;Accepted formats are: &quot; + me._acceptedFormats.Text.Trim.Replace(me._acceptedFormats.LineBreak, &quot;, &quot;))
            End If
            me._format = pValue
         End Set
      End Property

      Overridable Function AsDefault(pValue As Variant) As Variant
         Select me.Format
            Case &quot;Default&quot;
               AsDefault = pValue
            Case &quot;String&quot;
               AsDefault = me.AsString(pValue)
            Case &quot;Integer&quot;
               AsDefault = me.AsInteger(pValue)
            Case &quot;Currency&quot;
               AsDefault = me.AsCurrency(pValue)
            Case &quot;Float&quot;
               AsDefault = me.AsFloat(pValue)
            Case &quot;Date&quot;
               AsDefault = me.AsDate(pValue)
            Case &quot;DateTime&quot;
               AsDefault = me.AsDateTime(pValue)
            Case &quot;Boolean&quot;
               AsDefault = me.AsBoolean(pValue)
         End Select
      End Function

      Overridable Function AsString(pValue As Variant) As String
         AsString = CStr(pValue)
      End Function

      Overridable Function AsInteger(pValue As Variant) As Integer
         Dim value As Integer
         TryStrToInt(CStr(pValue), value)
         AsInteger = value
      End Function

      Overridable Function AsCurrency(pValue As Variant) As Currency
         Dim value As Currency
         TryStrToCurr(CStr(pValue), value)
         AsCurrency = value
      End Function

      Overridable Function AsFloat(pValue As Variant) As Extended
         Dim value As Extended
         TryStrToFloat(CStr(pValue), value)
         AsFloat = value
      End Function

      Overridable Function AsDate(pValue As Variant) As TDateTime
         Dim value As TDateTime
         TryStrToDate(CStr(pValue), value)
         AsDate = value
      End Function

      Overridable Function AsDateTime(pValue As Variant) As TDateTime
         AsDateTime = StrToDateTime(CStr(pValue))
      End Function

      Overridable Function AsBoolean(pValue As Variant) As Boolean
         Select TypeName(pValue)
            Case &quot;Boolean&quot;
               AsBoolean = CBool(pValue)
            Case &quot;String&quot;
               Dim s As String = LCase(Trim(pValue))
               If s = &quot;true&quot; Or s = &quot;yes&quot; Or s = &quot;1&quot; Or s = &quot;s&quot; Then
                  AsBoolean = True
               ElseIf s = &quot;false&quot; Or s = &quot;no&quot; Or s = &quot;0&quot; Or s = &quot;n&quot; Then
                  AsBoolean = False
               End If
            Case Else
               AsBoolean = False
         End Select
      End Function

      Sub Fill(pValue As ValueFormatter)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Format = .Format
         End With
      End Sub

      Function Copy() As ValueFormatter
         Copy = New ValueFormatter(me)
      End Function

      Sub Free()
         If me._acceptedFormats &lt;&gt; NULL Then me._acceptedFormats.Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
