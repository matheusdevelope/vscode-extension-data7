    <mod_pipeline_datasource_csv>
      <Codigo>Imports Forms
Imports Collections
Imports mod_pipeline_datasource_grid

&apos;@Module-Imported
Namespace mod_pipeline_datasource_csv

   Class CSVGridDataSource
      Inherits GridDataSource

      Separator As String = &quot;;&quot;

      Sub New(pPath As String, pSeparator As String = &quot;;&quot;, pWritable As Boolean = False)
         MyBase.New(pPath, pWritable, &quot;CSV.Forms.Grid&quot;)
         me.Separator = pSeparator
      End Sub

      Protected Overridable Overrides Sub _loadFromFile(pPath As String)
         If me.Separator.Trim() = &quot;&quot;
            me.Separator = &quot;;&quot;
         End If
         Dim _lines As New StringList()
         Try
            _lines.LoadFromFile(pPath)

            If _lines.Count &gt; 0 Then
               me._grid.RowCount = _lines.Count
               Dim _maxCols As Integer = 1

               Dim r As Integer
               For r = 0 To _lines.Count - 1
                  Dim _line As String = _lines.Strings(r)

                  If _line &lt;&gt; &quot;&quot; Then
                     &apos; Usa o nosso parser robusto em vez do Split nativo
                     Dim _parts As StringList = me._parseCSVLine(_line, me.Separator)
                     Dim _cols As Integer = _parts.Count

                     If _cols &gt; _maxCols Then
                        _maxCols = _cols
                        me._grid.ColCount = _maxCols
                     End If

                     Dim c As Integer
                     For c = 0 To _cols - 1
                        Dim _val As String = _parts.Strings(c)
                        &apos; Reverte os enters escapados (se houver na exportação original)
                        _val = Replace(Replace(_val, &quot;\r&quot;, Chr(13)), &quot;\n&quot;, Chr(10))

                        me._grid.Cells(c, r) = _val
                     Next

                     &apos; Limpa a lista gerada pelo parser para evitar Memory Leak
                     _parts.Free()
                  End If
               Next
            End If

            _lines.Free()
         Catch ex As Exception
            _lines.Free()
            Throw ex
         End Try
      End Sub

      Private Function _parseCSVLine(line As String, pSep As String) As StringList
         Dim result As New StringList()
         Dim i As Integer = 1
         Dim inQuotes As Boolean = False
         Dim token As String = &quot;&quot;
         Dim ch As String
         Dim _len As Integer = Len(line)

         Do While i &lt;= _len
            ch = Mid(line, i, 1)

            If ch = &quot;&quot;&quot;&quot; Then
               If inQuotes Then
                  &apos; Verifica se é uma aspa escapada (&quot;&quot;) dentro do texto
                  If i &lt; _len And Mid(line, i + 1, 1) = &quot;&quot;&quot;&quot; Then
                     token = token &amp; &quot;&quot;&quot;&quot;
                     i = i + 1
                  Else
                     &apos; Fim do bloco de aspas
                     inQuotes = False
                  End If
               Else
                  &apos; Início do bloco de aspas
                  inQuotes = True
               End If

            ElseIf ch = pSep And Not inQuotes Then
               &apos; Delimitador encontrado fora de aspas -&gt; Salva o token
               result.Add(token)
               token = &quot;&quot;

            Else
               &apos; Caractere normal
               token = token &amp; ch
            End If

            i = i + 1
         Loop

         &apos; Adiciona o último token após o laço
         result.Add(token)

         _parseCSVLine = result
      End Function

      Protected Overridable Overrides Sub _saveToFile(pPath As String)
         me._grid.ExportToCSV(pPath, me.Separator)
      End Sub

      Protected Overridable Overrides Function _getExtension() As String
         _getExtension = &quot;.csv&quot;
      End Function

      Protected Overridable Overrides Function _getExtensionFilter As String
         _getExtensionFilter = &quot;Arquivos CSV (*.csv)|*.csv&quot;
      End Function

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline_datasource_csv>
