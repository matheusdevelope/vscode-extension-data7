         With pValue
            me.Success = .Success
            me.Logs.Text = .Logs.Text
            me._foundFields = .FoundFields.Copy()
            me._missingFieldsOptional = .MissingFieldsOptional.Copy()
            me._missingFieldsRequired = .MissingFieldsRequired.Copy()
