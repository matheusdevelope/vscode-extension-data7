    <mod_winapi>
      <Codigo>
&apos;@Module-Imported
Namespace mod_winapi

   Const SW_HIDE = 0
   Const SW_SHOWNORMAL = 1
   Const SW_NORMAL = 1
   Const SW_SHOWMINIMIZED = 2
   Const SW_SHOWMAXIMIZED = 3
   Const SW_MAXIMIZE = 3
   Const SW_SHOWNOACTIVATE = 4
   Const SW_SHOW = 5
   Const SW_MINIMIZE = 6
   Const SW_SHOWMINNOACTIVE = 7
   Const SW_SHOWNA = 8
   Const SW_RESTORE = 9
   Const SW_SHOWDEFAULT = 10
   Const SW_FORCEMINIMIZE = 11

   Private Const SM_CXSCREEN = 0
   Private Const SM_CYSCREEN = 1
   Private Const SM_CXVIRTUALSCREEN = 78
   Private Const SM_CYVIRTUALSCREEN = 79

   Private Const MFO_DEFAULT = 1

   Private Const MOUSEEVENTF_MOVE = 1
   Private Const MOUSEEVENTF_LEFTDOWN = 2
   Private Const MOUSEEVENTF_LEFTUP = 4
   Private Const MOUSEEVENTF_RIGHTDOWN = 8
   Private Const MOUSEEVENTF_RIGHTUP = 16
   Private Const MOUSEEVENTF_MIDDLEDOWN = 32
   Private Const MOUSEEVENTF_MIDDLEUP = 64
   Private Const MOUSEEVENTF_WHEEL = 2048
   Private Const MOUSEEVENTF_ABSOLUTE = 32768

   Private Const MONITOR_DEFAULTTONULL = 0
   Private Const MONITOR_DEFAULTTOPRIMARY = 1
   Private Const MONITOR_DEFAULTTONEAREST = 2

   Private Const MONITOR_SIZE = 40

   Private Structure TMonitorInfo
      cbSize As Long
      rcMonitor As TRect
      rcWork As TRect
      dwFlags As Long
   End Structure

   Private Declare Function _GetForegroundWindow Lib &quot;user32.dll&quot; Alias &quot;GetForegroundWindow&quot;  As Long
   Private Declare Function _SetForegroundWindow Lib &quot;user32.dll&quot; Alias &quot;SetForegroundWindow&quot; (hwnd As Long) As Long
   Private Declare Function _FindWindow Lib &quot;user32.dll&quot; Alias &quot;FindWindowW&quot; (lpClassName As String, lpWindowName As String) As Long
   Private Declare Function _MoveWindow Lib &quot;user32.dll&quot; Alias &quot;MoveWindow&quot; (hwnd As Long, pX As Long, pY As Long, nWidth As Long, nHeight As Long, bRepaint As Boolean) As Long
   Private Declare Function _ShowWindow Lib &quot;user32.dll&quot; Alias &quot;ShowWindow&quot; (hwnd As Long, nCmdShow As Long) As Long
   Private Declare Function _GetWindowRect Lib &quot;user32.dll&quot; Alias &quot;GetWindowRect&quot; (hwnd As Long, ByRef lpRect As TRect) As Long
   Private Declare Function _GetSystemMetrics Lib &quot;user32.dll&quot; Alias &quot;GetSystemMetrics&quot; (nIndepX As Long) As Long
   Private Declare Function _SetCursorPos Lib &quot;user32.dll&quot; Alias &quot;SetCursorPos&quot; (pX As Long, pY As Long) As Long
   Private Declare Function _GetCursorPos Lib &quot;user32.dll&quot; Alias &quot;GetCursorPos&quot; (ByRef lpPoint As TPoint) As Long
   Private Declare Function _GetMonitorInfo Lib &quot;user32.dll&quot; Alias &quot;GetMonitorInfoA&quot; (hMonitor As Long, ByRef lpmi As TMonitorInfo) As Long
   Private Declare Function _GetMonitorFromWindow Lib &quot;user32.dll&quot; Alias &quot;MonitorFromWindow&quot; (hwnd As Long, dwFlags As Long) As Long
   Private Declare Function _GetMonitorFromPoint Lib &quot;user32.dll&quot; Alias &quot;MonitorFromPoint&quot; (xPoint As Long, yPoint As Long, dwFlags As Long) As Long
   Private Declare Function _GetMonitorFromRect Lib &quot;user32.dll&quot; Alias &quot;MonitorFromRect&quot; (ByRef lpRect As TRect, dwFlags As Long) As Long
   Private Declare Sub _MouseEvent Lib &quot;user32.dll&quot; Alias &quot;mouse_event&quot; (dwFlags As Long, dpX As Long, dpY As Long, cButtons As Long, dwExtraInfo As Long)

   Private Declare Function _CreateCompatibleDC Lib &quot;gdi32&quot; Alias &quot;CreateCompatibleDC&quot; (hdc As Long) As Long
   Private Declare Function _DeleteDC Lib &quot;gdi32&quot; Alias &quot;DeleteDC&quot; (hdc As Long) As Long
   Private Declare Function _CreateFont Lib &quot;gdi32&quot; Alias &quot;CreateFontA&quot; (nHeight As Long, nWidth As Long, nEscapement As Long, nOrientation As Long, fnWeight As Long, fdwItalic As Long, fdwUnderline As Long, fdwStrikeOut As Long, fdwCharSet As Long, fdwOutputPrecision As Long, fdwClipPrecision As Long, fdwQuality As Long, fdwPitchAndFamily As Long, lpszFace As String) As Long
   Private Declare Function _SelectObject Lib &quot;gdi32&quot; Alias &quot;SelectObject&quot; (hdc As Long, hObject As Long) As Long
   Private Declare Function _DeleteObject Lib &quot;gdi32&quot; Alias &quot;DeleteObject&quot; (hObject As Long) As Long
   Private Declare Function _GetTextExtentPoint32 Lib &quot;gdi32&quot; Alias &quot;GetTextExtentPoint32A&quot; (hdc As Long, lpsz As String, c As Long, ByRef lpSize As TPoint) As Long
   Private Declare Function _GetDC Lib &quot;user32.dll&quot; Alias &quot;GetDC&quot; (hwnd As Long) As Long
   Private Declare Function _ReleaseDC Lib &quot;user32.dll&quot; Alias &quot;ReleaseDC&quot; (hwnd As Long, hdc As Long) As Long

   Private Declare Function _ShellExecute Lib &quot;shell32.dll&quot; Alias &quot;ShellExecuteW&quot; (ByVal hwnd As Long, ByVal lpOperation As String, ByVal lpFile As String, ByVal lpParameters As String, ByVal lpDirectory As String, ByVal nShowCmd As Long) As Long

   Class WinAPI

      Shared Function Execute(pFile As String, pParameters As String, pRunAsAdm As Boolean = False, pShowWindow As Long = SW_HIDE) As Long
         Dim _operation As String
         If pRunAsAdm Then
            _operation = &quot;runas&quot;
         End If
         Execute = _ShellExecute(0, _operation, pFile, pParameters, &quot;&quot;, pShowWindow)
      End Function

      Shared Function Execute(pHwnd As Long, pOperation As String, pFile As String, pParameters As String, pDirectory As String, pShowWindow As Long) As Long
         Execute = _ShellExecute(pHwnd, pOperation, pFile, pParameters, pDirectory, pShowWindow)
      End Function

      Shared Function GetMetric(pIndex As Long) As Long
         GetMetric = _GetSystemMetrics(pIndex)
      End Function

      Shared Sub SendKeys(pKeys As String, pWait As Boolean = False)
         Dim shell As Variant = CreateObject(&quot;WScript.Shell&quot;)
         shell.SendKeys(pKeys, pWait)
         shell = &quot;&quot;
      End Sub

      Shared Function MeasureText(pHwnd As Long, pText As String) As TPoint
         Dim hDC As Long, sz As TPoint
         hDC = _GetDC(pHwnd)
         If hDC &lt;&gt; 0 Then
            _GetTextExtentPoint32(hDC, pText, Len(pText), sz)
            _ReleaseDC(pHwnd, hDC)
         End If
         MeasureText = sz
      End Function

      Shared Function MeasureText(pText As String, pFont As FontConfig, pHwnd As Long = 0) As TPoint
         MeasureText = WinAPI.MeasureText(pText, pFont.Name, pFont.Height, pFont.Bold, pFont.Italic, pFont.Underline, pFont.Orientation, pFont.Charset, FontQualityToInt(pFont.Quality), FontPitchToInt(pFont.Pitch), pHwnd)
      End Function

      Shared Function MeasureText(pText As String, pFont As TFont, pHwnd As Long = 0) As TPoint
         MeasureText = WinAPI.MeasureText(pText, pFont.Name, pFont.Height, pFont.Bold, pFont.Italic, pFont.Underline, pFont.Orientation, pFont.Charset, FontQualityToInt(pFont.Quality), FontPitchToInt(pFont.Pitch), pHwnd)
      End Function

      Shared Function MeasureText(pText As String, pName As String, pHeight As Long, pBold As Boolean = False, pItalic As Boolean = False, pUnderline As Boolean = False, pOrientation As Long = 0, pCharSet As Long = 0, pQuality As Long = 0, pPitch As Long = 0, pHwnd As Long = 0) As TPoint
         Dim hDC As Long, hFont As Long, hOld As Long, sz As TPoint
         Dim weight As Long = 400, italic As Long = 0, underline As Long = 0
         If pBold Then weight = 700
         If pItalic Then italic = 1
         If pUnderline Then underline = 1
         If pHwnd &lt;&gt; 0 Then
            hDC = _GetDC(pHwnd)
         Else
            hDC = _CreateCompatibleDC(0)
         End If
         hFont = _CreateFont(pHeight, 0, pOrientation, 0, weight, italic, underline, 0, pCharSet, 0, 0, pQuality, pPitch, pName)
         hOld = _SelectObject(hDC, hFont)
         _GetTextExtentPoint32(hDC, pText, Len(pText), sz)
         _SelectObject(hDC, hOld)
         _DeleteObject(hFont)
         If pHwnd &lt;&gt; 0 Then
            _ReleaseDC(pHwnd, hDC)
         Else
            _DeleteDC(hDC)
         End If
         &apos;Essa budega não retorna a mesma largura do developer, esse número mágico aproxima do largura real do componente.
         sz.X = CInt(sz.X * 1.2)
         MeasureText = sz
      End Function

      Class Window

         Shared Function GetForeground As Long
            GetForeground = _GetForegroundWindow()
         End Function

         Shared Function SetForeground(hwnd As Long) As Long
            SetForeground = _SetForegroundWindow(hwnd)
         End Function

         Shared Function Find(className As String, windowName As String) As Long
            Find = _FindWindow(className, windowName)
         End Function

         Shared Function Move(hwnd As Long, pX As Long, pY As Long, width As Long, height As Long, repaint As Boolean) As Long
            Move = _MoveWindow(hwnd, pX, pY, width, height, repaint)
         End Function

         Shared Function Show(hwnd As Long, cmdShow As Long) As Long
            Show = _ShowWindow(hwnd, cmdShow)
         End Function

         Shared Function Focus(hwnd As Long, restore As Boolean = False) As Boolean
            If restore Then _ShowWindow(hwnd, SW_RESTORE)
            _SetForegroundWindow(hwnd)
            Focus = (_GetForegroundWindow() = hwnd)
         End Function

         Shared Function GetRect(hwnd As Long) As TRect
            Dim r As TRect
            _GetWindowRect(hwnd, r)
            GetRect = r
         End Function

      End Class

      Class Mouse

         Shared Function GetPos As TPoint
            Dim p As TPoint
            _GetCursorPos(p)
            GetPos = p
         End Function

         Shared Sub SetPos(pPoint As TPoint)
            Mouse.SetPos(pPoint.X, pPoint.Y)
         End Sub

         Shared Sub SetPos(pX As Long, pY As Long)
            _SetCursorPos(pX, pY)
         End Sub

         Shared Sub LeftClick()
            Mouse.Dispatch(MOUSEEVENTF_LEFTDOWN, 0, 0, 0, 0)
            Mouse.Dispatch(MOUSEEVENTF_LEFTUP, 0, 0, 0, 0)
         End Sub

         Shared Sub LeftClick(pPoint As TPoint)
            Mouse.LeftClick(pPoint.X, pPoint.Y)
         End Sub

         Shared Sub LeftClick(pX As Long, pY As Long)
            Mouse.SetPos(pX, pY)
            Sleep(50)
            Mouse.LeftClick()
         End Sub

         Shared Sub RightClick()
            Mouse.Dispatch(MOUSEEVENTF_RIGHTDOWN, 0, 0, 0, 0)
            Mouse.Dispatch(MOUSEEVENTF_RIGHTUP, 0, 0, 0, 0)
         End Sub

         Shared Sub RightClick(pPoint As TPoint)
            Mouse.RightClick(pPoint.X, pPoint.Y)
         End Sub

         Shared Sub RightClick(pX As Long, pY As Long)
            Mouse.SetPos(pX, pY)
            Sleep(50)
            Mouse.RightClick()
         End Sub

         Shared Sub MiddleClick()
            Mouse.Dispatch(MOUSEEVENTF_MIDDLEDOWN, 0, 0, 0, 0)
            Mouse.Dispatch(MOUSEEVENTF_MIDDLEUP, 0, 0, 0, 0)
         End Sub

         Shared Sub DoubleClick()
            Mouse.LeftClick()
            Sleep(100)
            Mouse.LeftClick()
         End Sub

         Shared Sub ScrollVertical(pAmount As Long)
            Mouse.Dispatch(MOUSEEVENTF_WHEEL, 0, 0, pAmount, 0)
         End Sub

         Shared Sub Dispatch(pFlags As Long, pX As Long, pY As Long, pButtons As Long, pExtra As Long)
            _MouseEvent(pFlags, pX, pY, pButtons, pExtra)
         End Sub

      End Class

      Class Screen

         Shared Function CurrentWindow As Integer
            CurrentWindow = WinAPI.Window.GetForeground()
         End Function

         Shared Function Height As Integer
            Height = Screen.CurrentMonitor.Height
         End Function

         Shared Function Width As Integer
            Width = Screen.CurrentMonitor.Width
         End Function

         Shared Function WorkAreaHeight As Integer
            WorkAreaHeight = Screen.CurrentMonitor.WorkAreaHeight
         End Function

         Shared Function WorkAreaWidth As Integer
            WorkAreaWidth = Screen.CurrentMonitor.WorkAreaWidth
         End Function

         Shared Function VirtualHeight As Integer
            VirtualHeight = Screen.VirtualMonitor.Height
         End Function

         Shared Function VirtualWidth As Integer
            VirtualWidth = Screen.VirtualMonitor.Width
         End Function

         Shared Function CurrentMonitor As TMonitor
            CurrentMonitor = Screen.MonitorFromWindow(Screen.CurrentWindow)
         End Function

         Shared Function PrimaryMonitor As TMonitor
            PrimaryMonitor = Screen.MonitorFromWindow(0)
         End Function

         Shared Function VirtualMonitor As TMonitor
            Dim _rect As TRect
            _rect.Left = 0
            _rect.Top = 0
            _rect.Right = _GetSystemMetrics(SM_CXVIRTUALSCREEN)
            _rect.Bottom = _GetSystemMetrics(SM_CYVIRTUALSCREEN)
            VirtualMonitor = New TMonitor(0, False, _rect, _rect)
         End Function

         Shared Function MonitorFromPoint(pPoint As TPoint) As TMonitor
            Dim hMonitor As Long = _GetMonitorFromPoint(pPoint.X, pPoint.Y, MONITOR_DEFAULTTONEAREST)
            MonitorFromPoint = Screen.GetMonitorByHandle(hMonitor)
         End Function

         Shared Function MonitorFromWindow(pHandle As Long) As TMonitor
            Dim hMonitor As Long = _GetMonitorFromWindow(pHandle, MONITOR_DEFAULTTONEAREST)
            MonitorFromWindow = Screen.GetMonitorByHandle(hMonitor)
         End Function

         Shared Function MonitorFromRect(pRect As TRect) As TMonitor
            Dim hMonitor As Long = _GetMonitorFromRect(pRect, MONITOR_DEFAULTTONEAREST)
            MonitorFromRect = Screen.GetMonitorByHandle(hMonitor)
         End Function

         Private Shared Function GetMonitorByHandle(hMonitor As Long) As TMonitor
            Dim info As TMonitorInfo
            info.cbSize = MONITOR_SIZE
            If _GetMonitorInfo(hMonitor, info) &lt;&gt; 0 Then
               GetMonitorByHandle = New TMonitor(hMonitor, (info.dwFlags And 1) &lt;&gt; 0, info.rcMonitor, info.rcWork)
            Else
               GetMonitorByHandle = NULL
            End If
         End Function

      End Class

   End Class

   Private Function FontQualityToInt(pQuality As TFontQuality) As Long
      Select pQuality
         Case fqDefault
            FontQualityToInt = 0
         Case fqDraft
            FontQualityToInt = 1
         Case fqProof
            FontQualityToInt = 2
         Case fqNonAntialiased
            FontQualityToInt = 3
         Case fqAntialiased
            FontQualityToInt = 4
         Case fqClearType
            FontQualityToInt = 5
         Case fqClearTypeNatural
            FontQualityToInt = 6
         Case Else
            FontQualityToInt = 0
      End Select
   End Function

   Private Function FontPitchToInt(pPitch As TFontPitch) As Long
      Select pPitch
         Case fpDefault
            FontPitchToInt = 0
         Case fpFixed
            FontPitchToInt = 2
         Case fpVariable
            FontPitchToInt = 1
         Case Else
            FontPitchToInt = 0
      End Select
   End Function

   Class TMonitor

      Private _ID As Long
      Private _Primary As Boolean
      Private _bounds As TRect
      Private _WorkArea As TRect

      Sub New(pID As Integer, pPrimary As Boolean, pBounds As TRect, pWorkArea As TRect)
         MyBase.New()
         me._ID = pID
         me._Primary = pPrimary
         me._bounds.Left = pBounds.Left
         me._bounds.Top = pBounds.Top
         me._bounds.Right = pBounds.Right
         me._bounds.Bottom = pBounds.Bottom
         me._WorkArea.Left = pWorkArea.Left
         me._WorkArea.Top = pWorkArea.Top
         me._WorkArea.Right = pWorkArea.Right
         me._WorkArea.Bottom = pWorkArea.Bottom
      End Sub

      Property ID As Long
         Get
            ID = me._ID
         End Get
      End Property

      Property Primary As Boolean
         Get
            Primary = me._Primary
         End Get
      End Property

      Property Bounds As TRect
         Get
            Bounds = me._bounds
         End Get
      End Property

      Property WorkArea As TRect
         Get
            WorkArea = me._WorkArea
         End Get
      End Property

      Property Width As Integer
         Get
            Width = me._bounds.Right - me._bounds.Left
         End Get
      End Property

      Property Height As Integer
         Get
            Height = me._bounds.Bottom - me._bounds.Top
         End Get
      End Property

      Property WorkAreaWidth As Integer
         Get
            WorkAreaWidth = me._WorkArea.Right - me._WorkArea.Left
         End Get
      End Property

      Property WorkAreaHeight As Integer
         Get
            WorkAreaHeight = me._WorkArea.Bottom - me._WorkArea.Top
         End Get
      End Property

      Private Function ToString(pRect As TRect) As String
         ToString = &quot;[&quot; &amp; CStr(pRect.Left) &amp; &quot;,&quot; &amp; CStr(pRect.Top) &amp; &quot; - &quot; &amp; CStr(pRect.Right) &amp; &quot;,&quot; &amp; CStr(pRect.Bottom) &amp; &quot;]&quot;
      End Function

      Function ToString(pPrint As Boolean = False) As String
         With New Collections.StringList()
            .Add(&quot;ID: &quot; &amp; Cstr(me.ID))
            .Add(&quot;Primary: &quot; &amp; CStr(me.Primary))
            .Add(&quot;Bounds: &quot; &amp; me.ToString(me.Bounds))
            .Add(&quot;WorkArea: &quot; &amp; me.ToString(me.WorkArea))
            .Add(&quot;Width: &quot; &amp; CStr(me.Width))
            .Add(&quot;Height: &quot; &amp; CStr(me.Height))
            .Add(&quot;WorkAreaWidth: &quot; &amp; CStr(me.WorkAreaWidth))
            .Add(&quot;WorkAreaHeight: &quot; &amp; CStr(me.WorkAreaHeight))
            If pPrint
               print .Text
               Forms.ProcessMessages()
            End If
            ToString = .Text
            .Free()
         End With
      End Function

   End Class

