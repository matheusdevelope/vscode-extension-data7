    <mod_pipeline_exporter>
      <Codigo>Imports mod_base_list
Imports mod_pipeline_cell
Imports mod_pipeline_group
Imports mod_pipeline_record
Imports mod_pipeline_navigator
Imports mod_pipeline_export_field

&apos;@Module-Imported
Namespace mod_pipeline_exporter

   Delegate Sub OnProgressDelegate(pCurrent As Integer, pTotal As Integer)

   Class TExporter
      Inherits BaseItem

      Protected _path As String
      Protected _fields As TExportFieldList = New TExportFieldList()
      ApplyHeader As Boolean = True
      OnProgress As OnProgressDelegate

      Property Path As String
         Get
            Path = me._path
         End Get
         Set(pValue As String)
            me._path = pValue
         End Set
      End Property

      Property Fields As TExportFieldList
         Get
            Fields = me._fields
         End Get
         Set(pValue As TExportFieldList)
            If me._fields &lt;&gt; NULL Then me._fields.Free()
            me._fields = pValue.Copy()
         End Set
      End Property

      Sub New(pPath As String = &quot;&quot;)
         MyBase.New()
         me.Path = pPath
      End Sub

      Sub Export(pGroups As TGroupList, pNavigator As TNavigator, pDir As String = &quot;&quot;)
         If pGroups = NULL Or pNavigator = NULL Then Exit Sub
         Dim i As Integer
         Dim count As Integer = pGroups.Count - 1
         For i = 0 To count
            Dim _group As TGroup = pGroups.Take(i)

            Dim _targetPath As String = _group.OutputPath

            If _targetPath = &quot;&quot; Then
               Dim _folder As String = Trim(pDir)
               If _folder = &quot;&quot; Then _folder = me.Path
               If Right(_folder, 1) &lt;&gt; &quot;\&quot; And Right(_folder, 1) &lt;&gt; &quot;/&quot; Then _folder = _folder &amp; &quot;\&quot;
               _targetPath = _folder &amp; _group.GetID()
            End If

            me.Export(_group.Items, pNavigator, _targetPath)
         Next
      End Sub

      Sub Export(pRecords As TRecordList, pNavigator As TNavigator, pPath As String = &quot;&quot;)
         If pRecords = NULL Or pNavigator = NULL Then Exit Sub
         If pRecords.Count = 0 Then Exit Sub

         pPath = Trim(pPath)
         If pPath = &quot;&quot;
            pPath = me.Path
         End If

         If pPath &lt;&gt; &quot;&quot; Then
            pNavigator.Data.Path = pPath
         End If

         me._beforeExport(pNavigator)
         Try
            pNavigator.Data.Open()
            pNavigator.Reset()
            If me.ApplyHeader
               pNavigator.Rows = 2
               pNavigator.Columns = 1
            Else
               pNavigator.Rows = 1
               pNavigator.Columns = 1
            End If
            Dim _map As TExportFieldList = me._getMapping(pRecords.Take(0))
            If me.ApplyHeader Then me._writeHeader(pNavigator, _map)
            me._processRecords(pRecords, pNavigator, _map)
            me._afterExport(pNavigator)
         Catch ex As Exception
            me._handleError(ex)
         Finally
            pNavigator.Data.Close()
         End Try
      End Sub

      Protected Overridable Sub _processRecords(pRecords As TRecordList, pNavigator As TNavigator, pMap As TExportFieldList)
         Dim i As Integer
         Dim recordCount As Integer = pRecords.Count
         For i = 0 To recordCount - 1
            Dim _record As TRecord = pRecords.Take(i)
            me._beforeProcessRecord(_record, i)
            me._processRecord(_record, pNavigator, pMap, i)
            me._afterProcessRecord(_record, i)
            If me.OnProgress &lt;&gt; NULL Then me.OnProgress(i + 1, recordCount)
            pNavigator.Nextt()
         Next
      End Sub

      Protected Overridable Sub _processRecord(pRecord As TRecord, pNavigator As TNavigator, pMap As TExportFieldList, pIndex As Integer)
         If pRecord.Selected
            Dim i As Integer
            Dim count As Integer = pMap.Count - 1
            For i = 0 To count
               Dim _field As TExportField = pMap.Take(i)
               If pRecord.Cells.Has(_field.Name) Then
                  Dim _cell As TCell = pRecord.Cells.Take(_field.Name)
                  Dim _value As Variant = me._prepareValue(_cell)
                  me._writeCell(pNavigator, _field, _value, i, pIndex)
               End If
            Next
         End If
      End Sub

      Protected Overridable Sub _writeHeader(pNavigator As TNavigator, pMap As TExportFieldList)
         Dim i As Integer
         Dim count As Integer = pMap.Count - 1
         Dim _pos As Integer = pNavigator.Position
         For i = 0 To count
            Dim _field As TExportField = pMap.Take(i)
            me._writeCell(pNavigator, _field, _field.Title, i, _pos)
         Next
         pNavigator.Position = _pos + 1
      End Sub

      Protected Overridable Sub _writeCell(pNavigator As TNavigator, pField As TExportField, pValue As Variant, pIndex As Integer, pY As Integer)
         pNavigator.SetValue(pIndex, pValue)
      End Sub

      Protected Overridable Function _prepareValue(pCell As TCell) As Variant
         _prepareValue = pCell.Value.AsDefault()
      End Function

      Protected Overridable Sub _beforeExport(pNavigator As TNavigator)
         &apos; Hook para preparativos técnicos
      End Sub

      Protected Overridable Sub _afterExport(pNavigator As TNavigator)
         &apos; Hook para finalização
      End Sub

      Protected Overridable Sub _beforeProcessRecord(pRecord As TRecord, pIndex As Integer)
      End Sub

      Protected Overridable Sub _afterProcessRecord(pRecord As TRecord, pIndex As Integer)
      End Sub

      Protected Overridable Sub _handleError(pEx As Exception)
         Throw pEx
      End Sub

      Protected Overridable Function _getMapping(pSample As TRecord) As TExportFieldList
         If me._fields.Count &gt; 0 Then
            _getMapping = me._fields
         Else
            If pSample &lt;&gt; NULL Then
               Dim i As Integer
               For i = 0 To pSample.Cells.Count - 1
                  Dim _cell As TCell = pSample.Cells.Take(i)
                  me._fields.Add(New TExportField(_cell.Name, _cell.Title))
               Next
            End If
            _getMapping = me._fields
         End If
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TExporter&quot;)
            .Prop(&quot;Fields&quot;, me._fields.ToString())
            .Prop(&quot;ApplyHeader&quot;, me.ApplyHeader)
            .Prop(&quot;OnProgress&quot;, Cstr(me.OnProgress &lt;&gt; NULL))
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         If me._fields &lt;&gt; NULL Then me._fields.Free()
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline_exporter>
    <mod_pipeline_export_field>
      <Codigo>
Imports mod_base_list
Imports mod_pipeline_util

&apos;@Module-Imported
Namespace mod_pipeline_export_field

   Class TExportField
      Inherits BaseItem

      Private _name As String
      Private _title As String
      FormatMask As String
      IndexX As Integer = -1
      IndexY As Integer = -1

      Property Name As String
         Get
            Name = me._name
         End Get
         Set(pValue As String)
            me._name = Utils.Normalize(pValue)
         End Set
      End Property

      Property Title As String
         Get
            Title = me._title
         End Get
         Set(pValue As String)
            me._title = Trim(pValue)
            If me._title = &quot;&quot; Then
               me._title = me.Name
            End If
         End Set
      End Property

      Sub New(pName As String, pTitle As String = &quot;&quot;, pFormatMask As String = &quot;&quot;)
         MyBase.New()
         me.Name = pName
         me.Title = pTitle
         me.FormatMask = pFormatMask
      End Sub

      Sub New(pValue As TExportField)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TExportField)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Name = .Name
            me.Title = .Title
            me.FormatMask = .FormatMask
            me.IndexX = .IndexX
            me.IndexY = .IndexY
         End With
      End Sub

      Overrides Function Copy() As TExportField
         Copy = New TExportField(me)
      End Function

      Overrides Function GetID As String
         GetID = me.Name
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TExportField&quot;)
            .Prop(&quot;Name&quot;, me.Name)
            .Prop(&quot;Title&quot;, me.Title)
            .Prop(&quot;FormatMask&quot;, me.FormatMask)
            .Prop(&quot;IndexX&quot;, me.IndexX)
            .Prop(&quot;IndexY&quot;, me.IndexY)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.Name = &quot;&quot;
         me.Title = &quot;&quot;
         me.FormatMask = &quot;&quot;
         me.IndexX = -1
         me.IndexY = -1
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TExportFieldFindDelegate(pValue As TExportField, i As Integer, extra As Variant) As Boolean
   Delegate Function TExportFieldMapDelegate(pValue As TExportField, i As Integer, extra As Variant) As TExportField
   Delegate Sub TExportFieldForEachDelegate(pValue As TExportField, i As Integer, extra As Variant)

   Class TExportFieldList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TExportFieldList&quot;, False)
      End Sub

      Property Item(pIndex As Integer) As TExportField
         Get
            Item = CType(MyBase.Take(pIndex), TExportField)
         End Get
         Set(pValue As TExportField)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TExportField
         Take = CType(MyBase.Take(pIndex), TExportField)
      End Function

      Function Take(pID As String) As TExportField
         Take = CType(MyBase.TakeFromId(pID), TExportField)
      End Function

      Function First As TExportField
         First = CType(MyBase.First, TExportField)
      End Function

      Function First(pLimit As Integer) As TExportFieldList
         First = CType(MyBase.Range(pLimit, False), TExportFieldList)
      End Function

      Function Last As TExportField
         Last = CType(MyBase.Last, TExportField)
      End Function

      Function Last(pLimit As Integer) As TExportFieldList
         Last = CType(MyBase.Range(pLimit, True), TExportFieldList)
      End Function

      Function Copy As TExportFieldList
         Return CType(MyBase.Copy(), TExportFieldList)
      End Function

      Function IndexOf(handler As TExportFieldFindDelegate) As Integer
         IndexOf = me.IndexOf(handler, &quot;&quot;)
      End Function

      Function IndexOf(handler As TExportFieldFindDelegate, extra As Variant) As Integer
         IndexOf = MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As TExportFieldFindDelegate) As TExportField
         Find = me.Find(handler, &quot;&quot;)
      End Function

      Function Find(handler As TExportFieldFindDelegate, extra As Variant) As TExportField
         Find = CType(MyBase.Find(handler, extra), TExportField)
      End Function

      Function Filter(handler As TExportFieldFindDelegate) As TExportFieldList
         Return me.Filter(handler, &quot;&quot;)
      End Function

      Function Filter(handler As TExportFieldFindDelegate, extra As Variant) As TExportFieldList
         Filter = CType(MyBase.Filter(handler, extra), TExportFieldList)
      End Function

      Sub ForEach(handler As TExportFieldFindDelegate)
         me.ForEach(handler, &quot;&quot;)
      End Sub

      Sub ForEach(handler As TExportFieldForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As TExportFieldFindDelegate) As TExportFieldList
         Map = me.Map(handler, &quot;&quot;)
      End Function

      Function Map(handler As TExportFieldMapDelegate, extra As Variant) As TExportFieldList
         With CType(MyBase.Map(handler, extra), TExportFieldList)
            Map = .Copy()
         End With
      End Function

   End Class

End Namespace</Codigo>
