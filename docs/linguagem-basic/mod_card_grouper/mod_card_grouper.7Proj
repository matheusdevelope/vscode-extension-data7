   Class TSchema
      Inherits BaseItem

      Protected _name As String
      Protected _window As TWindow = New TWindow()
      Protected _fields As TFieldList = New TFieldList()
      HeaderIndex As Integer = -1

      SupportedInputDataSources As TEnumList
      SupportedInputNavigators As TEnumList
      SupportedOutputDataSources As TEnumList
      SupportedOutputNavigators As TEnumList
      SupportedGroupers As TEnumList

      Property Name As String
         Get
            Name = me._name
         End Get
      End Property

      Property Window As TWindow
         Get
            Window = me._window
         End Get
         Set(pValue As TWindow)
            If me._window &lt;&gt; NULL Then me._window.Free()
            me._window = pValue
         End Set
      End Property

      Property Fields As TFieldList
         Get
            Fields = me._fields
         End Get
         Set(pValue As TFieldList)
            If me._fields &lt;&gt; NULL Then me._fields.Free()
            me._fields = pValue
         End Set
      End Property

      Sub New(pName As String = &quot;TSchema&quot;)
         MyBase.New()
         me._initSupportedTypes()
         me._name = pName
      End Sub

      Sub New(pWindow As TWindow, pFields As TFieldList, pName As String = &quot;TSchema&quot;)
         MyBase.New()
         me._initSupportedTypes()
         me._window = pWindow
         me._fields = pFields
         me._name = pName
      End Sub

      Sub New(pValue As TSchema)
         MyBase.New()
         me._initSupportedTypes()
         me.Fill(pValue)
      End Sub

      Private Sub _initSupportedTypes()
         me.SupportedInputDataSources = New TEnumList()
         me.SupportedInputNavigators = New TEnumList()
         me.SupportedOutputDataSources = New TEnumList()
         me.SupportedOutputNavigators = New TEnumList()
         me.SupportedGroupers = New TEnumList()
      End Sub

      Sub AddField(pName As String, pRequired As Boolean = False)
         If Not me._fields.Has(pName) Then
            me._fields.Add(New TField(pName, pRequired))
         End If
      End Sub

      Sub AddOption(pFieldName As String, pOption As String)
         If me._fields.Has(pFieldName) Then
            Dim _options As TOptionList = me._fields.Take(pFieldName).Options
            If Not _options.Has(pOption) Then
               _options.Add(New TOption(pOption))
            End If
         End If
      End Sub

      Sub Fill(pValue As TSchema)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me._name = .Name
            me._window = .Window.Copy()
            me._fields = .Fields.Copy()
            me.HeaderIndex = .HeaderIndex
         End With
      End Sub

      Overrides Function Copy() As TSchema
         Copy = New TSchema(me)
      End Function

      Overrides Function GetID As String
         GetID = Cstr(me.GetHashCode())
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TSchema&quot;)
            .Prop(&quot;Name&quot;, me._name)
            .Prop(&quot;HeaderIndex&quot;, me.HeaderIndex)
            .Prop(&quot;Window&quot;, me._window.ToString())
            .Prop(&quot;Fields&quot;, me._fields.ToString())
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         If me._window &lt;&gt; NULL Then me._window.Free()
         If me._fields &lt;&gt; NULL Then me._fields.Free()
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

