    <mod_labeled_container>
      <Codigo>Imports Forms

&apos;@Module-Imported
Namespace mod_labeled_container

   Class TLabeledContainer

      Protected _control As CustomControl
      Protected _label As StaticText
      Protected _container As CustomControl

      Private _position As TAlign = alLeft
      Private _spacing As Integer = 6
      Private _heightEdit As Integer = 21
      Private _lblWidth As Integer

      Sub New(pControl As Forms.TWinControl, pLabel As String, pLabelWidth As Integer = 80)
         MyBase.New()
         me._lblWidth = pLabelWidth

         me._control = New CustomControl(pControl)
         me._control.Align = alTop

         me._label = New StaticText(me._control)
         me._label.AutoSize = False
         me._label.WordWrap = True
         me._label.AlignWithMargins = True
         me._label.Width = me._lblWidth

         me._container = New CustomControl(me._control)
         me._container.AlignWithMargins = True

         me.Caption = pLabel
         me.UpdateLayout()
      End Sub

      Property Caption As String
         Get
            Caption = me._label.Caption
         End Get
         Set(pValue As String)
            me.SetCaption(pValue)
         End Set
      End Property

      Property LabelPosition As TAlign
         Get
            LabelPosition = me._position
         End Get
         Set(pValue As TAlign)
            me._position = pValue
            me.UpdateLayout()
         End Set
      End Property

      Property LabelSpacing As Integer
         Get
            LabelSpacing = me._spacing
         End Get
         Set(pValue As Integer)
            me._spacing = pValue
            me.UpdateLayout()
         End Set
      End Property

      Property LabelWidth As Integer
         Get
            LabelWidth = me._lblWidth
         End Get
         Set(pValue As Integer)
            me._lblWidth = pValue
            me.UpdateLayout()
         End Set
      End Property

      Property Control As CustomControl
         Get
            Control = me._control
         End Get
      End Property

      Property Label As StaticText
         Get
            Label = me._label
         End Get
      End Property

      Property Container As CustomControl
         Get
            Container = me._container
         End Get
      End Property

      Private Sub UpdateLayout()
         me._label.Width = me._lblWidth
         me._label.Align = me._position
         me._container.Align = alClient

         me.ResetMargins(me._label.Margins)
         me.ResetMargins(me._container.Margins)
         me._container.Margins.Bottom = 3

         Select me._position
            Case alTop
               me._label.Alignment = taLeftJustify
               me._label.Height = 14
               me._spacing = 0
               me._label.Margins.Bottom = me._spacing
               me._control.Height = me._label.Height + me._heightEdit + me._spacing + 2

            Case alBottom
               me._label.Alignment = taLeftJustify
               me._label.Height = 14
               me._spacing = 0
               me._label.Margins.Top = me._spacing
               me._control.Height = me._label.Height + me._heightEdit + me._spacing + 2

            Case alLeft
               me._label.Alignment = taRightJustify
               If me.Caption.Length &lt;= 20 Then me._label.Margins.Top = 4
               me._label.Margins.Right = me._spacing
               me._container.Margins.Top = 2
               me._control.Height = me._heightEdit + 5

            Case alRight
               me._label.Alignment = taLeftJustify
               If me.Caption.Length &lt;= 20 Then me._label.Margins.Top = 4
               me._label.Margins.Left = me._spacing
               me._container.Margins.Top = 2
               me._control.Height = me._heightEdit + 5

         End Select
      End Sub

      Private Sub SetCaption(pValue As String)
         me._label.Caption = pValue
      End Sub

      Private Sub ResetMargins(ByRef m As TMargins)
         m.Left = 0
         m.Top = 0
         m.Right = 0
         m.Bottom = 0
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub
   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_labeled_container>
    <mod_notifier>
      <Codigo>Imports mod_base_list

&apos;@Module-Imported
Namespace mod_notifier

   Delegate Sub DelChange(pName As String, pValue As Variant, pType As String)
   Delegate Sub DelChangeObject(pName As String, pValue As TObject, pType As String)
   Delegate Sub DelChangeBoolean(pName As String, pValue As Boolean)
   Delegate Sub DelChangeDate(pName As String, pValue As TDateTime)
   Delegate Sub DelChangeInteger(pName As String, pValue As Integer)
   Delegate Sub DelChangeDouble(pName As String, pValue As Double)
   Delegate Sub DelChangeString(pName As String, pValue As String)

   Dim _value As Variant = &quot;&quot;

   Class Notifier
      Inherits BaseItem

      InternalName As String
      OnChangeNotify As DelChange
      OnChangeObjectNotify As DelChangeObject
      OnChangeBooleanNotify As DelChangeBoolean
      OnChangeDateNotify As DelChangeDate
      OnChangeIntegerNotify As DelChangeInteger
      OnChangeDoubleNotify As DelChangeDouble
      OnChangeStringNotify As DelChangeString

      Notify As Boolean = True
      Private _notify As Boolean = True

      Sub New(pOnChangeNotify As DelChange, pName As String = &quot;&quot;)
         MyBase.New()
         me.OnChangeNotify = pOnChangeNotify
         me.InternalName = pName
      End Sub

      Sub New(pOnChangeNotify As DelChange, pOnChangeDate As DelChangeDate, pName As String = &quot;&quot;)
         MyBase.New()
         me.OnChangeNotify = pOnChangeNotify
         me.OnChangeDateNotify = pOnChangeDate
         me.InternalName = pName
      End Sub

      Sub New(pValue As Notifier)
         MyBase.New()
         If pValue &lt;&gt; NULL Then me.Fill(pValue)
      End Sub

      Sub New(pName As String = &quot;&quot;)
         MyBase.New()
         me.InternalName = pName
      End Sub


      Sub PauseNotify()
         me._notify = CBool(me.Notify)
         me.Notify = False
      End Sub

      Sub ResumeNotify()
         me.Notify = CBool(me._notify)
      End Sub

      Sub SetSilent(ByRef pDest As Variant, ByVal pValue As Variant)
         me.PauseNotify()
         pDest = pValue
         me.ResumeNotify()
      End Sub

      Protected Overridable Sub OnChange(pName As String, pValue As Variant, pType As String)
      End Sub

      Protected Overridable Sub OnChangeObject(pName As String, pValue As TObject, pType As String)
      End Sub

      Protected Overridable Sub OnChangeDate(pName As String, pValue As TDateTime)
      End Sub

      Protected Overridable Sub OnChangeBoolean(pName As String, pValue As Boolean)
      End Sub

      Protected Overridable Sub OnChangeInteger(pName As String, pValue As Integer)
      End Sub

      Protected Overridable Sub OnChangeDouble(pName As String, pValue As Double)
      End Sub

      Protected Overridable Sub OnChangeString(pName As String, pValue As String)
      End Sub

      Private Sub Dispatch(pName As String, pValue As TObject, pType As String)
         me.OnChangeObject(pName, pValue, pType)
         If me.OnChangeObjectNotify &lt;&gt; NULL Then me.OnChangeObjectNotify(pName, pValue, pType)
         me.DispatchEvent(me.Fullname(pName), _value, pType)
      End Sub

      Protected Sub Dispatch(pName As String, pValue As Variant, pType As String)
         If Not me.Notify Then Exit Sub
         me.DispatchEvent(me.Fullname(pName), pValue, pType)
      End Sub

      Protected Sub Dispatch(pName As String)
         If Not me.Notify Then Exit Sub
         me.DispatchEvent(me.Fullname(pName), _value, &quot;&quot;)
      End Sub

      Private Sub DispatchEvent(pName As String, pValue As Variant, pType As String)
         me.OnChange(pName, pValue, pType)
         If me.OnChangeNotify &lt;&gt; NULL Then me.OnChangeNotify(pName, pValue, pType)
      End Sub

      Private Sub DispatchDate(pName As String, pValue As TDateTime)
         me.OnChangeDate(pName, pValue)
         If me.OnChangeDateNotify &lt;&gt; NULL Then me.OnChangeDateNotify(pName, pValue)
         me.DispatchEvent(pName, pValue, &quot;TDateTime&quot;)
      End Sub

      Private Sub DispatchBoolean(pName As String, pValue As Boolean)
         me.OnChangeBoolean(pName, pValue)
         If me.OnChangeBooleanNotify &lt;&gt; NULL Then me.OnChangeBooleanNotify(pName, pValue)
         me.DispatchEvent(pName, pValue, &quot;Boolean&quot;)
      End Sub

      Private Sub DispatchInteger(pName As String, pValue As Integer)
         me.OnChangeInteger(pName, pValue)
         If me.OnChangeIntegerNotify &lt;&gt; NULL Then me.OnChangeIntegerNotify(pName, pValue)
         me.DispatchEvent(pName, pValue, &quot;Integer&quot;)
      End Sub

      Private Sub DispatchDouble(pName As String, pValue As Double)
         me.OnChangeDouble(pName, pValue)
         If me.OnChangeDoubleNotify &lt;&gt; NULL Then me.OnChangeDoubleNotify(pName, pValue)
         me.DispatchEvent(pName, pValue, &quot;Double&quot;)
      End Sub

      Private Sub DispatchString(pName As String, pValue As String)
         me.OnChangeString(pName, pValue)
         If me.OnChangeStringNotify &lt;&gt; NULL Then me.OnChangeStringNotify(pName, pValue)
         me.DispatchEvent(pName, pValue, &quot;String&quot;)
      End Sub

      Protected Sub SetDate(pName As String, ByRef pDest As TDateTime, ByVal pValue As TDateTime)
         pDest = pValue
         If Not me.Notify Then Exit Sub
         me.DispatchDate(me.Fullname(pName), pValue)
      End Sub

      Protected Sub SetBoolean(pName As String, ByRef pDest As Boolean, ByVal pValue As Boolean)
         pDest = pValue
         If Not me.Notify Then Exit Sub
         me.DispatchBoolean(me.Fullname(pName), pValue)
      End Sub

      Protected Sub SetInteger(pName As String, ByRef pDest As Integer, ByVal pValue As Integer)
         pDest = pValue
         If Not me.Notify Then Exit Sub
         me.DispatchInteger(me.Fullname(pName), pValue)
      End Sub

      Protected Sub SetDouble(pName As String, ByRef pDest As Double, ByVal pValue As Double)
         pDest = pValue
         If Not me.Notify Then Exit Sub
         me.DispatchDouble(me.Fullname(pName), pValue)
      End Sub

      Protected Sub SetString(pName As String, ByRef pDest As String, ByVal pValue As String)
         pDest = pValue
         If Not me.Notify Then Exit Sub
         me.DispatchString(me.Fullname(pName), pValue)
      End Sub

      Private Function Fullname(pName As String) As String
         If me.InternalName &lt;&gt; &quot;&quot;
            Fullname = me.InternalName &amp; &quot;.&quot; &amp; pName
         Else
            Fullname = pName
         End If
      End Function

      Sub Attach(pNotifier As Notifier)
         If pNotifier = NULL Then Exit Sub
         pNotifier.OnChangeObjectNotify = me.OnChangeObjectHandler
         pNotifier.OnChangeNotify = me.OnChangeVariantHandler
         pNotifier.OnChangeNotify = me.OnChangeVariantHandler
         pNotifier.OnChangeNotify = me.OnChangeVariantHandler
         pNotifier.OnChangeNotify = me.OnChangeVariantHandler
         pNotifier.OnChangeNotify = me.OnChangeVariantHandler
      End Sub

      Private Sub OnChangeObjectHandler(pName As String, pValue As TObject, pType As String)
         me.Dispatch(pName, pValue, pType)
      End Sub

      Private Sub OnChangeVariantHandler(pName As String, pValue As Variant, pType As String)
         me.Dispatch(pName, pValue, pType)
      End Sub

      Sub Fill(pValue As Notifier)
         If pValue = NULL Then Exit Sub
         With pValue
            me.InternalName = .InternalName
            me.OnChangeNotify = .OnChangeNotify
            me.OnChangeObjectNotify = .OnChangeObjectNotify
            me.OnChangeDateNotify = .OnChangeDateNotify
            me.OnChangeBooleanNotify = .OnChangeBooleanNotify
            me.OnChangeIntegerNotify = .OnChangeIntegerNotify
            me.OnChangeDoubleNotify = .OnChangeDoubleNotify
            me.OnChangeStringNotify = .OnChangeStringNotify
         End With
      End Sub

      Overrides Function Copy As Notifier
         Copy = New Notifier(me)
      End Function

      Overridable Overrides Function GetID As String
         GetID = CStr(me.GetHashCode)
      End Function

      Overridable Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;Notifier&quot;)
            .Prop(&quot;InternalName&quot;, me.InternalName)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.InternalName = &quot;&quot;
         me.OnChangeNotify = NULL
         me.OnChangeDateNotify = NULL
         me.OnChangeBooleanNotify = NULL
         me.OnChangeIntegerNotify = NULL
         me.OnChangeDoubleNotify = NULL
         me.OnChangeStringNotify = NULL
      End Sub

      Sub Free()
         me.Dispose()
         MyBase.Free()
      End Sub

   End Class
End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_notifier>
    <mod_pipeline>
      <Codigo>Imports Collections
Imports mod_pipeline_group
Imports mod_pipeline_record
Imports mod_pipeline_schema
Imports mod_pipeline_mapper
Imports mod_pipeline_grouper
Imports mod_pipeline_exporter
Imports mod_pipeline_extractor
Imports mod_pipeline_navigator
Imports mod_pipeline_validation
Imports mod_pipeline_datasource

&apos;Importamos os namespaces para que a engine carregue os .bas, pois ela não puxa quando usa atribuição direta sem imports
Imports mod_pipeline_navigator_horizontal
Imports mod_pipeline_navigator_vertical
Imports mod_pipeline_datasource_grid
Imports mod_pipeline_datasource_excel
Imports mod_pipeline_datasource_csv

&apos;@Module-Imported
Namespace mod_pipeline

   Delegate Sub OnPhaseChangeDelegate(pPhase As String, pDescription As String)

   Class TPipeline

      Schema As TSchema
      InputSource As TDataSource
      InputNavigator As TNavigator

      Mapper As TMapper = New TMapper()
      Extractor As TExtractor = New TExtractor()
      Grouper As TGrouper

      Exporter As TExporter
      OutputSource As TDataSource
      OutputNavigator As TNavigator

      OnPhaseChange As OnPhaseChangeDelegate

      &apos; === VARIÁVEIS DE ESTADO ===
      Result As TPipelineResult
      Records As TRecordList
      Groups As TGroupList

      Sub New()
         MyBase.New()
      End Sub

      &apos; 0. INICIALIZAÇÃO
      Sub Initialize()
         If me.InputSource = NULL Then
            Throw New Exception(&quot;Pipeline.InputSource Not Defined.&quot;)
         End If

         &apos; Limpa o estado anterior caso a classe esteja sendo reaproveitada
         If me.Result &lt;&gt; NULL Then me.Result.Free()
         me.Result = New TPipelineResult()

         If me.Records &lt;&gt; NULL Then me.Records.Free()
         me.Records = NULL

         If me.Groups &lt;&gt; NULL Then me.Groups.Free()
         me.Groups = NULL

         me.InputSource.Open()
      End Sub

      Function Run() As TPipelineResult
         me.Initialize()
         If me.RunMapping()
            If me.RunExtraction()
               If me.RunGrouping()
                  If me.RunExport()
                     me.Cleanup()
                  End If
               End If
            End If
         End If
         Run = me.Result
      End Function

      &apos; 1. FASE DE MAPEAMENTO (Localizar Header)
      Function RunMapping() As Boolean
         me._notify(&quot;MAPPING&quot;, &quot;Localizando cabeçalho e estruturando Schema...&quot;)
         me.Mapper.ThrowExceptionOnFailure = False
         Dim _mapRes As TValidationResult = me.Mapper.Execute(me.Schema, me.InputNavigator)

         me.Result.Logs.Add(_mapRes.Logs.Text)
         RunMapping = _mapRes.Success

         If Not _mapRes.Success Then
            me.Result.Logs.Add(&quot;Pipeline interrompido: Falha no mapeamento.&quot;)
         End If
         _mapRes.Free()
      End Function

      &apos; 2. FASE DE EXTRAÇÃO (Leitura física para memória)
      Function RunExtraction() As Boolean
         me._notify(&quot;EXTRACTION&quot;, &quot;Extraindo dados da fonte de entrada...&quot;)

         &apos; 1. Evita Memory Leak: Libera a lista de registros anterior
         If me.Records &lt;&gt; NULL Then
            me.Records.Free()
            me.Records = NULL
         End If

         &apos; 2. O Segredo: Retorna o ponteiro de leitura para a primeira linha APÓS o cabeçalho
         If me.Schema &lt;&gt; NULL Then
            If me.Schema.HeaderIndex &gt;= 0 Then
               me.InputNavigator.Position = me.Schema.HeaderIndex + 1
            End If
         End If

         &apos; 3. Inicia a extração com o cursor no lugar certo
         me.Records = me.Extractor.Execute(me.Schema, me.InputNavigator)

         If me.Records = NULL Then
            RunExtraction = False
            Exit Function
         End If

         me.Result.RecordsRead = me.Records.Count
         me.Result.Logs.Add(&quot;Sucesso: &quot; &amp; Cstr(me.Records.Count) &amp; &quot; registros extraídos.&quot;)
         RunExtraction = True
      End Function

      &apos; 3. FASE DE AGRUPAMENTO (Opcional)
      Function RunGrouping() As Boolean
         If me.Grouper = NULL Then
            RunGrouping = True
            Exit Function
         End If

         If me.Records = NULL Then
            Throw New Exception(&quot;TPipeline: É necessário executar a extração (RunExtraction) antes do agrupamento.&quot;)
         End If

         me._notify(&quot;GROUPING&quot;, &quot;Organizando dados em grupos hierárquicos...&quot;)

         me.Groups = me.Grouper.Execute(me.Records)

         If me.Groups = NULL Then
            RunGrouping = False
            Exit Function
         End If

         me.Result.Logs.Add(&quot;Sucesso: &quot; &amp; Cstr(me.Groups.Count) &amp; &quot; grupos gerados.&quot;)
         RunGrouping = True
      End Function

      &apos; 4. FASE DE EXPORTAÇÃO (Escrita no destino)
      Function RunExport() As Boolean
         If me.Exporter = NULL Or me.OutputSource = NULL Then
            Throw New Exception(&quot;TPipeline: Exporter ou OutputSource não definidos.&quot;)
         End If

         If me.Records = NULL Then
            Throw New Exception(&quot;TPipeline: Não há registros para exportar. Execute a extração primeiro.&quot;)
         End If

         me._notify(&quot;EXPORTING&quot;, &quot;Gravando dados na fonte de saída...&quot;)
         me.OutputNavigator.Data = me.OutputSource

         If me.Groups &lt;&gt; NULL Then
            me.Exporter.Export(me.Groups, me.OutputNavigator)
         Else
            me.Exporter.Export(me.Records, me.OutputNavigator)
         End If

         me.Result.RecordsExported = me.Records.Count
         me.Result.Logs.Add(&quot;Sucesso: Dados gravados em &quot; &amp; me.OutputSource.Name)
         me.Result.Success = True

         RunExport = True
      End Function

      &apos; 5. FINALIZAÇÃO
      Sub Cleanup()
         If me.InputSource &lt;&gt; NULL Then me.InputSource.Close()
         If me.OutputSource &lt;&gt; NULL Then me.OutputSource.Close()
      End Sub

      Protected Overridable Sub _notify(pPhase As String, pDesc As String)
         If me.OnPhaseChange &lt;&gt; NULL Then me.OnPhaseChange(pPhase, pDesc)
      End Sub

      Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TPipeline&quot;)
            .Prop(&quot;Schema&quot;, me.Schema.ToString())
            .Prop(&quot;InputSource&quot;, me.InputSource.ToString())
            .Prop(&quot;InputNavigator&quot;, me.InputNavigator.ToString())
            .Prop(&quot;Mapper&quot;, CStr(me.Mapper &lt;&gt; NULL))
            .Prop(&quot;Extractor&quot;, CStr(me.Extractor &lt;&gt; NULL))
            .Prop(&quot;Grouper&quot;, CStr(me.Grouper &lt;&gt; NULL))
            .Prop(&quot;Exporter&quot;, me.Exporter.ToString())
            .Prop(&quot;OutputSource&quot;, CStr(me.OutputSource &lt;&gt; NULL))
            .Prop(&quot;OutputNavigator&quot;, CStr(me.OutputNavigator &lt;&gt; NULL))
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         If me.Mapper &lt;&gt; NULL Then me.Mapper.Free()
         If me.Extractor &lt;&gt; NULL Then me.Extractor.Free()
         If me.Result &lt;&gt; NULL Then me.Result.Free()
         If me.Records &lt;&gt; NULL Then me.Records.Free()
         If me.Groups &lt;&gt; NULL Then me.Groups.Free()
         MyBase.Free()
      End Sub
   End Class


   Class TPipelineResult

      Success As Boolean = False
      RecordsRead As Integer = 0
      RecordsExported As Integer = 0
      ExecutionTime As Double = 0
      Logs As StringList = New StringList()

      Sub New()
         MyBase.New()
      End Sub

      Function ToString(pPrint As Boolean = False) As String
         Dim _logs As String
         If me.Logs &lt;&gt; NULL Then
            _logs = me.Logs.Text
         End If
         With console.Block(&quot;TPipelineResult&quot;)
            .Prop(&quot;Success&quot;, me.Success)
            .Prop(&quot;RecordsRead&quot;, me.RecordsRead)
            .Prop(&quot;RecordsExported&quot;, me.RecordsExported)
            .Prop(&quot;Logs&quot;, _logs)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         If me.Logs &lt;&gt; NULL Then me.Logs.Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline>
    <mod_pipeline_actions>
      <Codigo>Imports Vcl.Dialogs
Imports System.IOUtils
Imports mod_pipeline_controller
Imports mod_pipeline_record
Imports mod_pipeline_group
Imports mod_pipeline_cell
Imports mod_base_editor

&apos;@Module-Imported
Namespace mod_pipeline_actions

   Class TPipelineActions

      Private _form As mod_pipeline_form.TPipelineForm
      Private _controller As TPipelineController

      ValidadeOnSelectPathSource As Boolean = True
      Private _pathSourceIsValid As Boolean = False
      Private _isUpdating As Boolean = False

      Sub New(pView As mod_pipeline_form.TPipelineForm, pController As TPipelineController)
         MyBase.New()
         me._form = pView
         me._controller = pController
         me._fill()
         me._bind()
         me._updateUI()
      End Sub

      Private Sub _autoSelect(pCombo As TComboEditor)
         If pCombo.Items.Count &gt;= 1 Then
            pCombo.ItemIndex = 0
         End If
      End Sub

      Private Sub _fill()
         me._isUpdating = True
         Try
            me._form.InSchemaSource.ListaOpcoes = me._controller.GetInputSchemaOptions()
            me._isUpdating = False

            me._refreshInputInfraCombos()
            me._refreshOutputInfraCombos()
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
      End Sub

      Private Sub _refreshInputInfraCombos()
         me._isUpdating = True
         Try
            Dim optDS As String = me._controller.GetInputDataSourceOptions()
            If me._form.InDataSourceType.ListaOpcoes &lt;&gt; optDS Then
               me._form.InDataSourceType.ListaOpcoes = optDS
               me._autoSelect(me._form.InDataSourceType)
            End If
            me._controller.SetInputDataSource(me._form.InDataSourceType.NameSelect)

            Dim optNav As String = me._controller.GetInputNavigatorOptions()
            If me._form.InNavigatorType.ListaOpcoes &lt;&gt; optNav Then
               me._form.InNavigatorType.ListaOpcoes = optNav
               me._autoSelect(me._form.InNavigatorType)
            End If
            me._controller.SetInputNavigator(me._form.InNavigatorType.NameSelect)

            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
      End Sub

      Private Sub _refreshOutputInfraCombos()
         me._isUpdating = True
         Try
            Dim optDS As String = me._controller.GetOutputDataSourceOptions()
            If me._form.OutDataSourceType.ListaOpcoes &lt;&gt; optDS Then
               me._form.OutDataSourceType.ListaOpcoes = optDS
               me._autoSelect(me._form.OutDataSourceType)
            End If
            me._controller.SetOutputDataSource(me._form.OutDataSourceType.NameSelect)

            Dim optNav As String = me._controller.GetOutputNavigatorOptions()
            If me._form.OutNavigatorType.ListaOpcoes &lt;&gt; optNav Then
               me._form.OutNavigatorType.ListaOpcoes = optNav
               me._autoSelect(me._form.OutNavigatorType)
            End If
            me._controller.SetOutputNavigator(me._form.OutNavigatorType.NameSelect)

            Dim optGroups As String = me._controller.GetGrouperOutputOptions()
            If optGroups &lt;&gt; &quot;&quot; Then optGroups = &quot;=;&quot; &amp; optGroups

            If me._form.InGrouperOutput.ListaOpcoes &lt;&gt; optGroups Then
               me._form.InGrouperOutput.ListaOpcoes = optGroups
            End If
            me._controller.SetOutputGrouper(me._form.InGrouperOutput.NameSelect)

            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
      End Sub

      Private Sub _bind()
         me._form.InSchemaSource.OnChange = me._handleSelectSchemaSource
         me._form.InDataSourceType.OnChange = me._handleSelectInDataSource
         me._form.InNavigatorType.OnChange = me._handleSelectInNavigator
         me._form.InPathSource.OnButtonClick = me._handleSelectPathSource

         me._form.OutDataSourceType.OnChange = me._handleSelectOutDataSource
         me._form.OutNavigatorType.OnChange = me._handleSelectOutNavigator
         me._form.InGrouperOutput.OnChange = me._handleSelectGrouperOutput
         me._form.InPathOutput.OnButtonClick = me._handleSelectPathOutput

         me._form.TopBtnRead.OnClick = me._handleOnClickRead
         me._form.TopBtnExport.OnClick = me._handleOnClickExport
         me._form.BtnRead.OnClick = me._handleOnClickRead
         me._form.BtnExport.OnClick = me._handleOnClickExport

         me._form.GridRecords.OnMarcaDesmarcaLinhaParaExclusao = me._handleOnMarcaDesmarcaLinhaParaExclusaoRecords
         me._form.GridGroups.OnMarcaDesmarcaLinhaParaExclusao = me._handleOnMarcaDesmarcaLinhaParaExclusaoGroups

         me._controller.OnLog = me._handleOnLog
      End Sub

      Private Sub _updateUI()
         If me._isUpdating Then Exit Sub

         Dim step1_SchemaInOK As Boolean = (me._form.InSchemaSource.ValueSelect &lt;&gt; &quot;&quot;)

         If me._form.InDataSourceType.Enabled &lt;&gt; step1_SchemaInOK Then me._form.InDataSourceType.Enabled = step1_SchemaInOK
         If me._form.InNavigatorType.Enabled &lt;&gt; step1_SchemaInOK Then me._form.InNavigatorType.Enabled = step1_SchemaInOK

         Dim step2_InfraInOK As Boolean = step1_SchemaInOK And (me._form.InDataSourceType.ValueSelect &lt;&gt; &quot;&quot;) And (me._form.InNavigatorType.ValueSelect &lt;&gt; &quot;&quot;)
         If me._form.InPathSource.Enabled &lt;&gt; step2_InfraInOK Then me._form.InPathSource.Enabled = step2_InfraInOK

         Dim step3_PathInOK As Boolean = step2_InfraInOK And (me._form.InPathSource.AsString &lt;&gt; &quot;&quot;)
         If me._form.BtnRead.Enabled &lt;&gt; step3_PathInOK Then me._form.BtnRead.Enabled = step3_PathInOK
         If me._form.TopBtnRead.Enabled &lt;&gt; step3_PathInOK Then me._form.TopBtnRead.Enabled = step3_PathInOK

         Dim canExportBase As Boolean = me._controller.CanExport()

         Dim step4_SchemaOutOK As Boolean = canExportBase

         If me._form.OutDataSourceType.Enabled &lt;&gt; step4_SchemaOutOK Then me._form.OutDataSourceType.Enabled = step4_SchemaOutOK
         If me._form.OutNavigatorType.Enabled &lt;&gt; step4_SchemaOutOK Then me._form.OutNavigatorType.Enabled = step4_SchemaOutOK

         Dim step5_InfraOutOK As Boolean = step4_SchemaOutOK And (me._form.OutDataSourceType.ValueSelect &lt;&gt; &quot;&quot;) And (me._form.OutNavigatorType.ValueSelect &lt;&gt; &quot;&quot;)

         Dim hasGrouperOptions As Boolean = (me._form.InGrouperOutput.ListaOpcoes &lt;&gt; &quot;&quot;)
         Dim enableGrouper As Boolean = step5_InfraOutOK And hasGrouperOptions
         If me._form.InGrouperOutput.Enabled &lt;&gt; enableGrouper Then me._form.InGrouperOutput.Enabled = enableGrouper

         If me._form.InPathOutput.Enabled &lt;&gt; step5_InfraOutOK Then me._form.InPathOutput.Enabled = step5_InfraOutOK

         Dim step7_PathOutOK As Boolean = step5_InfraOutOK And (me._form.InPathOutput.AsString &lt;&gt; &quot;&quot;)
         If me._form.BtnExport.Enabled &lt;&gt; step7_PathOutOK Then me._form.BtnExport.Enabled = step7_PathOutOK
         If me._form.TopBtnExport.Enabled &lt;&gt; step7_PathOutOK Then me._form.TopBtnExport.Enabled = step7_PathOutOK
      End Sub

      Private Sub _invalidateInputData()
         me._form.InPathSource.AsString = &quot;&quot;
         Try
            me._controller.SetInputPath(&quot;&quot;)
         Catch ex As Exception
         End Try
         me._clearGrids()
      End Sub

      Private Sub _invalidateOutputData()
         me._form.InPathOutput.AsString = &quot;&quot;
         me._controller.SetOutputPath(&quot;&quot;)
         me._clearGridGroups()
      End Sub

      Private Sub _handleSelectSchemaSource(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT SCHEMA SOURCE&quot;)
            me._controller.SetInputSchema(me._form.InSchemaSource.NameSelect)
            me._refreshInputInfraCombos()
            me._refreshOutputInfraCombos()
            me._invalidateInputData()
            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectInDataSource(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT InDataSource&quot;)
            me._controller.SetInputDataSource(me._form.InDataSourceType.NameSelect)
            me._invalidateInputData()
            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectInNavigator(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT InNavigator&quot;)
            me._controller.SetInputNavigator(me._form.InNavigatorType.NameSelect)
            me._invalidateInputData()
            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectPathSource(pSender As TObject)
         If me._form.InSchemaSource.ValueSelect = &quot;&quot; Then
            Forms.MessageBox.Show(&quot;Selecione o modelo de entrada antes de selecionar o arquivo.&quot;)
            me._form.InSchemaSource.SetFocus()
            Exit Sub
         End If
         me._internalLog(&quot;SELECT PATH SOURCE&quot;)
         Dim _extension As String = me._controller.GetInputExtension()
         Dim _path As String = me._openDialog(&quot;Selecionar Arquivo&quot;, _extension).Trim()

         If _path &lt;&gt; &quot;&quot; Then
            me._form.InPathSource.AsString = _path
            me._controller.SetInputPath(_path)
            me._clearGrids()
            If me.ValidadeOnSelectPathSource Then
               me._validateSource()
            End If
         End If
         me._updateUI()
      End Sub

      Private Sub _handleOnClickRead(pSender As TObject)
         me._internalLog(&quot;READ&quot;)
         me._clearGrids()
         If me._processReading() Then
            me._populateGridRecords()
            me._processGrouping()
            me._applyCurrentOutputPaths()
            me._populateGridGroups()
         End If
         me._updateUI()
      End Sub

      Private Sub _handleSelectOutDataSource(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT OutDataSource&quot;)
            me._controller.SetOutputDataSource(me._form.OutDataSourceType.NameSelect)
            me._invalidateOutputData()
            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectOutNavigator(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT OutNavigator&quot;)
            me._controller.SetOutputNavigator(me._form.OutNavigatorType.NameSelect)
            me._invalidateOutputData()
            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Throw ex
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectGrouperOutput(pSender As TObject)
         If me._isUpdating Then Exit Sub
         me._isUpdating = True
         Try
            me._internalLog(&quot;SELECT GROUPER OUTPUT&quot;)
            me._controller.SetOutputGrouper(me._form.InGrouperOutput.NameSelect)
            me._invalidateOutputData()

            If me._controller.CanExport() Then
               me._processGrouping()
               me._populateGridGroups()
            End If

            me._isUpdating = False
         Catch ex As Exception
            me._isUpdating = False
            Forms.MessageBox.Show(&quot;Erro ao agrupar: &quot; &amp; ex._GetMessage())
         End Try
         me._updateUI()
      End Sub

      Private Sub _handleSelectPathOutput(pSender As TObject)
         me._internalLog(&quot;SELECT PATH OUTPUT&quot;)

         Dim groups As TGroupList = me._controller.GetGroups()
         Dim isMultiGroup As Boolean = False

         If groups &lt;&gt; NULL Then
            If groups.Count &gt; 1 Then isMultiGroup = True
         End If

         Dim _extension As String = me._controller.GetOutputExtension()
         Dim _defaultExt As String = me._extractDefaultExt(_extension)
         Dim _path As String = &quot;&quot;

         Dim _initialDir As String = me._getDirectoryName(me._form.InPathSource.AsString)

         If isMultiGroup Then
            _path = me._OpenSelectFolderDialog(&quot;Selecione a pasta para salvar os lotes&quot;, _initialDir)
         Else
            _path = me._OpenSaveFileDialog(&quot;Selecionar Arquivo&quot;, _extension, _defaultExt, _initialDir).Trim()
         End If

         If _path &lt;&gt; &quot;&quot; Then
            me._form.InPathOutput.AsString = _path
            me._controller.SetOutputPath(_path)
            me._applyCurrentOutputPaths()
            me._populateGridGroups()
         End If

         me._updateUI()
      End Sub

      Private Sub _applyCurrentOutputPaths()
         Dim _path As String = me._form.InPathOutput.AsString
         If _path = &quot;&quot; Then Exit Sub

         Dim _extension As String = me._controller.GetOutputExtension()
         Dim _defaultExt As String = me._extractDefaultExt(_extension)

         Dim prefix As String = &quot;&quot;
         Dim baseInputName As String = me._getFileNameWithoutExt(me._form.InPathSource.AsString)
         If baseInputName &lt;&gt; &quot;&quot; Then prefix = baseInputName &amp; &quot;-&quot;

         me._controller.ApplyGroupPaths(_path, prefix, _defaultExt)
      End Sub

      Private Sub _handleOnMarcaDesmarcaLinhaParaExclusaoRecords(S As TObject, pRow As Integer)
         Dim _id As String = me._form.GridRecords.Cells(me._form.GridRecords.ColCount - 1, pRow)
         Dim _records As TRecordList = me._controller.GetRecords()
         If _records &lt;&gt; NULL
            If _records.Has(_id)
               Dim _record As TRecord = _records.Take(_id)
               _record.Selected = Not _record.Selected
            End If
         End If
      End Sub

      Private Sub _handleOnMarcaDesmarcaLinhaParaExclusaoGroups(S As TObject, pRow As Integer)
         Dim _id As String = me._form.GridGroups.Cells(me._form.GridGroups.ColCount - 1, pRow)
         Dim _groups As TGroupList = me._controller.GetGroups()
         If _groups &lt;&gt; NULL
            If _groups.Has(_id)
               Dim _group As TGroup = _groups.Take(_id)
               _group.Selected = Not _group.Selected
            End If
         End If
      End Sub

      Private Sub _populateGridGroups()
         Dim groups As TGroupList = me._controller.GetGroups()

         If groups = NULL Then
            me._clearGridGroups()
            Exit Sub
         End If

         If groups.Count = 0 Then
            me._clearGridGroups()
            Exit Sub
         End If

         Dim grid As Forms.Grid = me._form.GridGroups
         grid.BeginUpdate()
         grid.Clear()

         grid.ColCount = 5
         grid.RowCount = groups.Count + 1

         grid.Cells(0, 0) = &quot;Chave&quot;
         grid.Cells(1, 0) = &quot;Qtd. Registros&quot;
         grid.Cells(2, 0) = &quot;Status&quot;
         grid.Cells(3, 0) = &quot;Caminho&quot;
         grid.Cells(4, 0) = &quot;ID&quot;

         Dim i As Integer
         For i = 0 To groups.Count - 1
            Dim grp As TGroup = groups.Take(i)

            grid.Cells(0, i + 1) = grp.Key.Key
            grid.Cells(1, i + 1) = CStr(grp.Items.Count)
            grid.Cells(2, i + 1) = &quot;Pronto&quot;

            If grp.OutputPath &lt;&gt; &quot;&quot; Then
               grid.Cells(3, i + 1) = grp.OutputPath
            Else
               grid.Cells(3, i + 1) = &quot;Aguardando...&quot;
            End If

            grid.Cells(4, i + 1) = grp.GetID()
         Next

         grid.EndUpdate()
         grid.AutoSize = True

         grid.PermiteMarcarExclusao = True
      End Sub

      Private Sub _populateGridRecords()
         Dim records As TRecordList = me._controller.GetRecords()

         If records = NULL Then
            me._clearGridRecords()
            Exit Sub
         End If

         If records.Count = 0
            me._clearGridRecords()
            Exit Sub
         End If

         Dim grid As Forms.Grid = me._form.GridRecords
         grid.BeginUpdate()
         grid.Clear()

         Dim firstRec As TRecord = records.Take(0)
         Dim dataCols As Integer = firstRec.Cells.Count
         grid.ColCount = dataCols + 2
         grid.RowCount = records.Count + 1

         grid.Cells(0, 0) = &quot;Item&quot;
         Dim colIdx As Integer
         For colIdx = 0 To dataCols - 1
            grid.Cells(colIdx + 1, 0) = firstRec.Cells.Take(colIdx).Title
         Next
         grid.Cells(grid.ColCount - 1, 0) = &quot;ID&quot;

         Dim rowIdx As Integer
         For rowIdx = 0 To records.Count - 1
            Dim rec As TRecord = records.Take(rowIdx)
            grid.Cells(0, rowIdx + 1) = Right(&quot;00000&quot; &amp; CStr(rowIdx + 1), 5)
            For colIdx = 0 To dataCols - 1
               grid.Cells(colIdx + 1, rowIdx + 1) = rec.Cells.Take(colIdx).Value.AsString
            Next
            grid.Cells(grid.ColCount - 1, rowIdx + 1) = rec.GetID()
         Next

         grid.EndUpdate()
         grid.AutoSize = True

         grid.PermiteMarcarExclusao = True
      End Sub

      Private Sub _clearGrids()
         me._clearGridRecords()
         me._clearGridGroups()
      End Sub

      Private Sub _clearGridRecords()
         With me._form.GridRecords
            .BeginUpdate()
            .Clear()
            .PermiteMarcarExclusao = False
            .ColCount = 5
            .RowCount = 2
            .EndUpdate()
         End With
      End Sub

      Private Sub _clearGridGroups()
         With me._form.GridGroups
            .BeginUpdate()
            .Clear()
            .PermiteMarcarExclusao = False
            .ColCount = 5
            .RowCount = 2
            .Cells(0, 0) = &quot;Chave&quot;
            .Cells(1, 0) = &quot;Qtd. Registros&quot;
            .Cells(2, 0) = &quot;Status&quot;
            .Cells(3, 0) = &quot;Caminho&quot;
            .Cells(4, 0) = &quot;ID&quot;
            .EndUpdate()
         End With
      End Sub

      Private Sub _validateSource()
         Try
            If Not me._controller.Validate() Then
               Dim _error As String = me._controller.GetLastError()
               Forms.MessageBox.Show(&quot;O arquivo selecionado é inválido, verifique:&quot; &amp; Chr(13) &amp; &quot;Arquivo: &quot; &amp; me._form.InPathSource.AsString &amp; Chr(13) &amp; Chr(13) &amp; _error)
               me._form.InPathSource.AsString = &quot;&quot;
            Else
               me._pathSourceIsValid = True
               If Forms.MessageBox.Confirmation(&quot;Estrutura do arquivo válida, deseja prosseguir com a leitura dos dados?&quot;)
                  me._handleOnClickRead(NULL)
               End If
               Exit Sub
            End If
         Catch ex As Exception
            Forms.MessageBox.Show(&quot;Ocorreu um erro ao carregar o arquivo: &quot; &amp; ex._GetMessage())
            me._form.InPathSource.AsString = &quot;&quot;
         End Try
         me._pathSourceIsValid = False
      End Sub

      Private Sub _handleOnClickExport(pSender As TObject)
         me._internalLog(&quot;EXPORT&quot;)
         me._processExporting()
         me._updateUI()
      End Sub

      Private Function _processReading() As Boolean
         _processReading = False
         Try
            If me._controller.Read() Then
               _processReading = True
            Else
               Forms.MessageBox.Show(&quot;Erro na leitura: &quot; &amp; me._controller.GetLastError())
            End If
         Catch ex As Exception
            Forms.MessageBox.Show(&quot;Erro ao fazer a leitura do arquivo: &quot; &amp; ex._GetMessage())
         End Try
      End Function

      Private Sub _processGrouping()
         Try
            me._controller.Group()
         Catch ex As Exception
            Forms.MessageBox.Show(&quot;Ocorreu um erro ao processar o agrupamento: &quot; &amp; ex._GetMessage())
         End Try
      End Sub

      Private Sub _processExporting()
         Try
            Dim _path As String = me._form.InPathOutput.AsString
            If me._controller.Export(_path) Then
               If Forms.MessageBox.Confirmation(&quot;Exportação concluída com sucesso!&quot; &amp; Chr(13) &amp; &quot;Deseja abrir o local de exportação?&quot;) Then
                  If IO.File.Exists(_path)
                     _path = me._getDirectoryName(_path)
                  End If
                  Environment.Execute(&quot;explorer&quot;, _path.Quoted, False)
               End If
            Else
               Forms.MessageBox.Show(&quot;Falha na exportação: &quot; &amp; me._controller.GetLastError())
            End If
         Catch ex As Exception
            Forms.MessageBox.Show(&quot;Ocorreu um erro ao fazer a exportação do arquivo: &quot; &amp; ex._GetMessage())
         End Try
      End Sub

      Private Sub _internalLog(pMsg As String)
         me._handleOnLog(pMsg)
      End Sub

      Private Sub _handleOnLog(pMsg As String)
         me._form.LogMemo.Lines.Add(pMsg)
      End Sub

      Private Function _getFileNameWithoutExt(pPath As String) As String
         _getFileNameWithoutExt = TPath.GetFileNameWithoutExtension(pPath)
      End Function

      Private Function _getDirectoryName(pPath As String) As String
         _getDirectoryName = TPath.GetDirectoryName(pPath)
      End Function

      Private Function _extractDefaultExt(ByVal pFilter As String) As String
         _extractDefaultExt = &quot;&quot;
         If pFilter = &quot;&quot; Then Exit Function
         Dim posStart As Integer = InStr(pFilter, &quot;*.&quot;)
         If posStart = 0 Then
             Exit Function
         End If
         posStart += 2
         Dim ext As String = Mid(pFilter, posStart)
         Dim posEnd As Integer = InStr(ext, &quot;;&quot;)
         If posEnd &gt; 0 Then ext = Left(ext, posEnd - 1)
         posEnd = InStr(ext, &quot;|&quot;)
         If posEnd &gt; 0 Then
            ext = Left(ext, posEnd - 1)
         End If
         _extractDefaultExt = Replace(ext, &quot;)&quot;, &quot;&quot;).Trim()
      End Function

      Private Function _openDialog(pTitle As String, pFilter As String) As String
         _openDialog = &quot;&quot;
         With New TOpenDialog(NULL)
            .Title = pTitle
            .Filter = pFilter
            If .Execute() Then _openDialog = .Filename
            .Free()
         End With
      End Function

      Private Function _OpenSaveFileDialog(pTitle As String, pFilter As String, pDefaultExt As String, pInitialDir As String) As String
         _OpenSaveFileDialog = &quot;&quot;
         With New TSaveDialog(NULL)
            .Title = pTitle
            .Filter = pFilter
            .DefaultExt = pDefaultExt

            If pInitialDir &lt;&gt; &quot;&quot; Then .InitialDir = pInitialDir

            If .Execute() Then
               Dim _selectedPath As String = .Filename
               If _selectedPath &lt;&gt; &quot;&quot; And pDefaultExt &lt;&gt; &quot;&quot; Then
                  If InStr(_selectedPath, &quot;.&quot;) = 0 Then
                     _selectedPath = _selectedPath &amp; &quot;.&quot; &amp; pDefaultExt
                  End If
               End If
               _OpenSaveFileDialog = _selectedPath
            End If
            .Free()
         End With
      End Function

      Private Function _OpenSelectFolderDialog(pTitle As String, pInitialDir As String) As String
         _OpenSelectFolderDialog = IO.Directory.SelectDialog(pTitle, pInitialDir)
      End Function

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline_actions>
    <mod_pipeline_cell>
      <Codigo>
Imports mod_base_list
Imports mod_pipeline_value
Imports mod_pipeline_util

&apos;@Module-Imported
Namespace mod_pipeline_cell

   Class TCell
      Inherits BaseItem

      Index As Integer
      Private _name As String
      Title As String
      Private _value As TTValue

      Property Name As String
         Get
            Name = me._name
         End Get
         Set(pValue As String)
            me._name = Utils.Normalize(pValue)
         End Set
      End Property

      Property Value As TTValue
         Get
            Value = me._value
         End Get
         Set(pValue As TTValue)
            If me._value &lt;&gt; NULL Then me._value.Free()
            me._value = pValue
         End Set
      End Property

      Sub New(pIndex As Integer, pName As String)
         MyBase.New()
         me.Index = pIndex
         me.Name = pName
         me.Title = pName
      End Sub

      Sub New(pIndex As Integer, pName As String, pTitle As String, pValue As TTValue)
         MyBase.New()
         me.Index = pIndex
         me.Name = pName
         me.Title = pTitle
         me._value = pValue
      End Sub

      Sub New(pValue As TCell)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TCell)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Index = .Index
            me.Name = .Name
            me.Title = .Title
            IF .Value &lt;&gt; NULL Then
               me._value = .Value.Copy()
            End If
         End With
      End Sub

      Overrides Function Copy() As TCell
         Copy = New TCell(me)
      End Function

      Overrides Function GetID As String
         GetID = me.Name
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         Dim _valueStr As String
         If me._value &lt;&gt; NULL Then
            _valueStr = me._value.ToString()
         Else
            _valueStr = &quot;NULL&quot;
         End If
         With console.Block(&quot;TCell&quot;)
            .Prop(&quot;Index&quot;, me.Index)
            .Prop(&quot;Name&quot;, me.Name)
            .Prop(&quot;Title&quot;, me.Title)
            .Prop(&quot;Value&quot;, _valueStr)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.Index = 0
         me.Name = &quot;&quot;
         me.Title = &quot;&quot;
         If me._value &lt;&gt; NULL Then me._value.Free()
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TCellFindDelegate(pValue As TCell, i As Integer, extra As Variant) As Boolean
   Delegate Function TCellMapDelegate(pValue As TCell, i As Integer, extra As Variant) As TCell
   Delegate Sub TCellForEachDelegate(pValue As TCell, i As Integer, extra As Variant)

   Class TCellList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TCellList&quot;, False)
      End Sub

      Property Item(pIndex As Integer) As TCell
         Get
            Item = CType(MyBase.Take(pIndex), TCell)
         End Get
         Set(pValue As TCell)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TCell
         Take = CType(MyBase.Take(pIndex), TCell)
      End Function

      Function Take(pID As String) As TCell
         Take = CType(MyBase.TakeFromId(pID), TCell)
      End Function

      Function First As TCell
         First = CType(MyBase.First, TCell)
      End Function

      Function First(pLimit As Integer) As TCellList
         First = CType(MyBase.Range(pLimit, False), TCellList)
      End Function

      Function Last As TCell
         Last = CType(MyBase.Last, TCell)
      End Function

      Function Last(pLimit As Integer) As TCellList
         Last = CType(MyBase.Range(pLimit, True), TCellList)
      End Function

      Function Copy As TCellList
         Return CType(MyBase.Copy(), TCellList)
      End Function

      Function IndexOf(handler As TCellFindDelegate) As Integer
         IndexOf = me.IndexOf(handler, &quot;&quot;)
      End Function

      Function IndexOf(handler As TCellFindDelegate, extra As Variant) As Integer
         IndexOf = MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As TCellFindDelegate) As TCell
         Find = me.Find(handler, &quot;&quot;)
      End Function

      Function Find(handler As TCellFindDelegate, extra As Variant) As TCell
         Find = CType(MyBase.Find(handler, extra), TCell)
      End Function

      Function Filter(handler As TCellFindDelegate) As TCellList
         Return me.Filter(handler, &quot;&quot;)
      End Function

      Function Filter(handler As TCellFindDelegate, extra As Variant) As TCellList
         Filter = CType(MyBase.Filter(handler, extra), TCellList)
      End Function

      Sub ForEach(handler As TCellFindDelegate)
         me.ForEach(handler, &quot;&quot;)
      End Sub

      Sub ForEach(handler As TCellForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As TCellFindDelegate) As TCellList
         Map = me.Map(handler, &quot;&quot;)
      End Function

      Function Map(handler As TCellMapDelegate, extra As Variant) As TCellList
         With CType(MyBase.Map(handler, extra), TCellList)
            Map = .Copy()
         End With
      End Function

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
