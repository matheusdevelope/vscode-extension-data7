&apos;@Module-Imported
Namespace mod_pipeline_option

   Class TOption
      Inherits BaseItem

      Private _value As String
      Private _found As Boolean

      Property Value As String
         Get
            Value = me._value
         End Get
      End Property

      Property Found As Boolean
         Get
            Found = me._found
         End Get
         Set(pValue As Boolean)
            me._found = pValue
         End Set
      End Property

      Sub New(pValue As String, pFound As Boolean = False)
         MyBase.New()
         me._value = Utils.Normalize(pValue)
         me._found = pFound
      End Sub

      Sub New(pValue As TOption)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TOption)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me._value = .Value
            me._found = .Found
         End With
      End Sub

      Overrides Function Copy() As TOption
         Copy = New TOption(me)
      End Function

      Overrides Function GetID As String
         GetID = me._value
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TOption&quot;)
            .Prop(&quot;Value&quot;, me._value)
            .Prop(&quot;Found&quot;, me._found)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me._value = &quot;&quot;
         me._found = False
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TOptionFindDelegate(pValue As TOption, i As Integer, extra As Variant) As Boolean
   Delegate Function TOptionMapDelegate(pValue As TOption, i As Integer, extra As Variant) As TOption
   Delegate Sub TOptionForEachDelegate(pValue As TOption, i As Integer, extra As Variant)

   Class TOptionList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TOptionList&quot;, False)
      End Sub

      Function Add(pValue As String) As TOption
         Dim _option As TOption
         If me.Has(pValue) Then
            _option = me.Take(pValue)
         Else
            _option = New TOption(pValue)
            me.Add(_option)
         End If
         Add = _option
      End Function

      Function AsString As String
         Dim txt As New StringList()
         Dim i As Integer, _count As Integer = me.Count - 1
         For i = 0 to _count
            txt.Add(me.Take(i).Value)
         Next
         AsString = txt.Text.Trim.Replace(txt.LineBreak, &quot;, &quot;)
         txt.Free()
      End Function

      Property Item(pIndex As Integer) As TOption
         Get
            Item = CType(MyBase.Take(pIndex), TOption)
         End Get
         Set(pValue As TOption)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TOption
         Take = CType(MyBase.Take(pIndex), TOption)
      End Function

      Function Take(pID As String) As TOption
         Take = CType(MyBase.TakeFromId(pID), TOption)
      End Function

      Function First As TOption
         First = CType(MyBase.First, TOption)
      End Function

      Function First(pLimit As Integer) As TOptionList
         First = CType(MyBase.Range(pLimit, False), TOptionList)
      End Function

      Function Last As TOption
         Last = CType(MyBase.Last, TOption)
      End Function

      Function Last(pLimit As Integer) As TOptionList
         Last = CType(MyBase.Range(pLimit, True), TOptionList)
      End Function

      Function Copy As TOptionList
         Return CType(MyBase.Copy(), TOptionList)
      End Function

