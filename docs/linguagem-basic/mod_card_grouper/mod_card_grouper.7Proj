    <mod_pipeline_controller>
      <Codigo>Imports mod_pipeline
Imports mod_pipeline_datasource
Imports mod_pipeline_navigator
Imports mod_pipeline_exporter
Imports mod_pipeline_record
Imports mod_pipeline_group

&apos;@Module-Imported
Namespace mod_pipeline_controller

   Delegate Sub OnLogDelegate(pMsg As String)

   Class TPipelineController

      Protected _pipe As TPipeline
      Protected _canExport As Boolean = False
      Protected _lastError As String = &quot;&quot;

      Protected _inDataSourceName As String = &quot;&quot;
      Protected _inNavigatorName As String = &quot;&quot;
      Protected _outDataSourceName As String = &quot;&quot;
      Protected _outNavigatorName As String = &quot;&quot;

      Private _lastProgressBucket As Double = -1
      ProgressStep As Integer = 10

      OnLog As OnLogDelegate

      Sub New()
         MyBase.New()
         me._pipe = New TPipeline()
         me._pipe.OnPhaseChange = me._handleOnPhaseChange
         me._pipe.Extractor.OnProgress = me._handleOnProgress
      End Sub

      Protected Overridable Sub _handleOnProgress(pCurrent As Integer, pTotal As Integer)
         If pTotal &lt;= 0 Then Exit Sub
         If me._lastProgressBucket = 999 Then Exit Sub

         If pCurrent &gt;= pTotal Then
            me._handleOnPhaseChange(&quot;Extração&quot;, &quot;Progresso: 100% (&quot; &amp; CStr(pTotal) &amp; &quot;/&quot; &amp; CStr(pTotal) &amp; &quot;)&quot;)
            me._lastProgressBucket = 999
            Exit Sub
         End If

         Dim _percentTotal As Double = (pCurrent / pTotal) * 100
         Dim _bucket As Integer = Int(_percentTotal / me.ProgressStep)

         If _bucket &gt; _lastProgressBucket And _bucket &gt; 0 Then
            me._lastProgressBucket = _bucket
            Dim _percentDisplay As Integer = _bucket * me.ProgressStep
            Dim _label As String = &quot;Progresso: &quot; &amp; Replace(Replace(CStr(_percentDisplay), &quot;,&quot;, &quot;&quot;), &quot;.&quot;, &quot;,&quot;) &amp; &quot;% (&quot; &amp; CStr(pCurrent) &amp; &quot;/&quot; &amp; CStr(pTotal) &amp; &quot;)&quot;
            me._handleOnPhaseChange(&quot;Extração&quot;, _label)
         End If
      End Sub

      Protected Sub _handleOnPhaseChange(pPhase As String, pDesc As String)
         me.SendLog(&quot;[&quot; &amp; pPhase &amp; &quot;] &quot; &amp; pDesc)
      End Sub

      Overridable Function GetInputDataSourceOptions() As String
         If me._pipe.Schema &lt;&gt; NULL
            If me._pipe.Schema.SupportedInputDataSources.Count &gt; 0 Then
               GetInputDataSourceOptions = me._pipe.Schema.SupportedInputDataSources.AsOptions
               Exit Function
            End If
         End If
         GetInputDataSourceOptions = DataSource.GetOptions()
      End Function

      Overridable Function GetInputNavigatorOptions() As String
         If me._pipe.Schema &lt;&gt; NULL
            If me._pipe.Schema.SupportedInputNavigators.Count &gt; 0 Then
               GetInputNavigatorOptions = me._pipe.Schema.SupportedInputNavigators.AsOptions
               Exit Function
            End If
         End If
         GetInputNavigatorOptions = Navigator.GetOptions()
      End Function

      Overridable Function GetOutputDataSourceOptions() As String
         If me._pipe.Schema &lt;&gt; NULL
            If me._pipe.Schema.SupportedOutputDataSources.Count &gt; 0 Then
               GetOutputDataSourceOptions = me._pipe.Schema.SupportedOutputDataSources.AsOptions
               Exit Function
            End If
         End If
         GetOutputDataSourceOptions = DataSource.GetOptions()
      End Function

      Overridable Function GetOutputNavigatorOptions() As String
         If me._pipe.Schema &lt;&gt; NULL
            If me._pipe.Schema.SupportedOutputNavigators.Count &gt; 0 Then
               GetOutputNavigatorOptions = me._pipe.Schema.SupportedOutputNavigators.AsOptions
               Exit Function
            End If
         End If
         GetOutputNavigatorOptions = Navigator.GetOptions()
      End Function

      Protected Overridable Sub _buildInputInfra()
         If me._inDataSourceName &lt;&gt; &quot;&quot; And me._inNavigatorName &lt;&gt; &quot;&quot; Then
            Try
               If me._pipe.InputSource &lt;&gt; NULL Then me._pipe.InputSource.Free()
               me._pipe.InputSource = TDataSource.Load(me._inDataSourceName, &quot;&quot;, False)
               If me._pipe.InputNavigator &lt;&gt; NULL Then me._pipe.InputNavigator.Free()
               me._pipe.InputNavigator = TNavigator.Load(me._inNavigatorName, me._pipe.InputSource)
               me._canExport = False
            Catch ex As Exception
               me._lastError = ex._GetMessage()
               Throw ex
            End Try
         End If
      End Sub

      Overridable Sub SetInputDataSource(pName As String)
         me._inDataSourceName = pName.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Trim()
         me._buildInputInfra()
      End Sub

      Overridable Sub SetInputNavigator(pName As String)
         me._inNavigatorName = pName.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Trim()
         me._buildInputInfra()
      End Sub

      Overridable Sub SetOutputDataSource(pName As String)
         me._outDataSourceName = pName.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Trim()
      End Sub

      Overridable Sub SetOutputNavigator(pName As String)
         me._outNavigatorName = pName.Replace(&quot;&quot;&quot;&quot;, &quot;&quot;).Trim()
      End Sub

      Overridable Function GetInputExtension() As String
         &apos; 1. Prioriza a seleção atual da UI gerando uma instância temporária
         If me._inDataSourceName &lt;&gt; &quot;&quot; Then
            Dim dummySource As TDataSource = TDataSource.Load(me._inDataSourceName, &quot;&quot;, False)
            GetInputExtension = dummySource.GetExtensionFilter()
            dummySource.Free()
            Exit Function
         End If

         &apos; 2. Fallback: Se não tem string, mas o objeto físico existe, usa ele
         If me._pipe.InputSource &lt;&gt; NULL Then
            GetInputExtension = me._pipe.InputSource.GetExtensionFilter()
            Exit Function
         End If

         &apos; 3. Fallback universal de segurança
         GetInputExtension = &quot;Todos os Arquivos (*.*)|*.*&quot;
      End Function

      Overridable Function GetOutputExtension() As String
         &apos; Se o objeto físico já existir, usa ele
         If me._pipe.OutputSource &lt;&gt; NULL Then
            GetOutputExtension = me._pipe.OutputSource.GetExtensionFilter()
            Exit Function
         End If

         &apos; Se não existir (cenário do botão SelectPath), cria uma instância temporária (dummy)
         &apos; apenas para extrair a propriedade de extensão e depois a descarta.
         If me._outDataSourceName &lt;&gt; &quot;&quot; Then
            Dim dummySource As TDataSource = TDataSource.Load(me._outDataSourceName, &quot;&quot;, False)
            GetOutputExtension = dummySource.GetExtensionFilter()
            dummySource.Free()
            Exit Function
         End If
         GetOutputExtension = &quot;Todos os Arquivos (*.*)|*.*&quot;
      End Function

      Overridable Function GetInputSchemaOptions() As String
         GetInputSchemaOptions = &quot;&quot;
      End Function

      Overridable Sub SetInputSchema(pSchema As String)
         me.SendLog(&quot;Definindo schema [&quot; &amp; pSchema &amp; &quot;] de entrada...&quot;)
      End Sub

      Overridable Function GetGrouperOutputOptions() As String
         GetGrouperOutputOptions = &quot;&quot;
      End Function

      Overridable Sub SetOutputGrouper(pGrouper As String)
         me.SendLog(&quot;Definindo agrupamento [&quot; &amp; pGrouper &amp; &quot;]...&quot;)
      End Sub

      Overridable Sub SetInputPath(pPath As String)
         me.SendLog(&quot;Definindo arquivo de origem: &quot; &amp; pPath)
         If me._pipe.InputSource.IsOpened
            me._pipe.InputSource.Close()
         End If
         me._pipe.InputSource.Path = pPath
         me._canExport = False
      End Sub

      Overridable Sub SetOutputPath(pPath As String)
         me.SendLog(&quot;Definindo destino da exportação: &quot; &amp; pPath)
         me._pipe.Exporter = New TExporter(pPath)
      End Sub

      Protected Overridable Sub _prepareOutputInfra(pPath As String)
         If me._outDataSourceName &lt;&gt; &quot;&quot; And me._outDataSourceName &lt;&gt; &quot;&quot; Then
            Try
               If me._pipe.OutputSource &lt;&gt; NULL Then me._pipe.OutputSource.Free()
               me._pipe.OutputSource = TDataSource.Load(me._outDataSourceName, pPath, True)
               If me._pipe.OutputNavigator &lt;&gt; NULL Then me._pipe.OutputNavigator.Free()
               me._pipe.OutputNavigator = TNavigator.Load(me._outNavigatorName, me._pipe.OutputSource)
            Catch ex As Exception
               me._lastError = ex._GetMessage()
               Throw ex
            End Try
         End If
      End Sub

      Overridable Sub ApplyGroupPaths(pBasePath As String, pPrefix As String, pExt As String)
         Dim groups As TGroupList = me.GetGroups()
         If groups = NULL Then Exit Sub
         Dim isFolder As Boolean = (groups.Count &gt; 1)
         Dim i As Integer
         For i = 0 To groups.Count - 1
            Dim grp As TGroup = groups.Take(i)
            Dim safeGroupID As String = me._sanitizeFileName(grp.GetID())
            If isFolder Then
               Dim folder As String = pBasePath
               If Right(folder, 1) &lt;&gt; &quot;\&quot; And Right(folder, 1) &lt;&gt; &quot;/&quot; Then folder = folder &amp; &quot;\&quot;
               grp.OutputPath = folder &amp; pPrefix &amp; safeGroupID &amp; &quot;.&quot; &amp; pExt
            Else
               grp.OutputPath = pBasePath
            End If
         Next
      End Sub

      Private Function _sanitizeFileName(pFileName As String) As String
         Dim invalidChars As String = &quot;\/:*?&quot;&quot;&lt;&gt;|&quot;
         Dim cleanName As String = pFileName
         Dim i As Integer
         For i = 1 To Len(invalidChars)
            Dim charToReplace As String = Mid(invalidChars, i, 1)
            cleanName = Replace(cleanName, charToReplace, &quot;_&quot;)
         Next
         _sanitizeFileName = cleanName
      End Function

      Function Validate() As Boolean
         me.SendLog(&quot;Validando integridade das definições...&quot;)
         If me._pipe.Schema = NULL Or me._pipe.InputSource = NULL Then
            me._lastError = &quot;Schema ou Arquivo de origem não definidos.&quot;
            Validate = False
            Exit Function
         End If
         Try
            me._pipe.Initialize()
            If Not me._pipe.RunMapping() Then
               me._lastError = me._pipe.Result.Logs.Text
               Validate = False
               Exit Function
            End If
            Validate = True
         Catch ex As Exception
            me._lastError = ex._GetMessage()
            Throw ex
         End Try
      End Function

      Function Read() As Boolean
         Read = False
         me.SendLog(&quot;Iniciando leitura e extração...&quot;)
         me._canExport = False

         me._lastProgressBucket = -1

         Try
             If Not me._pipe.RunExtraction() Then
                 me._lastError = me._pipe.Result.Logs.Text
                 Read = False
                 Exit Function
             End If

             &apos; EXTRAÇÃO FINALIZADA COM SUCESSO: Força o log de 100% caso tenha parado antes por linha vazia
             If me._lastProgressBucket &lt;&gt; 999 Then
                me._handleOnPhaseChange(&quot;Extração&quot;, &quot;Progresso: 100% concluído!&quot;)
                me._lastProgressBucket = 999
             End If

             me._canExport = True
             Read = True
             Exit Function
         Catch ex As Exception
             me._lastError = ex._GetMessage()
             Throw ex
         End Try
      End Function

      Function Group() As Boolean
         me.SendLog(&quot;Processando agrupamentos (Preview)...&quot;)
         Try
             Dim _resGroup As Boolean = me._pipe.RunGrouping()
             If Not _resGroup Then me._lastError = me._pipe.Result.Logs.Text
             Group = _resGroup
         Catch ex As Exception
             me._lastError = ex._GetMessage()
             Throw ex
         End Try
      End Function

      Function Export(pPath As String) As Boolean
         me.SendLog(&quot;Iniciando exportação física...&quot;)
         Try
             me._prepareOutputInfra(pPath)

             If Not me._pipe.RunExport() Then
                 me._lastError = me._pipe.Result.Logs.Text
                 me._pipe.Cleanup()
                 Export = False
                 Exit Function
             End If

             me._pipe.Cleanup()
             Export = True
         Catch ex As Exception
             me._pipe.Cleanup()
             me._lastError = ex._GetMessage()
             Throw ex
         End Try
      End Function

      Function GetLastError() As String
         GetLastError = me._lastError
      End Function

      Function CanRead() As Boolean
         CanRead = True
      End Function

      Function CanExport() As Boolean
         CanExport = me._canExport
      End Function

      Function GetRecords() As TRecordList
         GetRecords = me._pipe.Records
      End Function

      Function GetGroups() As TGroupList
         GetGroups = me._pipe.Groups
      End Function

      Sub SendLog(pMsg As String)
         If me.OnLog &lt;&gt; NULL Then me.OnLog(pMsg)
      End Sub

      Sub Free()
         If me._pipe &lt;&gt; NULL Then me._pipe.Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline_controller>
    <mod_pipeline_datasource>
      <Codigo>
Imports mod_enum
Imports System.IOUtils

&apos;@Module-Imported
Namespace mod_pipeline_datasource

   Class DataSource
      Inherits BaseEnum

      Private Shared _Initialized As Boolean

      Private Shared Sub Initialize()
         If _Initialized Then Exit Sub
         BaseEnum._AddEnumItem(&quot;DataSource&quot;, New DataSource(1, &quot;Excel&quot;))
         BaseEnum._AddEnumItem(&quot;DataSource&quot;, New DataSource(2, &quot;CSV&quot;))
         BaseEnum._AddEnumItem(&quot;DataSource&quot;, New DataSource(9, &quot;Grid&quot;))
         _Initialized = True
      End Sub

      Shared Function Excel As DataSource
         Excel = Load(&quot;Excel&quot;)
      End Function

      Shared Function CSV As DataSource
         CSV = Load(&quot;CSV&quot;)
      End Function

      Shared Function Grid As DataSource
         Grid = Load(&quot;Grid&quot;)
      End Function

      Shared Function Load(pValue As DataSource) As DataSource
         Load = Load(pValue.AsString)
      End Function

      Shared Function Load(pValue As Integer) As DataSource
         DataSource.Initialize()
         Load = DataSource(BaseEnum._GetCache(&quot;DataSource&quot;, pValue))
      End Function

      Shared Function Load(pValue As String) As DataSource
         DataSource.Initialize()
         Load = DataSource(BaseEnum._GetCache(&quot;DataSource&quot;, pValue))
      End Function

      Shared Function GetOptions() As String
         DataSource.Initialize()
         GetOptions = BaseEnum._GetEnumOptions(&quot;DataSource&quot;)
      End Function

   End Class

   Class TDataSource

      Protected _name As String
      Protected _path As String
      Protected _pathLoaded As Boolean = False
      Protected _isOpened As Boolean = False
      Protected _isWritable As Boolean = False
      Extension As String

      Sub New(pName As String = &quot;TDataSource&quot;, pPath As String = &quot;&quot;, pIsWritable As Boolean = False)
         MyBase.New()
         me._name = pName
         me._isWritable = pIsWritable
         me.Path = pPath
      End Sub

      Property Path As String
         Get
            Path = me._path
         End Get
         Set(pValue As String)
            If me._isOpened And me._pathLoaded Then
               Throw New Exception(&quot;TDataSource: Não é possível alterar o Path com a fonte aberta e carregada.&quot;)
            End If
            me._path = pValue
            me._afterSetPath(pValue)
         End Set
      End Property

      Property Name As String
         Get
            Name = me._name
         End Get
         Set(pValue As String)
            me._name = pValue
         End Set
      End Property

      Property IsOpened As Boolean
         Get
            IsOpened = me._isOpened
         End Get
      End Property

      Property IsWritable As Boolean
         Get
            IsWritable = me._isWritable
         End Get
      End Property

      Sub Open()
         me._beforeOpen()
         Try
            If me._path &lt;&gt; &quot;&quot; Then
               If IO.File.Exists(me._path) Then
                  me._loadFromFile(me._path)
                  me._pathLoaded = True
               ElseIf Not me._isWritable Then
                  Throw New Exception(&quot;TDataSource: Arquivo [&quot; &amp; me._path &amp; &quot;] não encontrado para leitura.&quot;)
               End If
            End If

            me._isOpened = True
            me._afterOpen()
         Catch ex As Exception
            me._isOpened = False
            Throw ex
         End Try
      End Sub

      Sub Close()
         me._beforeClose()
         Try
            If me._isWritable And me._path &lt;&gt; &quot;&quot; And me._isOpened Then
               Dim __Path As String = me._normalizePath(me._path)
               IO.File.Delete(__Path)
               me._saveToFile(__Path)
            End If
            me._isOpened = False
            me._pathLoaded = False
            me._afterClose()
         Catch ex As Exception
            me._isOpened = True
            Throw ex
         End Try
      End Sub

      Sub Clear()
         me._ensureIsOpened(&quot;Clear&quot;)
         me._ensureIsWritable(&quot;Clear&quot;)
         me._clear()
      End Sub

      Function GetValue(pX As Integer, pY As Integer) As Variant
         me._ensureIsOpened(&quot;GetValue&quot;)
         me._ensureBounds(pX, pY)
         GetValue = me._getValue(pX, pY)
      End Function

      Sub SetValue(pX As Integer, pY As Integer, pValue As Variant)
         me._ensureIsOpened(&quot;SetValue&quot;)
         me._ensureIsWritable(&quot;SetValue&quot;)
         me._ensureBounds(pX, pY)
         me._setValue(pX, pY, pValue)
      End Sub

      Property Rows As Integer
         Get
            Rows = me._gettRows()
         End Get
         Set(pValue As Integer)
            me._settRows(pValue)
         End Set
      End Property

      Property Columns As Integer
         Get
            Columns = me._gettColumns()
         End Get
         Set(pValue As Integer)
            me._settColumns(pValue)
         End Set
      End Property

      Sub EnsureSize(pSizeX As Integer, pSizeY As Integer)
         me._ensureIsOpened(&quot;EnsureSize&quot;)
         me._ensureIsWritable(&quot;EnsureSize&quot;)
         me._ensureSize(pSizeX, pSizeY)
      End Sub

      Function GetExtension As String
         GetExtension = me._getExtension()
      End Function

      Function GetExtensionFilter As String
         GetExtensionFilter = me._getExtensionFilter()
      End Function

      Private Function _gettRows() As Integer
         me._ensureIsOpened(&quot;Rows&quot;)
         _gettRows = me._getRows()
      End Function

      Private Sub _settRows(pValue As Integer)
         me._ensureIsOpened(&quot;Rows&quot;)
         me._ensureIsWritable(&quot;Rows&quot;)
         me._setRows(pValue)
      End Sub

      Private Function _gettColumns() As Integer
         me._ensureIsOpened(&quot;Columns&quot;)
         _gettColumns = me._getColumns()
      End Function

      Private Sub _settColumns(pValue As Integer)
         me._ensureIsOpened(&quot;Columns&quot;)
         me._ensureIsWritable(&quot;Columns&quot;)
         me._setColumns(pValue)
      End Sub

      Protected Overridable Sub _beforeOpen()
         Throw New Exception(&quot;TDataSource._beforeOpen: Você deve implementar a abertura física da fonte de dados.&quot;)
      End Sub

      Protected Overridable Sub _afterOpen()
      End Sub

      Protected Overridable Sub _beforeClose()
         Throw New Exception(&quot;TDataSource._beforeClose: Você deve implementar o fechamento físico da fonte de dados.&quot;)
      End Sub

      Protected Overridable Sub _afterClose()
      End Sub

      Protected Overridable Sub _clear()
         Throw New Exception(&quot;TDataSource._clear: Você deve implementar a limpeza física da fonte de dados.&quot;)
      End Sub

      Protected Overridable Function _getValue(pX As Integer, pY As Integer) As Variant
         Throw New Exception(&quot;TDataSource.GetValue: leitura não implementada.&quot;)
      End Function

      Protected Overridable Sub _setValue(pX As Integer, pY As Integer, pValue As Variant)
         Throw New Exception(&quot;TDataSource.SetValue: escrita não implementada.&quot;)
      End Sub

      Protected Overridable Function _getRows() As Integer
         Throw New Exception(&quot;TDataSource._getRows: contagem de linhas não implementada.&quot;)
      End Function

      Protected Overridable Sub _setRows(pValue As Integer)
         Throw New Exception(&quot;TDataSource._setRows: definição de linhas não implementada.&quot;)
      End Sub

      Protected Overridable Function _getColumns() As Integer
         Throw New Exception(&quot;TDataSource._getColumns: contagem de colunas não implementada.&quot;)
      End Function

      Protected Overridable Sub _setColumns(pValue As Integer)
         Throw New Exception(&quot;TDataSource._setColumns: definição de colunas não implementada.&quot;)
      End Sub

      Protected Sub _ensureBounds(pX As Integer, pY As Integer)
         If pX &lt; 0 Or pY &lt; 0 Then
            Throw New Exception(&quot;Index negativo.&quot;)
         End If
         If pX &gt;= me._getColumns() Then
            Throw New Exception(&quot;Coluna fora do limite.&quot;)
         End If
         If pY &gt;= me._getRows() Then
            Throw New Exception(&quot;Linha fora do limite.&quot;)
         End If
      End Sub

      Protected Overridable Sub _ensureSize(pSizeX As Integer, pSizeY As Integer)
         If pSizeX &gt;= me.Columns Then
            me.Columns = pSizeX
         End If
         If pSizeY &gt;= me.Rows Then
            me.Rows = pSizeY
         End If
      End Sub

      Protected Overridable Sub _ensureIsOpened(pLocal As String)
         If Not me._isOpened Then
            Throw New Exception(&quot;TDataSource.&quot; &amp; pLocal &amp; &quot;: A fonte de dados deve estar aberta para esta operação.&quot;)
         End If
      End Sub

      Protected Overridable Sub _ensureIsWritable(pLocal As String)
         If Not me._isWritable Then
            Throw New Exception(&quot;TDataSource.&quot; &amp; pLocal &amp; &quot;: A fonte de dados não é gravável.&quot;)
         End If
      End Sub

      Protected Overridable Function _getExtension As String
         _getExtension = me.Extension
      End Function

      Protected Overridable Function _getExtensionFilter As String
         _getExtensionFilter = &quot;Todos os Arquivos (*.*)|*.*&quot;
      End Function

      Protected Overridable Function _normalizePath(pPath As String) As String
         If pPath = &quot;&quot; Then
            _normalizePath =  &quot;&quot;
            Exit Function
         End If

         Dim _cleanPath As String = pPath.Replace(&quot;/&quot;, &quot;\&quot;)

         If Right(_cleanPath, 1) = &quot;\&quot; Then
            Throw New Exception(&quot;TDataSource: O caminho informado é uma pasta. Defina um nome de arquivo válido.&quot;)
         End If

         If IO.Directory.Exists(_cleanPath) Then
            Throw New Exception(&quot;TDataSource: O caminho [&quot; &amp; _cleanPath &amp; &quot;] aponta para um diretório existente, não para um arquivo.&quot;)
         End If

         Dim _requiredExt As String = me._getExtension()
         If _requiredExt &lt;&gt; &quot;&quot; Then
            Dim _currentExt As String = TPath.GetExtension(_cleanPath)
            If LCase(_currentExt) &lt;&gt; LCase(_requiredExt) Then
               _cleanPath = TPath.ChangeExtension(_cleanPath, _requiredExt)
            End If
         End If

         _normalizePath = _cleanPath
      End Function

      Protected Overridable Sub _afterSetPath(pPath As String)
      End Sub

      Protected Overridable Sub _loadFromFile(pPath As String)
         Throw New Exception(&quot;TDataSource._loadFromFile: Operação de leitura do arquivo não implementada.&quot;)
      End Sub

      Protected Overridable Sub _saveToFile(pPath As String)
         Throw New Exception(&quot;TDataSource._saveToFile: Operação de escrita do arquivo não implementada.&quot;)
      End Sub

      Shared Function Load(pName As String, pPath As String, pWritable As Boolean) As TDataSource
         Select DataSource.Load(pName)
            Case DataSource.Grid
               Load = New mod_pipeline_datasource_grid.GridDataSource(&quot;&quot;, pWritable)
            Case DataSource.Excel
               Load = New mod_pipeline_datasource_excel.ExcelGridDataSource(pPath, pWritable)
            Case DataSource.CSV
               Load = New mod_pipeline_datasource_csv.CSVGridDataSource(pPath, &quot;;&quot;, pWritable)
            Case Else
               Throw New Exception(&quot;DataSource não suportado: &quot; &amp; pName)
         End Select
      End Function

      Function ToString(pPrint As Boolean = False) As String
         Dim rowsInfo As String = &quot;N/A&quot;
         If me._isOpened Then
            rowsInfo = CStr(me.Rows)
         End If
         Dim colsInfo As String = &quot;N/A&quot;
         If me._isOpened Then
            colsInfo = CStr(me.Columns)
         End If
         With console.Block(&quot;TDataSource&quot;)
            .Prop(&quot;Name&quot;, me._name)
            .Prop(&quot;IsOpened&quot;, me._isOpened)
            .Prop(&quot;IsWritable&quot;, me._isWritable)
            .Prop(&quot;IsOpened&quot;, me._isOpened)
            .Prop(&quot;Rows&quot;, rowsInfo)
            .Prop(&quot;Cols&quot;, colsInfo)
            .Prop(&quot;Extension&quot;, me._getExtension())
            .Prop(&quot;ExtensionFilter&quot;, me._getExtensionFilter())
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Dispose()
         If me._isOpened Then
            me.Close()
         End If
         me._name = &quot;&quot;
      End Sub

      Sub Free()
         me.Dispose()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
