    <mod_shortcut>
      <Codigo>
Imports Collections
Imports mod_base_list

&apos;@Module-Imported
Namespace mod_shortcut

   Private Dim _map As StringList

   Class TShortcuts

      Private _ctrl As Boolean
      Private _shift As Boolean
      Private _alt As Boolean
      Private _win As Boolean
      Private _esc As Boolean
      Private _shortcuts As TShortcutList = New TShortcutList()

      OnKeyDown As TKeyEvent
      OnKeyUp As TKeyEvent
      OnAction As TNotifyEvent

      Sub New()
         MyBase.New()
      End Sub

      Property Ctrl As Boolean
         Get
            Ctrl = me._ctrl
         End Get
      End Property

      Property Shift As Boolean
         Get
            Shift = me._shift
         End Get
      End Property

      Property Alt As Boolean
         Get
            Alt = me._alt
         End Get
      End Property

      Property Win As Boolean
         Get
            Win = me._win
         End Get
      End Property

      Property ESC As Boolean
         Get
            ESC = me._esc
         End Get
      End Property

      Property Items As TShortcutList
         Get
            Items = me._shortcuts
         End Get
      End Property

      Sub Assign(pShortcut As TShortcut)
         If pShortcut &lt;&gt; NULL
            If pShortcut.AsNumber &gt; 0
               Dim scid As String = pShortcut.GetID()
               If me._shortcuts.Has(scid) Then me._shortcuts.Delete(scid)
               me._shortcuts.Add(pShortcut)
            End If
         End If
      End Sub

      Sub Assign(pShortcut As TShortcut, pAction As TNotifyEvent)
         pShortcut.Action = pAction
         me.Assign(pShortcut)
      End Sub

      Sub Unassign(pShortcut As TShortcut)
         If pShortcut &lt;&gt; NULL
            If pShortcut.AsNumber &gt; 0
               Dim scid As String = pShortcut.GetID()
               If me._shortcuts.Has(scid) Then me._shortcuts.Delete(scid)
            End If
         End If
      End Sub

      Sub HandleOnKeyDown(pSender As TObject, ByRef pWord As Word, pShift As Forms.TShiftState)
         Select pWord
            Case 17
               me._ctrl = True
            Case 16
               me._shift = True
            Case 18
               me._alt = True
            Case 27
               me._esc = True
            Case 91, 92
               me._win = True
         End Select

         Dim scid As Long = TShortcut.CalculateNumber(pWord, me._ctrl,  me._shift,  me._alt, me._win)
         Dim idx As Integer = me._shortcuts.IndexOf(CStr(scid))
         If idx &gt;= 0
            Dim sc As TShortCut = me._shortcuts.Take(idx)
            If sc.Action &lt;&gt; NULL Then
               sc.Action(sc)
               If me.OnAction &lt;&gt; NULL Then me.OnAction(sc)
            End If
         End If
         If me.OnKeyDown &lt;&gt; NULL Then me.OnKeyDown(pSender, pWord, pShift)
      End Sub

      Sub HandleOnKeyUp(pSender As TObject, ByRef pWord As Word, pShift As Forms.TShiftState)
         Select pWord
            Case 17
               me._ctrl = False
            Case 16
               me._shift = False
            Case 18
               me._alt = False
            Case 27
               me._esc = False
            Case 91, 92
               me._win = False
         End Select
         If me.OnKeyUp &lt;&gt; NULL Then me.OnKeyUp(pSender, pWord, pShift)
      End Sub

      Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TShortcuts&quot;)
            .Prop(&quot;Ctrl&quot;, me.Ctrl)
            .Prop(&quot;Shift&quot;, me.Shift)
            .Prop(&quot;Alt&quot;, me.Alt)
            .Prop(&quot;Win&quot;, me.Win)
            .Prop(&quot;ESC&quot;, me.ESC)
            .Prop(&quot;Shortcuts&quot;, me._shortcuts.ToString(False))
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

   End Class

   Class TShortcut
      Inherits BaseItem

      Private _key As Word
      Private _ctrl As Boolean
      Private _shift As Boolean
      Private _alt As Boolean
      Private _win As Boolean
      Private _string As String
      Private _number As Long

      Private _ctrlMask As Long = 16384
      Private _shiftMask As Long = 8192
      Private _altMask As Long = 32768
      Private _winMask As Long = 4096

      Action As TNotifyEvent

      Sub New(pKey As Word, pCtrl As Boolean, pShift As Boolean, pAlt As Boolean, pWin As Boolean)
         MyBase.New()
         me._key = pKey
         me._ctrl = pCtrl
         me._shift = pShift
         me._alt = pAlt
         me._win = pWin
         _ensureMapIsInitialized()
         me._rebuild()
      End Sub

      Sub New(pShortcut As String)
         MyBase.New()
         _ensureMapIsInitialized()
         me._setFromString(pShortcut)
      End Sub

      Sub New(pShortcut As Long)
         MyBase.New()
         _ensureMapIsInitialized()
         me._setFromNumber(pShortcut)
      End Sub

      Sub New(pShortcut As TShortcut)
         MyBase.New()
         me.Fill(pShortcut)
      End Sub

      Property Key As Word
         Get
            Key = me._key
         End Get
         Set(pValue As Word)
            me._key = pValue
            me._rebuild()
         End Set
      End Property

      Property Ctrl As Boolean
         Get
            Ctrl = me._ctrl
         End Get
         Set(pValue As Boolean)
            me._ctrl = pValue
            me._rebuild()
         End Set
      End Property

      Property Shift As Boolean
         Get
            Shift = me._shift
         End Get
         Set(pValue As Boolean)
            me._shift = pValue
            me._rebuild()
         End Set
      End Property

      Property Alt As Boolean
         Get
            Alt = me._alt
         End Get
         Set(pValue As Boolean)
            me._alt = pValue
            me._rebuild()
         End Set
      End Property

      Property Win As Boolean
         Get
            Win = me._win
         End Get
         Set(pValue As Boolean)
            me._win = pValue
            me._rebuild()
         End Set
      End Property

      Property AsString As String
         Get
            AsString = me._string
         End Get
         Set(pValue As String)
            _ensureMapIsInitialized()
            me._setFromString(pValue)
         End Set
      End Property

      Property AsNumber As Long
         Get
            AsNumber = me._number
         End Get
         Set(pValue As Long)
            _ensureMapIsInitialized()
            me._setFromNumber(pValue)
         End Set
      End Property

      Private Sub _rebuild()
         me._number = me._key
         If me._ctrl Then me._number += me._ctrlMask
         If me._shift Then me._number += me._shiftMask
         If me._alt Then me._number += me._altMask
         If me._win Then me._number += me._winMask
         With New StringList()
           If me._ctrl Then .Add(&quot;Ctrl&quot;)
           If me._shift Then .Add(&quot;Shift&quot;)
           If me._alt Then .Add(&quot;Alt&quot;)
           If me._win Then .Add(&quot;Win&quot;)
           Dim keyName As String = me._keyToString(me._key)
           If keyName &lt;&gt; &quot;&quot; Then .Add(keyName)
           me._string = .Text.Trim.Replace(.LineBreak, &quot;+&quot;)
           .Free()
         End With
      End Sub

      Shared Function CalculateNumber(pKey As Word, pCtrl As Boolean, pShift As Boolean, pAlt As Boolean, pWin As Boolean) As Long
         If pCtrl Then pKey += 16384
         If pShift Then pKey += 8192
         If pAlt Then pKey += 32768
         If pWin Then
            pKey += 4096
         End If
         CalculateNumber = pKey
      End Function

      Private Sub _setFromString(pShortcut As String)
         Dim _keystr As String
         With New StringList()
            .LineBreak = &quot;+&quot;
            .Text = UCase(pShortcut)
            me._ctrl = .IndexOf(&quot;CTRL&quot;) &gt;= 0
            me._shift = .IndexOf(&quot;SHIFT&quot;) &gt;= 0
            me._alt = .IndexOf(&quot;ALT&quot;) &gt;= 0
            me._win = .IndexOf(&quot;WIN&quot;) &gt;= 0
            If .Count &gt; 0 Then _keystr = Trim(.Strings(.Count - 1))
            me._key = me._stringToKey(_keystr)
            .Free()
         End With
         me._rebuild()
      End Sub

      Private Sub _setFromNumber(pNumber As Long)
         me._ctrl = (pNumber And me._ctrlMask) &lt;&gt; 0
         me._shift = (pNumber And me._shiftMask) &lt;&gt; 0
         me._alt = (pNumber And me._altMask) &lt;&gt; 0
         me._win = (pNumber And me._winMask) &lt;&gt; 0
         me._key = pNumber And Not (me._ctrlMask Or me._shiftMask Or me._altMask Or me._winMask)
         me._rebuild()
      End Sub

      Private Function _stringToKey(pString As String) As Word
         pString = UCase(pString)
         If _map.IndexOfName(pString) &gt;= 0
            _stringToKey = CInt(_map.Values(pString))
         ElseIf Len(pString) = 1
            _stringToKey = Asc(pString.LastChar)
         Else
            _stringToKey = 0
         End If
      End Function

      Private Function _keyToString(pKey As Word) As String
         Dim i As Integer, count As Integer = _map.Count - 1
         For i = 0 To count
            Dim _name As String = UCase(_map.Names(i))
            If CInt(_map.Values(_name)) = pKey Then
               _keyToString = _name
               Exit Function
            End If
         Next
         _keyToString = Chr(pKey)
      End Function

      Function Matches(pKey As Word, pCtrl As Boolean, pShift As Boolean, pAlt As Boolean, pWin As Boolean) As Boolean
         Matches = (me.Key = pKey And me.Ctrl = pCtrl And me.Shift = pShift And me.Alt = pAlt And me.Win = pWin)
      End Function

      Function Matches(pShortcut As TShortcut) As Boolean
         If pShortcut = NULL Then
            Matches = False
            Exit Function
         End If
         Matches = me.Matches(pShortcut.Key, pShortcut.Ctrl, pShortcut.Shift, pShortcut.Alt, pShortcut.Win)
      End Function

      Sub Fill(pValue As TShortcut)
         If pValue = NULL Then Exit Sub
         With pValue
            me.AsNumber = .AsNumber
            me.Action = .Action
         End With
      End Sub

      Shared Function Load(pShortcut As String) As TShortcut
         Load = New TShortcut(pShortcut)
      End Function

      Shared Function Load(pNumber As Long) As TShortcut
         Load = New TShortcut(pNumber)
      End Function

      Shared Function Load(pKey As Word, pCtrl As Boolean, pShift As Boolean, pAlt As Boolean, pWin As Boolean) As TShortcut
         Load = New TShortcut(pKey, pCtrl, pShift, pAlt, pWin)
      End Function

      Overrides Function Copy As TShortcut
         Copy = New TShortcut(me)
      End Function

      Overrides Function GetID As String
         GetID = CStr(me._number)
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TShortcut&quot;)
            .Prop(&quot;Key&quot;, me.Key)
            .Prop(&quot;Ctrl&quot;, me.Ctrl)
            .Prop(&quot;Shift&quot;, me.Shift)
            .Prop(&quot;Alt&quot;, me.Alt)
            .Prop(&quot;Win&quot;, me.Win)
            .Prop(&quot;AsString&quot;, me.AsString)
            .Prop(&quot;AsNumber&quot;, me.AsNumber)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.AsNumber = 0
      End Sub

      Sub Free()
         me.Dispose()
         MyBase.Free()
      End Sub

   End Class

   Class TShortcutList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TShortcutList&quot;, False)
      End Sub

      Property Item(pIndex As Integer) As TShortcut
         Get
            Item = CType(MyBase.Item(pIndex), TShortcut)
         End Get
         Set(pValue As TShortcut)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TShortcut
         Take = CType(MyBase.Take(pIndex), TShortcut)
      End Function

      Function Take(pID As String) As TShortcut
         Take = CType(MyBase.TakeFromId(pID), TShortcut)
      End Function

      Function First As TShortcut
         First = CType(MyBase.First, TShortcut)
      End Function

      Function First(pLimit As Integer) As TShortcutList
         First = CType(MyBase.Range(pLimit, False), TShortcutList)
      End Function

      Function Last As TShortcut
         Last = CType(MyBase.Last, TShortcut)
      End Function

      Function Last(pLimit As Integer) As TShortcutList
         Last = CType(MyBase.Range(pLimit, True), TShortcutList)
      End Function

      Function Copy As TShortcutList
         Copy = CType(MyBase.Copy(), TShortcutList)
      End Function

   End Class

   Private Sub _ensureMapIsInitialized()
      If _map &lt;&gt; NULL
         Exit Sub
      End If
      _map = New StringList()
      Dim i As Integer
      For i = 0 To 11
         _map.Add(&quot;F&quot; + CStr(i + 1) + &quot;=&quot; + CStr(112 + i))
      Next
      With _map
         .Add(&quot;CTRL=17&quot;)
         .Add(&quot;SHIFT=16&quot;)
         .Add(&quot;ALT=18&quot;)
         .Add(&quot;ESC=27&quot;)
         .Add(&quot;TAB=9&quot;)
         .Add(&quot;ENTER=13&quot;)
         .Add(&quot;RETURN=13&quot;)
         .Add(&quot;SPACE=32&quot;)
         .Add(&quot;DEL=46&quot;)
         .Add(&quot;DELETE=46&quot;)
         .Add(&quot;HOME=36&quot;)
         .Add(&quot;END=35&quot;)
         .Add(&quot;PGUP=33&quot;)
         .Add(&quot;PAGEUP=33&quot;)
         .Add(&quot;PGDN=34&quot;)
         .Add(&quot;PAGEDOWN=34&quot;)
         .Add(&quot;INS=45&quot;)
         .Add(&quot;INSERT=45&quot;)
         .Add(&quot;LEFT=37&quot;)
         .Add(&quot;UP=38&quot;)
         .Add(&quot;RIGHT=39&quot;)
         .Add(&quot;DOWN=40&quot;)
         .Add(&quot;WIN=91&quot;)
         .Add(&quot;WIN=92&quot;)
      End With
   End Sub

End Namespace</Codigo>
