&apos;@Module-Imported
Namespace mod_pipeline_navigator

   Class Navigator
      Inherits BaseEnum

      Private Shared _Initialized As Boolean

      Private Shared Sub Initialize()
         If _Initialized Then Exit Sub
         BaseEnum._AddEnumItem(&quot;Navigator&quot;, New Navigator(0, &quot;Horizontal&quot;))
         BaseEnum._AddEnumItem(&quot;Navigator&quot;, New Navigator(1, &quot;Vertical&quot;))
         _Initialized = True
      End Sub

      Shared Function Horizontal As Navigator
         Horizontal = Load(&quot;Horizontal&quot;)
      End Function

      Shared Function Vertical As Navigator
         Vertical = Load(&quot;Vertical&quot;)
      End Function

      Shared Function Load(pValue As Navigator) As Navigator
         Load = Load(pValue.AsString)
      End Function

      Shared Function Load(pValue As Integer) As Navigator
         Navigator.Initialize()
         Load = Navigator(BaseEnum._GetCache(&quot;Navigator&quot;, pValue))
      End Function

      Shared Function Load(pValue As String) As Navigator
         Navigator.Initialize()
         Load = Navigator(BaseEnum._GetCache(&quot;Navigator&quot;, pValue))
      End Function

      Shared Function GetOptions() As String
         Navigator.Initialize()
         GetOptions = BaseEnum._GetEnumOptions(&quot;Navigator&quot;)
      End Function

   End Class

   Class TNavigator
      Inherits BaseItem

      Protected _name As String
      Protected _data As TDataSource
      Protected _position As Integer = 0

      Property Name As String
         Get
            Name = me._name
         End Get
      End Property

      Property Data As TDataSource
         Get
            Data = me._data
         End Get
         Set(pValue As TDataSource)
            me._data = pValue
         End Set
      End Property

      Property Rows As Integer
         Get
            Rows = me._getRows()
         End Get
         Set(pValue As Integer)
            me._setRows(pValue)
         End Set
      End Property

      Property Columns As Integer
         Get
            Columns = me._getColumns()
         End Get
         Set(pValue As Integer)
            me._setColumns(pValue)
         End Set
      End Property

      Property Records As Integer
         Get
            Records = me._getRecords()
         End Get
      End Property

      Property Position As Integer
         Get
            Position = me._getPosition()
         End Get
         Set(pValue As Integer)
            me._setPosition(pValue)
         End Set
      End Property

      Private Sub New(pName As String, pDataSource As TDataSource)
         MyBase.New()
         me._name = pName
         me._data = pDataSource
      End Sub

      Overridable Function GetHeader(pWindow As TWindow) As TRecord
         Throw New Exception(&quot;TNavigator.GetHeader não implementado na classe base.&quot;)
      End Function

      Overridable Function GetValueFrom(pX As Integer, pY As Integer) As Variant
         GetValueFrom = me._data.GetValue(pX, pY)
      End Function

      Overridable Function GetValue(pIndex As Integer) As Variant
         Throw New Exception(&quot;TNavigator.GetValue não implementado na classe base.&quot;)
      End Function

      Overridable Sub SetValueFrom(pX As Integer, pY As Integer, pValue As Variant)
         me.EnsureSize(pX + 1, pY + 1)
         me._data.SetValue(pX, pY, pValue)
      End Sub

      Overridable Sub SetValue(pIndex As Integer, pValue As Variant)
         Throw New Exception(&quot;TNavigator.SetValue não implementado na classe base.&quot;)
      End Sub

      Overridable Sub EnsureSize(pSizeX As Integer, pSizeY As Integer)
         me._data.EnsureSize(pSizeX, pSizeY)
      End Sub

      Overridable Function EOF() As Boolean
         EOF = me._position &gt;= me._getRecords()
      End Function

      Overridable Sub Nextt()
         me._position = me._position + 1
      End Sub

      Overridable Sub Previous()
         If me._position &gt; 0 Then
            me._position = me._position - 1
         End If
      End Sub

      Overridable Sub Reset()
         me._position = 0
      End Sub

      Overridable Function _getRows() As Integer
         _getRows = me._data.Rows
      End Function

      Overridable Sub _setRows(pValue As Integer)
         me._data.Rows = pValue
      End Sub

      Overridable Function _getColumns() As Integer
         _getColumns = me._data.Columns
      End Function

      Overridable Sub _setColumns(pValue As Integer)
         me._data.Columns = pValue
      End Sub

      Overridable Function _getRecords() As Integer
         Throw New Exception(&quot;TNavigator._getRecords não implementado.&quot;)
      End Function

      Protected Overridable Function _getPosition() As Integer
         _getPosition = me._position
      End Function

      Protected Overridable Sub _setPosition(pValue As Integer)
         If pValue &lt; 0 Then
            me._position = 0
         ElseIf pValue &gt; me.Records Then
            me._position = me.Records - 1
         Else
            me._position = pValue
         End If
      End Sub

      Overridable Overrides Function Copy() As TNavigator
         Throw New Exception(&quot;TNavigator.Copy: Você deve implementar a cópia do navegador na classe filha.&quot;)
      End Function

      Overridable Overrides Function GetID() As String
         GetID = me._name
      End Function

      Shared Function Load(pName As String, pData As TDataSource) As TNavigator
         Select Navigator.Load(pName)
            Case Navigator.Horizontal
               Load = New mod_pipeline_navigator_horizontal.TNavigatorHorizontal(pData)
            Case Navigator.Vertical
               Load = New mod_pipeline_navigator_vertical.TNavigatorVertical(pData)
            Case Else
               Throw New Exception(&quot;Navigator não suportado: &quot; &amp; pName)
         End Select
      End Function

      Overridable Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TNavigator&quot;)
            .Prop(&quot;Name&quot;, me._name)
            .Prop(&quot;Position&quot;, me._position)
            .Prop(&quot;Data&quot;, CStr(me._data &lt;&gt; NULL))
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overridable Overrides Sub Dispose()
         &apos;me._data = NULL
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
