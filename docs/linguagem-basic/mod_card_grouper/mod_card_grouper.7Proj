    <mod_event_emitter>
      <Codigo>Imports Collections
Imports mod_base_list

&apos;@Module-Imported
Namespace mod_event_emitter

   Delegate Sub DelegateCallback(pEvent As String)
   Delegate Sub DelegateCallbackVar(pEvent As String, pData As Variant)
   Delegate Sub DelegateCallbackObj(pEvent As String, pData As TObject)

   Class EventEmitter

      Events As EventCallbackList
      AvailableEvents As StringList
      CheckEvents As Boolean = False
      MaxListeners As Integer = -1

      Sub New()
         MyBase.New()
         me.events = New EventCallbackList()
         me.AvailableEvents = New StringList()
      End Sub

      Function Listen(pCallback As EventCallback) As EventCallback
         me.CheckEventIsValid(pCallback.EventName)
         me.CheckMaxListeners()
         me.events.Add(pCallback)
         Listen = me.events.Last
      End Function

      Function Listen(pEvent As String, pCallback As DelegateCallback) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         Listen = me.events.Last
      End Function

      Function ListenVar(pEvent As String, pCallback As DelegateCallbackVar) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         ListenVar = me.events.Last
      End Function

      Function ListenObj(pEvent As String, pCallback As DelegateCallbackObj) As EventCallback
         me.CheckEventIsValid(pEvent)
         me.CheckMaxListeners()
         me.events.Add(New EventCallback(pEvent, pCallback))
         ListenObj = me.events.Last
      End Function

      Sub Emit(pEvent As String)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer, count As Integer = _events.Count - 1
         For i = 0 To count
            If _events.Take(i).Callback &lt;&gt; NULL
               _events.Take(i).Callback(pEvent)
            End If
         Next
      End Sub

      Sub Emit(pEvent As String, pData As TObject)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer, count As Integer = _events.Count - 1
         For i = 0 To count
            If _events.Take(i).CallbackObj &lt;&gt; NULL
               _events.Take(i).CallbackObj(pEvent, pData)
            End If
         Next
      End Sub

      Sub Emit(pEvent As String, pData As Variant)
         me.CheckEventIsValid(pEvent)
         Dim _events As EventCallbackList = me.events.Filter(me.FilterEventsByName, pEvent)
         Dim i As Integer, count As Integer = _events.Count - 1
         For i = 0 To count
            If _events.Take(i).CallbackVar &lt;&gt; NULL
               _events.Take(i).CallbackVar(pEvent, pData)
            End If
         Next
      End Sub

      Sub EmitObj(pEvent As String, pData As TObject)
         me.Emit(pEvent, pData)
      End Sub

      Sub Emit(pEvent As String, pDataObj As TObject, pDataVar As Variant)
         me.Emit(pEvent)
         me.Emit(pEvent, pDataVar)
         me.EmitObj(pEvent, pDataObj)
      End Sub

      Sub Off(pIdCallback As String)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i).GetID &lt;&gt; pIdCallback
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pCallback As EventCallback)
         me.CheckEventIsValid(pCallback.EventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i) &lt;&gt; pCallback
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pEventName As String, pCallback As DelegateCallback)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).Callback &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub Off(pEventName As String, pCallback As DelegateCallbackVar)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).CallbackVar &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub OffObj(pEventName As String, pCallback As DelegateCallbackObj)
         me.CheckEventIsValid(pEventName)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer  = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i).EventName &lt;&gt; pEventName OR (me.events.Take(i).EventName = pEventName AND me.events.Take(i).CallbackObj &lt;&gt; pCallback)
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub RemoveListeners(pEventName As String)
         Dim new_events As EventCallbackList = New EventCallbackList()
         Dim i As Integer, count As Integer = me.events.Count - 1
         For i = 0 To count
            If me.events.Take(i).EventName &lt;&gt; pEventName
               new_events.Add(me.events.Take(i))
            End If
         Next
         me.events = new_events
      End Sub

      Sub RemoveListeners()
         me.events.Clean()
      End Sub

      Function Listeners(pEventName As String = &quot;&quot;) As EventCallbackList
         If pEventName &lt;&gt; &quot;&quot;
            Listeners = me.events.Filter(me.FilterEventsByName, pEventName)
         Else
            Listeners = me.events
         End If
      End Function

      Private Sub CheckEventIsValid(pEvent As String)
         If me.CheckEvents
            pEvent = LCase(pEvent)
            me.AvailableEvents.Text = LCase(me.AvailableEvents.Text)
            If me.AvailableEvents.IndexOf(pEvent) = -1
               Throw new Exception(&quot;The event [&quot; + pEvent + &quot;] is not aceppted.&quot; + CHAR(13) + &quot;Available events:&quot; + CHAR(13) + me.AvailableEvents.Text)
            End If
         End If
      End Sub

      Private Sub CheckMaxListeners()
          If me.MaxListeners &gt; -1 AND me.Events.Count = me.MaxListeners
              Throw New Exception(&quot;Número máximo de listeners atingido (&quot; + CStr(me.MaxListeners) + &quot;). Não é possível adicionar mais listeners.&quot;)
          End If
      End Sub

      Private Function FilterEventsByName(pValue As BaseItem, i As Integer, extra As Variant) As Boolean
         Dim _extra As String = CStr(extra)
         FilterEventsByName = UCase(EventCallback(pValue).EventName) = UCase(_extra)
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Class EventCallback
      Inherits BaseItem

      ReadOnly EventName As String
      ReadOnly CallbackVar As DelegateCallbackVar
      ReadOnly CallbackObj As DelegateCallbackObj
      ReadOnly Callback As DelegateCallback


      Sub New(pEventName As String, pCallbackWithoutData As DelegateCallback)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = NULL
         me.CallbackObj = NULL
         me.Callback = pCallbackWithoutData
      End Sub

      Sub New(pEventName As String, pCallbackObj As DelegateCallbackObj)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = NULL
         me.CallbackObj = pCallbackObj
         me.Callback = NULL
      End Sub

      Sub New(pEventName As String, pCallback As DelegateCallbackVar)
         MyBase.New()
         me.EventName = pEventName
         me.CallbackVar = pCallback
         me.CallbackObj = NULL
         me.Callback = NULL
      End Sub

      Sub New(pValue As EventCallback)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As EventCallback)
         If pValue = NULL
            Exit Sub
         End If
         With pValue
            me.EventName = .EventName
            me.CallbackVar = .CallbackVar
            me.CallbackObj = .CallbackObj
            me.Callback = .Callback
         End With
      End Sub

      Overrides Function Copy() As EventCallback
         Copy = New EventCallback(me)
      End Function

      Overrides Function GetID As String
         GetID = CStr(me.GetHashCode)
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;EventCallback&quot;)
            .Prop(&quot;EventName&quot;, me.EventName)
            .Prop(&quot;Has CallbackVar&quot;, me.CallbackVar &lt;&gt; NULL)
            .Prop(&quot;Has CallbackObj&quot;, me.CallbackObj &lt;&gt; NULL)
            .Prop(&quot;Has Callback&quot;, me.Callback &lt;&gt; NULL)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.CallbackVar = NULL
         me.CallbackObj = NULL
         me.Callback = NULL
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function FindDelegate(pValue As EventCallback, i As Integer, extra As Variant) As Boolean
   Delegate Function MapDelegate(pValue As EventCallback, i As Integer, extra As Variant) As EventCallback
   Delegate Sub ForEachDelegate(pValue As EventCallback, i As Integer, extra As Variant)

   Class EventCallbackList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;EventCallbackList&quot;, False)
      End Sub

      Property Item(pIndex As Integer) As EventCallback
         Get
            Item = CType(MyBase.Item(pIndex), EventCallback)
         End Get
         Set(pValue As EventCallback)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As EventCallback
         Take = CType(MyBase.Take(pIndex), EventCallback)
      End Function

      Function Take(pID As String) As EventCallback
         Take = CType(MyBase.TakeFromId(pID), EventCallback)
      End Function

      Function First As EventCallback
         First = CType(MyBase.First, EventCallback)
      End Function

      Function First(pLimit As Integer) As EventCallbackList
         First = CType(MyBase.Range(pLimit, False), EventCallbackList)
      End Function

      Function Last As EventCallback
         Last = CType(MyBase.Last, EventCallback)
      End Function

      Function Last(pLimit As Integer) As EventCallbackList
         Last = CType(MyBase.Range(pLimit, True), EventCallbackList)
      End Function

      Function Copy As EventCallbackList
         Copy = CType(MyBase.Copy(), EventCallbackList)
      End Function

      Function Filter(pHandler As FindDel, extra As Variant) As EventCallbackList
         Filter = EventCallbackList(MyBase.Filter(pHandler, extra))
      End Function

   End Class

End Namespace</Codigo>
