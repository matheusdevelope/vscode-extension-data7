Dim _form As New TFormCard(&quot;Processar retorno de cartões 3&quot;)

_form.Show()

_form.Free()


Dim status As String
If 1 &gt; 0 Then
   status = &quot;positivo&quot;
Else
   status = &quot;negativo&quot;
End If
Print status



Dim list As StringList
For __idx0 = 0 To list.Count - 1
   Dim item As String = list.Strings(__idx0)
   &apos; iterate strings
Next

For __idx1 = 0 To list.Count - 1
   Dim item As String = list.Strings(__idx1)
   &apos; &quot;item&quot; é inferido como String porque Strings(i) retorna String
Next

Dim outer As StringList
Dim inner As StringList
For __idx2 = 0 To outer.Count - 1
   Dim name As String = outer.Strings(__idx2)
   For __idx3 = 0 To inner.Count - 1
      Dim tag As String = inner.Strings(__idx3)
      &apos; acessa name e tag
   Next
Next</Codigo>
