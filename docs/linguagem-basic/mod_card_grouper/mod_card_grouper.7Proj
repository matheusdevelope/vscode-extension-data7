    <mod_pipeline_datasource_grid>
      <Codigo>Imports Forms
Imports mod_pipeline_datasource

&apos;@Module-Imported
Namespace mod_pipeline_datasource_grid

   Class GridDataSource
      Inherits TDataSource

      Protected _grid As Grid

      Property Data As Grid
         Get
            Data = me._grid
         End Get
         Set(pValue As Grid)
            If me._isOpened Then
               Throw New Exception(&quot;GridDataSource: Não é possível alterar o Data enquanto a fonte estiver aberta.&quot;)
            End If
            me._grid = pValue
         End Set
      End Property

      Sub New(pWritable As Boolean = False, pName As String = &quot;Forms.Grid&quot;)
         MyBase.New(pName, &quot;&quot;, pWritable)
         me._grid = New Forms.Grid(NULL)
      End Sub

      Sub New(pGrid As Grid, pWritable As Boolean = True, pName As String = &quot;Forms.Grid&quot;)
         MyBase.New(pName, &quot;&quot;,  pWritable)
         me._grid = pGrid
      End Sub

      Sub New(pPath As String, pWritable As Boolean = False, pName As String = &quot;Forms.Grid&quot;)
         MyBase.New(pName, pPath, pWritable)
         me._grid = New Forms.Grid(NULL)
      End Sub

      Protected Overridable Overrides Sub _beforeOpen()
         me._grid.BeginUpdate()
      End Sub

      Protected Overridable Overrides Sub _beforeClose()
         me._grid.EndUpdate()
      End Sub

      Protected Overridable Overrides Sub _afterClose()
      End Sub

      Protected Overridable Overrides Sub _clear()
         me._ensureIsWritable(&quot;_clear&quot;)
         me._grid.Clear()
      End Sub

      Protected Overridable Overrides Function _getValue(pX As Integer, pY As Integer) As Variant
         _getValue = me._grid.Cells(pX, pY)
      End Function

      Protected Overridable Overrides Sub _setValue(pX As Integer, pY As Integer, pValue As Variant)
         me._grid.Cells(pX, pY) = pValue
      End Sub

      Protected Overridable Overrides Function _getRows() As Integer
         _getRows = me._grid.RowCount
      End Function

      Protected Overridable Overrides Sub _setRows(pValue As Integer)
         me._grid.RowCount = pValue
      End Sub

      Protected Overridable Overrides Function _getColumns() As Integer
         _getColumns = me._grid.ColCount
      End Function

      Protected Overridable Overrides Sub _setColumns(pValue As Integer)
         me._grid.ColCount = pValue
      End Sub

      Sub Free()
         If me._grid &lt;&gt; NULL Then
            me._grid.Free()
            me._grid = NULL
         End If
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
