    <mod_pipeline_extractor>
      <Codigo>Imports mod_pipeline_schema
Imports mod_pipeline_navigator
Imports mod_pipeline_record
Imports mod_pipeline_cell
Imports mod_pipeline_field
Imports mod_pipeline_value

&apos;@Module-Imported
Namespace mod_pipeline_extractor

   Delegate Sub OnProgressDelegate(pCurrent As Integer, pTotal As Integer)

   Class TExtractor

      Protected _name As String

      StopOnEmptyRow As Boolean = True
      MaxRecords As Integer = -1
      OnProgress As OnProgressDelegate

      Sub New(pName As String = &quot;TExtractor&quot;)
         MyBase.New()
         me._name = pName
      End Sub

      Function Execute(pSchema As TSchema, pNavigator As TNavigator) As TRecordList
         Dim _dataSet As New TRecordList()
         Dim _recordCount As Integer = 0
         Dim _maxRecordsFinal As Integer = pNavigator.Records
         If me.MaxRecords &gt; 0 Then
            _maxRecordsFinal = me.MaxRecords
         End If
         While Not pNavigator.EOF()
            Dim _record As New TRecord(pNavigator.Position)
            Dim _isEmptyRow As Boolean = True
            Dim i As Integer
            Dim count As Integer = pSchema.Fields.Count - 1
            For i = 0 To count
               Dim _field As TField = pSchema.Fields.Take(i)
               If _field.Found
                  If _field.Index &gt;= 0
                     Dim _rawVal As Variant = pNavigator.GetValue(_field.Index)
                     If _isEmptyRow And Trim(CStr(_rawVal)) &lt;&gt; &quot;&quot; Then
                        _isEmptyRow = False
                     End If
                     _record.Cells.Add(New TCell(_field.Index, _field.Name, _field.OptionFound.Value, New TTValue(_rawVal)))
                  Else
                     _record.Cells.Add(New TCell(_field.Index, _field.Name, _field.OptionFound.Value, New TTValue(NULL)))
                  End If
               End If
            Next
            If me.StopOnEmptyRow And _isEmptyRow Then
               _record.Free()
               Exit While
            End If
            _dataSet.Add(_record)
            _recordCount = _recordCount + 1
            If me.MaxRecords &gt;-1 And _recordCount &gt;= me.MaxRecords Then
               Exit While
            End If
            If me.OnProgress &lt;&gt; NULL Then me.OnProgress(_recordCount, _maxRecordsFinal)
            pNavigator.Nextt()
         End While
         Execute = _dataSet
      End Function

   End Class

End Namespace</Codigo>
      <Aberto>false</Aberto>
      <OrdemAbertura>0</OrdemAbertura>
      <PastaID>{975F1BBE-964B-457F-AF70-A7BBD8FC0361}</PastaID>
    </mod_pipeline_extractor>
    <mod_pipeline_field>
      <Codigo>
Imports mod_base_list
Imports mod_pipeline_option

&apos;@Module-Imported
Namespace mod_pipeline_field

   Class TField
      Inherits BaseItem

      Private _name As String
      Private _options As TOptionList = New TOptionList()
      Private _indexOptionFound As Integer = -1
      Required As Boolean
      Export As Boolean = True
      Index As Integer = -1

      Property Name As String
         Get
            Name = me._name
         End Get
      End Property

      Property Options As TOptionList
         Get
            Options = me._options
         End Get
         Set(pValue As TOptionList)
            If me._options &lt;&gt; NULL Then me._options.Free()
            me._options = pValue
         End Set
      End Property

      Property IndexOptionFound As Integer
         Get
            IndexOptionFound = me._indexOptionFound
         End Get
         Set(pValue As Integer)
            If pValue &gt;= me._options.Count Then
               me._indexOptionFound = -1
            Else
               me._indexOptionFound = pValue
            End If
            me._options.Take(me._indexOptionFound).Found = True
         End Set
      End Property

      Property OptionFound As TOption
         Get
            If me.IndexOptionFound &gt;= 0 Then
               OptionFound = me._options.Take(me.IndexOptionFound)
            End If
         End Get
      End Property

      Property Found As Boolean
         Get
            Found = me.Index &gt;= 0
         End Get
      End Property

      Sub New(pName As String, pRequired As Boolean = False)
         MyBase.New()
         me._name = pName
         me._options.Add(pName)
         me.Required = pRequired
      End Sub

      Sub New(pValue As TField)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Fill(pValue As TField)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me._name = .Name
            me._options = .Options.Copy()
            me.Required = .Required
            me.Export = .Export
            me.Index = .Index
         End With
      End Sub

      Overrides Function Copy() As TField
         Copy = New TField(me)
      End Function

      Overrides Function GetID As String
         GetID = me.Name
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TField&quot;)
            .Prop(&quot;Name&quot;, me.Name)
            .Prop(&quot;Found&quot;, me.Found)
            .Prop(&quot;Required&quot;, me.Required)
            .Prop(&quot;Export&quot;, me.Export)
            .Prop(&quot;Options&quot;, me._options.ToString())
            .Prop(&quot;IndexOptionFound&quot;, me.IndexOptionFound)
            .Prop(&quot;Index&quot;, me.Index)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         me.Required = False
         If me._options &lt;&gt; NULL Then me._options.Free()
         me.Index = -1
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TFieldFindDelegate(pValue As TField, i As Integer, extra As Variant) As Boolean
   Delegate Function TFieldMapDelegate(pValue As TField, i As Integer, extra As Variant) As TField
   Delegate Sub TFieldForEachDelegate(pValue As TField, i As Integer, extra As Variant)

   Class TFieldList
      Inherits BaseList

      Sub New()
         MyBase.New(&quot;TFieldList&quot;, False)
      End Sub

      Sub Add(pName As String, pRequired As Boolean = True)
         me.Add(New TField(pName, pRequired))
      End Sub

      Property Item(pIndex As Integer) As TField
         Get
            Item = CType(MyBase.Take(pIndex), TField)
         End Get
         Set(pValue As TField)
            me.SetItem(pIndex, pValue)
         End Set
      End Property

      Function Take(pIndex As Integer) As TField
         Take = CType(MyBase.Take(pIndex), TField)
      End Function

      Function Take(pID As String) As TField
         Take = CType(MyBase.TakeFromId(pID), TField)
      End Function

      Function First As TField
         First = CType(MyBase.First, TField)
      End Function

      Function First(pLimit As Integer) As TFieldList
         First = CType(MyBase.Range(pLimit, False), TFieldList)
      End Function

      Function Last As TField
         Last = CType(MyBase.Last, TField)
      End Function

      Function Last(pLimit As Integer) As TFieldList
         Last = CType(MyBase.Range(pLimit, True), TFieldList)
      End Function

      Function Copy As TFieldList
         Return CType(MyBase.Copy(), TFieldList)
      End Function

      Function IndexOf(handler As TFieldFindDelegate) As Integer
         IndexOf = me.IndexOf(handler, &quot;&quot;)
      End Function

      Function IndexOf(handler As TFieldFindDelegate, extra As Variant) As Integer
         IndexOf = MyBase.IndexOf(handler, extra)
      End Function

      Function Find(handler As TFieldFindDelegate) As TField
         Find = me.Find(handler, &quot;&quot;)
      End Function

      Function Find(handler As TFieldFindDelegate, extra As Variant) As TField
         Find = CType(MyBase.Find(handler, extra), TField)
      End Function

      Function Filter(handler As TFieldFindDelegate) As TFieldList
         Return me.Filter(handler, &quot;&quot;)
      End Function

      Function Filter(handler As TFieldFindDelegate, extra As Variant) As TFieldList
         Filter = CType(MyBase.Filter(handler, extra), TFieldList)
      End Function

      Sub ForEach(handler As TFieldFindDelegate)
         me.ForEach(handler, &quot;&quot;)
      End Sub

      Sub ForEach(handler As TFieldForEachDelegate, extra As Variant)
         MyBase.ForEach(handler, extra)
      End Sub

      Function Map(handler As TFieldFindDelegate) As TFieldList
         Map = me.Map(handler, &quot;&quot;)
      End Function

      Function Map(handler As TFieldMapDelegate, extra As Variant) As TFieldList
         With CType(MyBase.Map(handler, extra), TFieldList)
            Map = .Copy()
         End With
      End Function

   End Class

End Namespace</Codigo>
