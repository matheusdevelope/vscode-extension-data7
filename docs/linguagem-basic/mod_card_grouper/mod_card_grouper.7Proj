&apos;@Module-Imported
Namespace mod_pipeline_group_definition

   Class TGroupDefinition
      Inherits BaseItem

      Protected _separator As String = Chr(30)

      Property Separator As String
         Get
            Separator = me._separator
         End Get
      End Property

      Protected _fields As TFieldList = New TFieldList()

      Property Fields As TFieldList
         Get
            Fields = me._fields
         End Get
         Set(pValue As TFieldList)
            If me._fields &lt;&gt; NULL Then me._fields.Free()
            me._fields = pValue.Copy()
         End Set
      End Property

      Sub New()
         MyBase.New()
      End Sub

      Sub New(pSeparator As String)
         MyBase.New()
         If pSeparator &lt;&gt; &quot;&quot;
            me._separator = pSeparator
         End If
      End Sub

      Sub New(pValue As TGroupDefinition)
         MyBase.New()
         me.Fill(pValue)
      End Sub

      Sub Add(pField As TField)
         me.AddField(pField.Copy())
      End Sub

      Protected Overridable Sub AddField(pField As TField)
         me._fields.Add(pField)
      End Sub

      Function GetKey(pRecord As TRecord) As String
         If me._fields.Count &lt;= 0 Then
            Throw New Exception(&quot;You must add at least one field as key to perform the selection&quot;)
         End If
         GetKey = me.BuildKey(pRecord)
      End Function

      Protected Overridable Function BuildKey(pRecord As TRecord) As String
         Dim key As String = &quot;&quot;
         Dim i As Integer
         Dim count As Integer = me._fields.Count - 1
         For i = 0 To count
            If i &gt; 0 Then key = key &amp; me._separator
            Dim name As String = me._fields.Take(i).Name
            key = key &amp; pRecord.Cells.Take(name).Value.AsString
         Next
         BuildKey = key
      End Function

      Sub Fill(pValue As TGroupDefinition)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Fields = .Fields
         End With
      End Sub

      Function Copy() As TGroupDefinition
         Copy = New TGroupDefinition(me)
      End Function

      Overridable Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TGroupDefinition&quot;)
            .Prop(&quot;Fields&quot;, me.Fields.ToString())
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         If me._fields &lt;&gt; NULL Then me._fields.Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
