&apos;@Module-Imported
Namespace mod_pipeline_group

   Class TGroup
      Inherits BaseItem

      Key As TGroupKey
      Items As TRecordList = New TRecordList()

      OutputPath As String
      Selected As Boolean = True

      Sub New(pKey As TGroupKey)
         MyBase.New()
         me.Key = pKey
         me.Items.OwnsObjects = False
      End Sub

      Sub New(pValue As TGroup)
         MyBase.New()
         me.Fill(pValue)
         me.Items.OwnsObjects = False
      End Sub

      Sub Fill(pValue As TGroup)
         IF pValue = NULL
            Exit Sub
         End If
         With pValue
            me.Key = .Key.Copy()
            me.Items = .Items.Copy()
            me.Items.OwnsObjects = False
            me.OutputPath = .OutputPath
            me.Selected = .Selected
         End With
      End Sub

      Overrides Function Copy() As TGroup
         Copy = New TGroup(me)
      End Function

      Overrides Function GetID As String
         GetID = me.Key.Key
      End Function

      Overrides Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TGroup&quot;)
            .Prop(&quot;Key&quot;, me.Key.ToString())
            .Prop(&quot;OutputPath&quot;, me.OutputPath)
            .Prop(&quot;Selected&quot;, me.Selected)
            .Prop(&quot;Items&quot;, me.Items.ToString())
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Overrides Sub Dispose()
         If me.Key &lt;&gt; NULL Then me.Key.Free()
         If me.Items &lt;&gt; NULL Then me.Items.Free(False)
      End Sub

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

   Delegate Function TGroupFindDelegate(pValue As TGroup, i As Integer, extra As Variant) As Boolean
   Delegate Function TGroupMapDelegate(pValue As TGroup, i As Integer, extra As Variant) As TGroup
   Delegate Sub TGroupForEachDelegate(pValue As TGroup, i As Integer, extra As Variant)

