      Function Range(pLimit As Integer, fromEnd As Boolean) As BaseList
         Dim result As BaseList = me.CreateInstance()
         Dim _count As Integer = me.Count
         If pLimit &lt;= 0 Or _count = 0
            Range = result
         End If
         Dim i As Integer, startIndex As Integer = 0, idx As Integer
         If fromEnd
            startIndex = _count - pLimit
         End If
         If startIndex &lt; 0
            startIndex = 0
         End If
         For i = 0 To pLimit - 1
            If fromEnd
               idx = startIndex + i
            Else
               idx = i
            End If
            If idx &gt;= 0 And idx &lt; _count
               result.Add(me.Take(idx))
            End If
         Next
         Range = result
