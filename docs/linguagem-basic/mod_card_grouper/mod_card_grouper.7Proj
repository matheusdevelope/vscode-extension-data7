    <mod_pipeline_form>
      <Codigo>Imports mod_form
Imports mod_topbar
Imports mod_control
Imports mod_base_editor
Imports mod_pipeline_actions
Imports mod_pipeline_resources
Imports mod_pipeline_controller
Imports Vcl.ExtCtrls

&apos;@Module-Imported
Namespace mod_pipeline_form

   Class TPipelineForm
      Inherits TFormLayout

      TopBtnRead As TButton
      TopBtnExport As TButton

      InDataSourceType As TComboEditor
      InNavigatorType As TComboEditor
      InSchemaSource As TComboEditor
      InPathSource As TButtonTextEditor
      BtnRead As Forms.FlatButton

      LogMemo As Forms.MemoTextBox
      GridRecords As Forms.Grid
      GridGroups As Forms.Grid

      OutDataSourceType As TComboEditor
      OutNavigatorType As TComboEditor
      InGrouperOutput As TComboEditor
      InPathOutput As TButtonTextEditor
      BtnExport As Forms.FlatButton

      Private resources As TPipelineResources

      Private _margins As Integer = 4
      Private _marginGrp As Integer = 22
      Private _rightWidth As Integer = 450
      Private _heightSections As Integer = 68

      Private _controller As TPipelineController
      Private _actions As TPipelineActions

      Sub New(pController As TPipelineController, pTitle As String = &quot;Processar arquivos&quot;)
         MyBase.New(pTitle, True)
         me.SizeWidth = 70
         me.SizeHeight = 80
         me.Width.Min = 900
         me.Height.Min = 650
         me.SizeWidth = 90
         me.SizeHeight = 90
         me._build()
         me._controller = pController
         me._actions = New TPipelineActions(me, me._controller)
      End Sub

      Private Sub _build()
         me._buildTopBar()
         me._buildHeader()
         me._buildContent()
         me._buildFooter()
      End Sub

      Private Sub _buildTopBar()
         me.TopBtnExport = me.TopBar.AddButton(&quot;export&quot;, &quot;Exportar&quot;, me.resources.IconExport, &quot;Exportar resultados&quot;, -1, &quot;Ctrl+E&quot;)
         me.TopBtnRead = me.TopBar.AddButton(&quot;Read&quot;, &quot;Importar&quot;, me.resources.IconRead, &quot;Importar arquivo&quot;, -1, &quot;Ctrl+I&quot;)
      End Sub

      Private Sub _buildHeader()
         me.Header.Height = me._heightSections
         Dim _grp As New Forms.ControlGroup(me.Header)
         _grp.Align = alClient
         _grp.Caption = &quot;1. Configurações de Entrada &quot;
         _grp.AlignWithMargins = True
         me._setMargins(_grp.Margins, 1, 1, 1, 1)

         Dim _workArea As Control = Control.BuildContainer(_grp.Parent, &quot;header_area&quot;, alClient)
         _workArea.SetMargins(me._margins, me._marginGrp, me._margins, me._margins)

         Dim _leftSchema As Control = Control.BuildContainer(_workArea.AsControl, &quot;h_left_schema&quot;, alLeft)
         _leftSchema.AsControl.Width = 160
         me.InSchemaSource = New TComboEditor(_leftSchema.AsControl, &quot; Modelo:&quot;)
         me.InSchemaSource.LabelPosition = alTop
         me.InSchemaSource.Align = alClient

         Dim _leftDS As Control = Control.BuildContainer(_workArea.AsControl, &quot;h_left_ds&quot;, alLeft)
         _leftDS.AsControl.Width = 140
         me.InDataSourceType = New TComboEditor(_leftDS.AsControl, &quot; Formato do Arquivo:&quot;)
         me.InDataSourceType.LabelPosition = alTop
         me.InDataSourceType.Align = alClient

         Dim _leftNav As Control = Control.BuildContainer(_workArea.AsControl, &quot;h_left_nav&quot;, alLeft)
         _leftNav.AsControl.Width = 120
         me.InNavigatorType = New TComboEditor(_leftNav.AsControl, &quot; Orientação:&quot;)
         me.InNavigatorType.LabelPosition = alTop
         me.InNavigatorType.Align = alClient

         Dim _right As Control = Control.BuildContainer(_workArea.AsControl, &quot;h_right&quot;, alRight)
         _right.AsControl.Width = 120
         Dim ctnButton As New TContaineEditor(_right.AsControl, &quot;&quot;)
         ctnButton.LabelPosition = alTop
         ctnButton.Align = alClient
         me.BtnRead = New Forms.FlatButton(ctnButton.Container)
         me.BtnRead.Align = alTop
         me.BtnRead.Text = &quot;Importar&quot;
         me.BtnRead.AlignWithMargins = True
         me._setMargins(me.BtnRead.Margins, 0, 0, 0, 2)

         Dim _center As Control = Control.BuildContainer(_workArea.AsControl, &quot;h_center&quot;, alClient)
         me.InPathSource = New TButtonTextEditor(_center.AsControl, &quot; Arquivo de Origem:&quot;)
         me.InPathSource.LabelPosition = alTop
         me.InPathSource.ImageBase64 = me.resources.IconFolder
         me.InPathSource.OnlyRead = True
         me.InPathSource.TabStop = False
         me.InPathSource.Align = alClient
      End Sub

      Private Sub _buildContent()

         Dim _logArea As Control = Control.BuildContainer(me.Content, &quot;log_area&quot;, alTop)
         _logArea.AsControl.Height = 120
         Dim _grpLog As New Forms.ControlGroup(_logArea.AsControl)
         _grpLog.Align = alClient
         _grpLog.Caption = &quot;Status do Processamento &quot;

         me.LogMemo = New Forms.MemoTextBox(_grpLog.Parent)
         me.LogMemo.Align = alClient
         me.LogMemo.ReadOnly = True
         me.LogMemo.TabStop = False
         me.LogMemo.AlignWithMargins = True
         me._setMargins(me.LogMemo.Margins, me._margins, me._marginGrp, me._margins, me._margins)

         Dim _dataArea As Control = Control.BuildContainer(me.Content, &quot;data_area&quot;, alClient)

         Dim _groupsContainer As Control = Control.BuildContainer(_dataArea.AsControl, &quot;grp_cont&quot;, alRight)
         _groupsContainer.AsControl.Width = me._rightWidth

         Dim _splitter As New TSplitter(_dataArea.AsControl)
         _splitter.Parent = _dataArea.AsControl
         _splitter.Align = alRight
         _splitter.Width = 2
         _splitter.Color = rgb(192, 192, 192)

         Dim _recordsContainer As Control = Control.BuildContainer(_dataArea.AsControl, &quot;rec_cont&quot;, alClient)

         Dim _grpRec As New Forms.ControlGroup(_recordsContainer.AsControl)
         _grpRec.Align = alClient
         _grpRec.Caption = &quot; Visualização dos Dados &quot;
         me.GridRecords = New Forms.Grid(_grpRec.Parent)
         me._setMargins(me.GridRecords.Margins, me._margins, me._marginGrp, me._margins, me._margins)
         With me.GridRecords
            .Align = alClient
            .AlignWithMargins = True
            .GridOptions.ColSizing = True
            .GridOptions.RowSelect = True
            .SortHeader = True
            .TabStop = False
         End With

         Dim _grpGrp As New Forms.ControlGroup(_groupsContainer.AsControl)
         _grpGrp.Align = alClient
         _grpGrp.Caption = &quot; Revisão de Grupos e Destinos &quot;
         me.GridGroups = New Forms.Grid(_grpGrp.Parent)
         me._setMargins(me.GridGroups.Margins, me._margins, me._marginGrp, me._margins, me._margins)
         With me.GridGroups
            .Align = alClient
            .AlignWithMargins = True
            .GridOptions.ColSizing = True
            .GridOptions.RowSelect = True
            .SortHeader = True
            .ColCount = 5
            .Cells(0, 0) = &quot;Chave&quot;
            .Cells(1, 0) = &quot;Qtd. Registros&quot;
            .Cells(2, 0) = &quot;Status&quot;
            .Cells(3, 0) = &quot;Caminho&quot;
            .Cells(4, 0) = &quot;ID&quot;
            .AutoSize = True
            .TabStop = False
         End With
      End Sub

      Private Sub _buildFooter()
         me.Footer.Height = me._heightSections
         Dim _grp As New Forms.ControlGroup(me.Footer)
         _grp.Align = alClient
         _grp.Caption = &quot;2. Configurações de Saída &quot;
         _grp.AlignWithMargins = True
         me._setMargins(_grp.Margins, 1, 1, 1, 1)

         Dim _workArea As Control = Control.BuildContainer(_grp.Parent, &quot;footer_area&quot;, alClient)
         _workArea.SetMargins(me._margins, me._marginGrp, me._margins, me._margins)

         Dim _leftDS As Control = Control.BuildContainer(_workArea.AsControl, &quot;f_left_ds&quot;, alLeft)
         _leftDS.AsControl.Width = 140
         me.OutDataSourceType = New TComboEditor(_leftDS.AsControl, &quot; Formato do Arquivo:&quot;)
         me.OutDataSourceType.LabelPosition = alTop
         me.OutDataSourceType.Align = alClient

         Dim _leftNav As Control = Control.BuildContainer(_workArea.AsControl, &quot;f_left_nav&quot;, alLeft)
         _leftNav.AsControl.Width = 120
         me.OutNavigatorType = New TComboEditor(_leftNav.AsControl, &quot; Orientação:&quot;)
         me.OutNavigatorType.LabelPosition = alTop
         me.OutNavigatorType.Align = alClient

         Dim _leftGrp As Control = Control.BuildContainer(_workArea.AsControl, &quot;f_left_grp&quot;, alLeft)
         _leftGrp.AsControl.Width = 160
         me.InGrouperOutput = New TComboEditor(_leftGrp.AsControl, &quot; Agrupamento:&quot;)
         me.InGrouperOutput.LabelPosition = alTop
         me.InGrouperOutput.Align = alClient

         Dim _right As Control = Control.BuildContainer(_workArea.AsControl, &quot;f_right&quot;, alRight)
         _right.AsControl.Width = 120
         Dim ctnButton As New TContaineEditor(_right.AsControl, &quot;&quot;)
         ctnButton.LabelPosition = alTop
         ctnButton.Align = alClient
         me.BtnExport = New Forms.FlatButton(ctnButton.Container)
         me.BtnExport.Text = &quot;EXPORTAR&quot;
         me.BtnExport.Align = alClient
         me.BtnExport.AlignWithMargins = True
         me._setMargins(me.BtnExport.Margins, 0, 0, 0, 2)

         Dim _center As Control = Control.BuildContainer(_workArea.AsControl, &quot;f_center&quot;, alClient)
         me.InPathOutput = New TButtonTextEditor(_center.AsControl, &quot; Destino:&quot;)
         me.InPathOutput.LabelPosition = alTop
         me.InPathOutput.ImageBase64 = me.resources.IconFolder
         me.InPathOutput.OnlyRead = True
         me.InPathOutput.TabStop = False
         me.InPathOutput.Align = alClient
      End Sub

      Private Sub _setMargins(pMargins As TMargins, pLeft As Integer, pTop As Integer, pRight As Integer, pBottom As Integer)
         With pMargins
            .Left = pLeft
            .Top = pTop
            .Right = pRight
            .Bottom = pBottom
         End With
      End Sub

      Sub Free()
         If me._actions &lt;&gt; NULL Then me._actions.Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
