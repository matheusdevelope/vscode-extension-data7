&apos;@Module-Imported
Namespace mod_pipeline_group_key

   Class TGroupKey
      Inherits BaseItem

      Private _key As String
      Private _separator As String
      Private _parts As StringList = New StringList()

      Property Key As String
         Get
            Key = me._key
         End Get
      End Property

      Property Separator As String
         Get
            Separator = me._separator
         End Get
      End Property

      Property Parts As StringList
         Get
            Parts = me._parts
         End Get
      End Property

      Sub New(pKey As String, pSeparator As String)
         MyBase.New()
         me._key = pKey
         me._separator = pSeparator
         me.Parse()
      End Sub

      Protected Sub Parse()
         me._parts.Clear()
         If me._key = &quot;&quot; Then Exit Sub
         If me._key &lt;&gt; &quot;&quot; Then
            me._parts.LineBreak = me._separator
            me._parts.Text = me._key
         End If
      End Sub

      Function HasParts() As Boolean
         HasParts = me._parts.Count &gt; 0
      End Function

      Function Part(pIndex As Integer) As String
         Part = me._parts.Strings(pIndex)
      End Function

      Function Count() As Integer
         Count = me._parts.Count
      End Function

      Function Copy() As TGroupKey
         Copy = New TGroupKey(me._key, me._separator)
      End Function

      Function ToString(pPrint As Boolean = False) As String
         With console.Block(&quot;TGroupKey&quot;)
            .Prop(&quot;Key&quot;, me.Key)
            .Prop(&quot;Separator&quot;, me.Separator)
            .Prop(&quot;Parts&quot;, me.Parts.Text)
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         If me._parts &lt;&gt; NULL Then me._parts.Free()
         MyBase.Free()
      End Sub

   End Class

