      Protected Overridable Overrides Sub _loadFromFile(pPath As String)
         me._grid.LoadFromXLS(pPath)
      End Sub

      Protected Overridable Overrides Sub _saveToFile(pPath As String)
         me._grid.ExportToExcel(pPath)
