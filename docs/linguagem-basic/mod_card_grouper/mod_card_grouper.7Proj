&apos;@Module-Imported
Namespace mod_pipeline_grouper

   Class TGrouper

      Protected _name As String
      Private _definition As TGroupDefinition

      Property Definition As TGroupDefinition
         Get
            Definition = me._definition
         End Get
         Set(pValue As TGroupDefinition)
            If me._definition &lt;&gt; NULL Then me._definition.Free()
            me._definition = pValue.Copy()
         End Set
      End Property

      Sub New(pSeparador As String = &quot;&quot;, pName As String = &quot;TGroupDefinition&quot;)
         MyBase.New()
         me._name = pName
         me._definition = New TGroupDefinition(pSeparador)
      End Sub

      Sub New(pDefinition As TGroupDefinition, pName As String = &quot;TGroupDefinition&quot;)
         MyBase.New()
         me._name = pName
         me.Definition = pDefinition
      End Sub

      Function Execute(pRecors As TRecordList) As TGroupList
         Dim groups As New TGroupList()
         Dim i As Integer
         Dim count As Integer = pRecors.Count - 1
         For i = 0 To count
            Dim rec As TRecord = pRecors.Take(i)
            If rec.Selected
               Dim keyStr As String = me._definition.GetKey(rec)
               Dim group As TGroup
               If groups.Has(keyStr) Then
                  group = groups.Take(keyStr)
               Else
                  group = New TGroup(New TGroupKey(keyStr, me._definition.Separator))
                  groups.Add(group)
               End If
               group.Items.Add(rec)
            End If
         Next
         Execute = groups
      End Function

      Overridable Function ToString(pPrint As Boolean = False) As String
         With console.Block(me._name)
            .Prop(&quot;Definition&quot;, me.Definition.ToString())
            .Close()
            .Printe(pPrint)
            ToString = .Text
            .Free()
         End With
      End Function

      Sub Free()
         MyBase.Free()
      End Sub

   End Class

End Namespace</Codigo>
