# Files excluded from the .vsix package.
# Everything in `src/` is compiled to `out/`; the .ts files don't need to ship.

.vscode/**
.vscode-test/**
src/**
.gitignore
.gitattributes
.cursor/**
.github/**

# Build/dev artefacts
node_modules/**
tsconfig.json
**/tsconfig.json
**/*.map
**/*.ts
!out/**/*.d.ts

# Linter and formatter configs (developer tooling, not runtime).
.editorconfig
.prettierrc
.prettierrc.*
.prettierignore
eslint.config.*
.eslintrc.*
.eslintignore

# Documentation that lives in the repo but doesn't need to ship in the package.
docs/**
project_context.md
CONTRIBUTING.md
CHANGELOG.md
scripts/**

# External documentation snapshots that should never be packaged.
Documentacao Classes Form Delphi/**

# Test artefacts
**/*.test.js
out/test/**

# MCP server: only the bundled binary + the articles data file ship in the VSIX.
# The unbundled out/mcp/server.js + per-module files are excluded; the single
# self-contained out/mcp/server.bundled.js is what external clients launch.
out/mcp/server.js
out/mcp/server.js.map
out/mcp/resources/**
out/mcp/tools/**
out/mcp/prompts/**
out/mcp/runtime/**
!out/mcp/server.bundled.js
!out/mcp/data/**
