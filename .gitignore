# is commented out by default.
#.vscode/

# Node / npm
node_modules/
npm-debug.log*
yarn-error.log
package-lock.json.bak

# TypeScript / build output
out/
dist/
*.tsbuildinfo

# Linter / formatter caches
.eslintcache
.prettiercache

# Coverage and test artefacts
coverage/
.nyc_output/
.vscode-test/

# VS Code Extension package output
*.vsix

# Logs
*.log

# OS / archive scratch (locally cached external docs are intentionally large
